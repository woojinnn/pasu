{
  "name": "pasu-extension",
  "version": "0.1.0",
  "private": true,
  "description": "Policy-engine-backed wallet transaction safety extension",
  "workspaces": [
    "dashboard"
  ],
  "scripts": {
    "dev:chrome": "yarn prepare:defaults && yarn prepare:wasm && cross-env TARGET_BROWSER=chrome webpack --config webpack/webpack.dev.js --watch",
    "dev:firefox": "yarn prepare:defaults && yarn prepare:wasm && cross-env TARGET_BROWSER=firefox webpack --config webpack/webpack.dev.js --watch",
    "build:chrome": "yarn prepare:defaults && yarn prepare:wasm && cross-env TARGET_BROWSER=chrome webpack --config webpack/webpack.prod.js",
    "build:firefox": "yarn prepare:defaults && yarn prepare:wasm && cross-env TARGET_BROWSER=firefox webpack --config webpack/webpack.prod.js",
    "build:options": "yarn workspace pasu-dashboard build",
    "build:ext": "run-s build:chrome build:options",
    "prepare:defaults": "node scripts/copy-default-policies.js && node scripts/copy-default-manifests.js && node scripts/copy-method-catalog.js",
    "prepare:wasm": "../scripts/wasm-build.sh",
    "build": "run-s build:chrome build:firefox",
    "zip:chrome": "web-ext build -s dist/chrome -a dist -n chrome.zip -o",
    "zip:firefox": "web-ext build -s dist/firefox -a dist -n firefox.zip -o",
    "zip": "run-p zip:chrome zip:firefox",
    "clean": "rimraf dist",
    "typecheck": "yarn prepare:wasm && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "prettier --write ."
  },
  "dependencies": {
    "@metamask/post-message-stream": "^8.1.0",
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "canonicalize": "^3.0.0",
    "eth-rpc-errors": "^4.0.3",
    "jszip": "^3.10.1",
    "object-hash": "^3.0.0",
    "process": "^0.11.10",
    "viem": "^2.13.7",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10",
    "@testing-library/react": "^16",
    "@types/chrome": "^0.0.268",
    "@types/object-hash": "^3.0.6",
    "@types/webextension-polyfill": "^0.10.7",
    "@vitest/ui": "^4.1.5",
    "buffer": "^6.0.3",
    "copy-webpack-plugin": "^12.0.2",
    "cross-env": "^7.0.3",
    "css-loader": "^7.1.4",
    "dotenv-webpack": "^8.1.0",
    "happy-dom": "^20.9.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.3.1",
    "rimraf": "^5.0.7",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.7.3",
    "vitest": "^4.1.5",
    "web-ext": "^8.0.0",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4",
    "webpack-merge": "^5.10.0",
    "wext-manifest-loader": "^2.4.2",
    "wext-manifest-webpack-plugin": "^1.4.1"
  },
  "packageManager": "yarn@4.14.1"
}
