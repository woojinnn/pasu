# Browser extension production build-time config. Copy to `.env` and fill in.
# `.env` is gitignored; webpack's dotenv plugin injects these into
# `process.env.*` at build time (see `webpack/webpack.common.js`).
#
# Development builds intentionally do NOT read `.env`, so a prod config here
# cannot accidentally point `yarn dev:chrome` at prod. For dev overrides, use
# command-line env vars or copy selected values to `.env.development`.

# Policy server base URL — the dashboard + SW talk to this host for auth,
# wallets, and policy storage. Defaults to the deployed instance.
DAMBI_SERVER_URL=https://dambi-policy.duckdns.org

# Optional. Without keys the extension falls back to public free-tier RPCs.
ALCHEMY_API_KEY=
INFURA_API_KEY=

# Registry bundle / token / index API base URL. The SW fetches declarative
# adapter bundles and per-chain token lists from `${REGISTRY_BASE_URL}/...`.
# The packaged build hard-fails when this is missing or non-HTTPS (see
# `webpack/webpack.prod.js`). Override with `DAMBI_ALLOW_INSECURE_REGISTRY=1`
# for local smoke tests only.
# Prod = dedicated project `dambi-registry`. This *.run.app host is the STABLE
# production endpoint — baked into the build via DefinePlugin (never user-entered)
# and carries no project number, so it does not churn. (Custom domain was
# evaluated and declined: no UX value for a build-baked URL.)
REGISTRY_BASE_URL=https://registry-api-v3-65uggwflcq-du.a.run.app

# Policy server JSON-RPC endpoint the SW POSTs evaluations to (actions,
# eval_context, wallet_id) and receives a `policy_request` payload (typed
# actions + state_before/deltas/state_after). Defaults to the local dev
# server when unset; production builds must point at the deployed URL.
POLICY_RPC_BASE_URL=http://127.0.0.1:8787

# Legacy alias still read as a fallback by the SW (orchestrator.ts +
# policy-rpc.ts) for worktrees predating the POLICY_RPC_BASE_URL split.
# New code should read POLICY_RPC_BASE_URL.
POLICY_RPC_URL=http://127.0.0.1:8787

# Registry bundle-signing trust anchor (supply-chain integrity). The SW verifies
# each decode bundle's detached ECDSA P-256 signature against PINNED_BUNDLE_PUBLIC_KEY
# (SPKI base64) BEFORE installing it. Staged rollout:
#   1. sign the registry + publish signatures/ (registryV2 `npm run sign` + publish-index.sh)
#   2. deploy the proxy /signatures/ allowlist
#   3. THEN flip DAMBI_REQUIRE_BUNDLE_SIGNATURE=true here and ship a release.
# When the flag is "true", a missing/invalid signature is FAIL-CLOSED (warn). When
# unset/"false" (default), signatures are not enforced (unsigned registry keeps working).
# Prod public key: `gcloud kms keys versions get-public-key` (SPKI PEM → strip → base64).
# Dev public key:  registryV2 `npm run gen-signing-key` prints it.
DAMBI_REQUIRE_BUNDLE_SIGNATURE=false
# Prod channel pin = `dambi-registry` HSM key `registry-signing/bundle-sign-p256` v1
# (EC_SIGN_P256_SHA256). Public key — safe to commit.
PINNED_BUNDLE_PUBLIC_KEY=MFkwEwYHKoZIzj0CAQYIKoZIzj0DAQcDQgAEn0jv/xWm40uSuypme7DYsvWjGBZdpAL7qxiM5bObv0NpWniN102CZx2y8U/cDAhA+f17FzTPSNtgq/8eS2eVdA==
