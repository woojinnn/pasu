# Optional. Without keys the extension falls back to public free-tier RPCs.
ALCHEMY_API_KEY=
INFURA_API_KEY=

# Registry bundle / token / index API base URL. The SW fetches declarative
# adapter bundles and per-chain token lists from `${REGISTRY_BASE_URL}/...`.
# Phase 3G v2 cutover deployed this to Cloud Run @ asia-northeast3; the
# packaged build hard-fails when this is missing or non-HTTPS (see
# `webpack/webpack.prod.js`). Override with `SCOPEBALL_ALLOW_INSECURE_REGISTRY=1`
# for local smoke tests only.
REGISTRY_BASE_URL=https://registry-api-v2-891268973493.asia-northeast3.run.app

# Phase 5 — rpc-server endpoint for `scopeball.evaluate_v3` JSON-RPC 2.0
# calls. The SW POSTs (envelopes, eval_context, wallet_id) and receives a
# `policy_request` payload (typed actions + state_before/deltas/state_after)
# which it then forwards to the WASM `evaluate_policy_request_json` entry.
# Defaults to the local dev server when unset (`http://127.0.0.1:8787`);
# production builds must point at the deployed Cloud Run policy-rpc URL.
POLICY_RPC_BASE_URL=http://127.0.0.1:8787

# Legacy alias retained for backwards compat with the pre-Phase-5
# `evaluateWithPolicyRpc` path. New code should read POLICY_RPC_BASE_URL.
POLICY_RPC_URL=http://127.0.0.1:8787
