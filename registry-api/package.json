{
  "name": "registry-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Caching authenticated reverse-proxy for the Dambi private adapter registry bucket",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node --enable-source-maps dist/index.js"
  },
  "engines": { "node": ">=20" },
  "dependencies": { "@google-cloud/storage": "^7.16.0" },
  "devDependencies": { "@types/node": "^20.19.0", "canonicalize": "^3.0.0", "typescript": "^5.7.3", "vitest": "^4.1.5" }
}
