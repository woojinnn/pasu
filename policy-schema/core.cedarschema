entity Wallet {
  address: String,
};
entity Protocol;

type Token = {
  chainId: Long,
  address: String,
  symbol: String,
  decimals: Long,
  isNative: Bool,
};

type AmountConstraint = {
  kind: String,
  value?: String,
};

type Validity = {
  expiresAt: String,
  source: String,
};

type UsdValuation = {
  value: decimal,
  asOfTs: Long,
  staleSec: Long,
  sources: Set<String>,
};

type WindowStats = {
  swapVolumeUsd24h?: decimal,
  swapCount24h?: Long
};
