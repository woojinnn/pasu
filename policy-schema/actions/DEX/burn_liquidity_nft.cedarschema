type BurnLiquidityNftContext = {
  nft: AssetRef,
  burnKind: String,
  outputs?: Set<AssetRefWithAmountConstraint>,
  recipient?: String,
  validity?: Validity,

  totalOutputUsd?: UsdValuation,
  nftOwnerIsActor?: Bool,
  recipientIsContract?: Bool,
  windowStats?: WindowStats,
};

action "burn_liquidity_nft" appliesTo {
  principal: Wallet,
  resource: Protocol,
  context: BurnLiquidityNftContext,
};
