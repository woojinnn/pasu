type Permit2Context = {
  base: SignatureBaseContext,

  permitKind: String,
  spender: String,
  token: Token,
  amountHuman: decimal,
  expiration: Long,
  sigDeadline: Long,
  sigDeadlineDeltaSec: Long,
  nonce: String,
  approvalCount: Long,

  nonceValid: Bool,
  isUnlimited: Bool,
  amountHumanClampedAtCeiling: Bool,

  totalApprovedUsd?: UsdValuation,
};

action "signature.permit2" appliesTo {
  principal: Wallet,
  resource: Protocol,
  context: Permit2Context,
};
