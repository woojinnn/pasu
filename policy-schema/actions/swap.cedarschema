type SwapContext = {
  swapMode: String,
  tokenIn: Token,
  tokenOut: Token,
  amountIn: AmountConstraint,
  amountOut: AmountConstraint,
  recipient: String,
  validity?: Validity,
  feeBps?: Long,

  totalInputUsd?: UsdValuation,
  totalMinOutputUsd?: UsdValuation,
  allowancesCoverInputs?: Bool,
  validityDeltaSec?: Long,
};

action "swap" appliesTo {
  principal: Wallet,
  resource: Protocol,
  context: SwapContext,
};
