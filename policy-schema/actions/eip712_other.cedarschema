type Eip712OtherContext = {
  signer: String,
  requestChainId: Long,
  domainChainId: Long,
  verifyingContract: String,
  primaryType: String,
  nowTs: Long,

  domainName: String,
  domainVersion: String,
  domainSalt: String,
  typesJson: String,
  messageJson: String,
};

action "signature.eip712_other" appliesTo {
  principal: Wallet,
  resource: Protocol,
  context: Eip712OtherContext,
};
