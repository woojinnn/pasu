type TransferContext = {
  token: AssetRef,
  from: String,
  recipient: String,

  amount?: AmountConstraint,

  recipientIsContract?: Bool,

  totalUsd?: UsdValuation,
  amountFractionOfPortfolioBps?: Long,
  windowStats?: WindowStats,
};

action "transfer" appliesTo {
  principal: Wallet,
  resource: Protocol,
  context: TransferContext,
};
