type SetApprovalForAllContext = {
  collection: AssetRef,
  operator: String,
  operatorLabel?: String,

  approved: Bool,
  previouslyApproved?: Bool,

  windowStats?: WindowStats,
};

action "set_approval_for_all" appliesTo {
  principal: Wallet,
  resource: Protocol,
  context: SetApprovalForAllContext,
};
