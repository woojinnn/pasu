type VoteContext = {
  governance: String,
  governanceLabel?: String,

  proposalId: String,
  support: String,
  reason?: String,

  votingPower?: String,

  validity?: Validity,
  validityDeltaSec?: Long,
};

action "vote" appliesTo {
  principal: Wallet,
  resource: Protocol,
  context: VoteContext,
};
