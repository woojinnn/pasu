type Eip2612Context = {
  base: SignatureBaseContext,

  owner: String,

  spender: String,
  token: Token,
  valueHuman: decimal,
  deadline: Long,
  deadlineDeltaSec: Long,
  nonce: String,

  nonceValid: Bool,
  isUnlimited: Bool,
  valueHumanClampedAtCeiling: Bool,

  totalApprovedUsd?: UsdValuation,
};

action "signature.eip2612" appliesTo {
  principal: Wallet,
  resource: Protocol,
  context: Eip2612Context,
};
