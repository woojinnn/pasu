# Server profile: LOCAL DASHBOARD DEV (Vite at http://127.0.0.1:5173).
#
# Copy to `.env.local` and fill in the GOOGLE_* + JWT_SECRET values.
# `yarn server:local` (or `scripts/start-policy-server.sh local`) loads
# this file and starts the policy-rpc server.
#
# Use this profile when you are iterating on the dashboard inside the
# Vite dev server (HMR). After Google OAuth, the server redirects to
# http://127.0.0.1:5173/auth/callback and the dashboard reads the token
# fragment via `AuthCallbackPage`.
#
# DO NOT use this profile to test the extension's options page OAuth
# flow — `chrome.identity.launchWebAuthFlow` cannot capture a redirect
# to a real localhost URL. Use `.env.ext` for that.

# Google OAuth 2.0 Web client.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# JWT signing key. Generate with: openssl rand -hex 32
JWT_SECRET=

# Server's OAuth callback — must match Google Cloud Console exactly.
GOOGLE_REDIRECT_URI=http://127.0.0.1:8788/auth/google/callback

# Where the server bounces users after successful OAuth. The dashboard
# at this origin handles the token fragment.
DASHBOARD_URL=http://127.0.0.1:5173

# Server bind address.
POLICY_SERVER_ADDR=127.0.0.1:8788

# Public API URL (used when the server constructs externally-visible URLs).
PUBLIC_API_URL=http://127.0.0.1:8788

# CORS — only local dev origins. The extension's options page does not
# call this server in `local` mode, so its origin is omitted.
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
CORS_ALLOW_PRIVATE_NETWORK=true

# Durable backends (leave unset → in-process SQLite default).
DATABASE_URL=
REDIS_URL=

PASU_SYNC_CONFIG=./pasu-sync.toml
SYNC_WORKER_TICK_SECS=30

ETHERSCAN_API_KEY=
