# Overrides .env for the `local` profile — put shared secrets (GOOGLE_*,
# JWT_SECRET, DATABASE_URL, …) in .env, not here.
#
# Profile: LOCAL DASHBOARD DEV (Vite at http://127.0.0.1:5173).
# `scripts/start-policy-server.sh local` sources `.env` first, then this
# overlay. After Google OAuth the server redirects to
# http://127.0.0.1:5173/auth/callback and the dashboard reads the token
# fragment via `AuthCallbackPage`.
#
# DO NOT use this profile to test the extension's options page OAuth flow —
# `chrome.identity.launchWebAuthFlow` cannot capture a redirect to a real
# localhost URL. Use `.env.ext` for that.
#
# Copy to `.env.local`. These match the base `.env` defaults, so for plain
# local dev an empty overlay also works; they are listed for clarity.

# Server's OAuth callback — must match Google Cloud Console exactly.
GOOGLE_REDIRECT_URI=http://127.0.0.1:8788/auth/google/callback

# Where the server bounces users after successful OAuth. The dashboard at
# this origin handles the token fragment.
DASHBOARD_URL=http://127.0.0.1:5173

# CORS — only local dev origins. The extension's options page does not call
# this server in `local` mode, so its origin is omitted.
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
