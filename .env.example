# Copy to `.env` and fill in. `.env` is gitignored.

# Google OAuth 2.0 Web client.
# Create at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must match GOOGLE_REDIRECT_URI below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# JWT signing key. Generate with: openssl rand -hex 32
# 32 bytes (64 hex chars) recommended.
JWT_SECRET=

# OAuth redirect — must match Google Cloud Console exactly.
GOOGLE_REDIRECT_URI=http://127.0.0.1:8788/auth/google/callback

# Dashboard URL — where users land after successful OAuth.
DASHBOARD_URL=http://127.0.0.1:5173

# Server bind address.
SIMULATION_SERVER_ADDR=127.0.0.1:8788

# Public API URL used when the server needs to construct externally-visible
# callback URLs in cloud deployments.
PUBLIC_API_URL=http://127.0.0.1:8788

# Comma-separated dashboard / extension origins allowed by CORS.
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:5174,http://localhost:5174
CORS_ALLOW_PRIVATE_NETWORK=true

# Durable cloud backends. Leave unset for local SQLite + in-process defaults.
DATABASE_URL=
REDIS_URL=

# Sync config path for the API process and the standalone sync worker.
SCOPEBALL_SYNC_CONFIG=./scopeball-sync.toml
SYNC_WORKER_TICK_SECS=30

# Optional — Etherscan V2 unified API key. Get one at
# https://etherscan.io/myapikey (free, 2-min signup).
#
# When set, `POST /wallets` discovers EVERY ERC-20 the wallet has
# interacted with. When unset, the server falls back to a hard-coded
# top-50 token list per chain (covers USDC, USDT, WETH, WBTC, …).
ETHERSCAN_API_KEY=
