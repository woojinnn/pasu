{
  "$schema": "Cloudy Pond design tokens — sampled from Cloudy Pond _ Pass _ Warn _ Fail.png",
  "$convention": "Every color's base hex (Sage #9CC58D, Slate #475569, Cyan #A4C9D1, Fog #F1F2F0, Sage Leaf #7CB069, Honey #D6A55D, Clay #C77268) sits at the 500 stop. Stops marked `sampled:true` were extracted from the source PNG; stops marked `interpolated:true` were synthesised toward white to fill the light end (Warn / Fail only).",

  "base": {
    "sage": {
      "role": "Primary",
      "base": "#9CC58D",
      "ramp": {
        "50":  { "hex": "#F8F9F6", "sampled": true },
        "100": { "hex": "#EBF3E8", "sampled": true },
        "200": { "hex": "#D9E9D3", "sampled": true },
        "300": { "hex": "#C5DDBD", "sampled": true },
        "400": { "hex": "#B0D1A4", "sampled": true },
        "500": { "hex": "#9CC58D", "sampled": true, "base": true },
        "600": { "hex": "#7FA172", "sampled": true },
        "700": { "hex": "#637E59", "sampled": true },
        "800": { "hex": "#44583D", "sampled": true },
        "900": { "hex": "#283523", "sampled": true }
      }
    },
    "slate": {
      "role": "Secondary",
      "base": "#475569",
      "ramp": {
        "50":  { "hex": "#EFF0F2", "sampled": true },
        "100": { "hex": "#D7DBDF", "sampled": true },
        "200": { "hex": "#B5BBC4", "sampled": true },
        "300": { "hex": "#9099A5", "sampled": true },
        "400": { "hex": "#697485", "sampled": true },
        "500": { "hex": "#475569", "sampled": true, "base": true },
        "600": { "hex": "#384455", "sampled": true },
        "700": { "hex": "#2A3441", "sampled": true },
        "800": { "hex": "#1B222C", "sampled": true },
        "900": { "hex": "#0D1118", "sampled": true }
      }
    },
    "cyan": {
      "role": "Tertiary",
      "base": "#A4C9D1",
      "ramp": {
        "50":  { "hex": "#F8F9F9", "sampled": true },
        "100": { "hex": "#EDF4F6", "sampled": true },
        "200": { "hex": "#DCEAED", "sampled": true },
        "300": { "hex": "#CAE0E4", "sampled": true },
        "400": { "hex": "#B6D4DA", "sampled": true },
        "500": { "hex": "#A4C9D1", "sampled": true, "base": true },
        "600": { "hex": "#85A4AB", "sampled": true },
        "700": { "hex": "#688186", "sampled": true },
        "800": { "hex": "#485A5E", "sampled": true },
        "900": { "hex": "#2B3639", "sampled": true }
      }
    },
    "fog": {
      "role": "Neutral",
      "base": "#F4F5F3",
      "$note": "Intentional exception to base-at-500 rule — Fog is neutral surface, not brand. Base pointer at 400 gives a brighter, cleaner page background. 500 stop (#F1F2F0) is retained from source PNG and remains available as the slightly heavier fog tone.",
      "ramp": {
        "50":  { "hex": "#FEFEFE", "sampled": true },
        "100": { "hex": "#FCFCFC", "sampled": true },
        "200": { "hex": "#FAFAF9", "sampled": true },
        "300": { "hex": "#F7F7F6", "sampled": true },
        "400": { "hex": "#F4F5F3", "sampled": true, "base": true },
        "500": { "hex": "#F1F2F0", "sampled": true },
        "600": { "hex": "#C5C6C4", "sampled": true },
        "700": { "hex": "#9B9C9A", "sampled": true },
        "800": { "hex": "#6E6E6D", "sampled": true },
        "900": { "hex": "#434343", "sampled": true }
      }
    }
  },

  "status": {
    "pass": {
      "role": "Pass",
      "base": "#7CB069",
      "ramp": {
        "50":  { "hex": "#F4F9F3", "sampled": true },
        "100": { "hex": "#E4EFE1", "sampled": true },
        "200": { "hex": "#CDE1C5", "sampled": true },
        "300": { "hex": "#B2D1A8", "sampled": true },
        "400": { "hex": "#96C087", "sampled": true },
        "500": { "hex": "#7CB069", "sampled": true, "base": true },
        "600": { "hex": "#648F55", "sampled": true },
        "700": { "hex": "#4E7041", "sampled": true },
        "800": { "hex": "#354E2C", "sampled": true },
        "900": { "hex": "#1E2E18", "sampled": true }
      }
    },
    "warn": {
      "role": "Warn",
      "base": "#D69238",
      "$note": "Diverges from source PNG by design — Honey hue shifted toward amber/orange (~hue 50) to push WARN further from PASS green on the colour wheel. Improves identifiability for protan/deutan colour blindness (4-channel redundant coding still applies via left border + icon + bg tint + 700-stop text).",
      "source_stop_count": 7,
      "source_base": "#D6A55D",
      "ramp": {
        "50":  { "hex": "#FBF2DF", "interpolated": true },
        "100": { "hex": "#F6DFB0", "interpolated": true },
        "200": { "hex": "#EEC781", "interpolated": true },
        "300": { "hex": "#E3AE56", "interpolated": true },
        "400": { "hex": "#DA9D43", "interpolated": true },
        "500": { "hex": "#D69238", "interpolated": true, "base": true },
        "600": { "hex": "#AC7529", "interpolated": true },
        "700": { "hex": "#80571F", "interpolated": true },
        "800": { "hex": "#573C16", "interpolated": true },
        "900": { "hex": "#2D210C", "interpolated": true }
      }
    },
    "fail": {
      "role": "Fail",
      "base": "#C77268",
      "source_stop_count": 8,
      "ramp": {
        "50":  { "hex": "#FAEAE6", "interpolated": true },
        "100": { "hex": "#F4D9D5", "interpolated": true },
        "200": { "hex": "#EDC9C4", "sampled": true },
        "300": { "hex": "#E2ADA5", "sampled": true },
        "400": { "hex": "#D48E85", "sampled": true },
        "500": { "hex": "#C77268", "sampled": true, "base": true },
        "600": { "hex": "#A25C54", "sampled": true },
        "700": { "hex": "#7F4740", "sampled": true },
        "800": { "hex": "#59302B", "sampled": true },
        "900": { "hex": "#361B18", "sampled": true }
      }
    }
  },

  "radius": {
    "sm":    "10px",
    "input": "12px",
    "md":    "14px",
    "lg":    "20px",
    "pill":  "999px"
  },

  "spacing": {
    "s1": "4px", "s2": "8px", "s3": "12px", "s4": "16px",
    "s6": "24px", "s8": "32px", "s12": "48px", "s16": "64px"
  },

  "type": {
    "sans": "\"IBM Plex Sans KR\", \"IBM Plex Sans\", system-ui, -apple-system, \"Apple SD Gothic Neo\", \"Malgun Gothic\", sans-serif",
    "mono": "\"IBM Plex Mono\", ui-monospace, SFMono-Regular, Menlo, Consolas, monospace",
    "$note": "Sans: IBM Plex Sans KR — humanist sans with subtle slab influence, dusty·earthy character, full Korean coverage, less default than Pretendard/Inter in dashboard contexts. Mono: IBM Plex Mono — same family system, slab feet keep engineering tone, less saturated in AI-tool screenshots than JetBrains Mono."
  },

  "interactive": {
    "focus-ring": {
      "$desc": "WCAG AA — 3:1 against any background. 2px Sage 500 ring with 2px Fog 50 offset for inv surfaces.",
      "outline":          "2px solid #9CC58D",
      "outline-offset":   "2px",
      "shadow-on-light":  "0 0 0 3px rgba(156,197,141,0.32)",
      "shadow-on-slate":  "0 0 0 2px rgba(255,255,255,0.4), 0 0 0 4px rgba(156,197,141,0.6)"
    },
    "disabled": {
      "opacity": 0.45,
      "cursor":  "not-allowed"
    },
    "error": {
      "border":  "#C77268",
      "shadow":  "0 0 0 3px rgba(199,114,104,0.18)",
      "text":    "#7F4740"
    }
  }
}
