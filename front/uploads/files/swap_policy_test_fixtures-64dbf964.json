      "meta": {
        "from": "0xA1c4000000000000000000000000000000007e29",
        "to": "0xE592427A0AEce92De3Edee1F18E0157C05861564",
        "selector": "0x414bf389",
        "chainId": 1,
        "value": "0x0",
        "nonce": 43,
        "blockTimestamp": 1748649600,
        "validityDeltaSec": 18,
        "recipientIsContract": false,
        "totalInputUsd": 4800.0,
        "isSimulated": true
      },
      "context": {
        "venue": "uniswap_v3",
        "tokenIn": "USDC",
        "tokenOut": "WETH",
        "direction": { "kind": "exact_input", "amountIn": "0x...", "minAmountOut": "0x...", "amountInUsd": 4800.0, "amountOutUsd": 4710.0 },
        "recipient": "0xA1c4000000000000000000000000000000007e29",
        "slippageBp": 150,
