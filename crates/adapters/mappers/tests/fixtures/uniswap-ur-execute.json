{
  "type": "adapter_function",
  "id": "uniswap/universal-router/execute@1.0.0",
  "publisher": "uniswap.eth",
  "match": {
    "chain_ids": [1, 8453, 10, 42161, 137],
    "to": [
      "0x66a9893cC07D91D95644AEDD05D03f95e1dBA8Af",
      "0x4c82d1FBfe28C977cbB58D8C7Ff8FCf9F70A2cca"
    ],
    "selector": "0x3593564c"
  },
  "abi_fragment": {
    "function_name": "execute",
    "abi": {
      "name": "execute",
      "type": "function",
      "inputs": [
        { "name": "commands", "type": "bytes" },
        { "name": "inputs",   "type": "bytes[]" },
        { "name": "deadline", "type": "uint256" }
      ]
    }
  },
  "emit": {
    "strategy": "opcode_stream_dispatch",
    "dispatcher_id": "universal_router",
    "mask": "0x7f",
    "allow_revert_bit": "0x80",
    "unknown_opcode_policy": "warn",
    "per_opcode_emit": {
      "0x00": {
        "name": "V3_SWAP_EXACT_IN",
        "category": "dex",
        "action": "swap",
        "fields": {
          "inputToken.asset.kind":     { "literal": "erc20" },
          "inputToken.asset.address":  { "fn": "unfold_v3_path",
                                         "args": [{ "from": "$.args.path" },
                                                  { "literal": "first_token" }] },
          "inputToken.amount.kind":    { "literal": "exact" },
          "inputToken.amount.value":   { "from": "$.args.amountIn" },
          "outputToken.asset.kind":    { "literal": "erc20" },
          "outputToken.asset.address": { "fn": "unfold_v3_path",
                                         "args": [{ "from": "$.args.path" },
                                                  { "literal": "last_token" }] },
          "outputToken.amount.kind":   { "literal": "min" },
          "outputToken.amount.value":  { "from": "$.args.amountOutMin" },
          "recipient":                 { "from": "$.args.recipient" }
        }
      },
      "0x01": {
        "name": "V3_SWAP_EXACT_OUT",
        "category": "dex",
        "action": "swap",
        "fields": {
          "inputToken.asset.kind":     { "literal": "erc20" },
          "inputToken.asset.address":  { "fn": "unfold_v3_path",
                                         "args": [{ "from": "$.args.path" },
                                                  { "literal": "last_token" }] },
          "inputToken.amount.kind":    { "literal": "max" },
          "inputToken.amount.value":   { "from": "$.args.amountInMax" },
          "outputToken.asset.kind":    { "literal": "erc20" },
          "outputToken.asset.address": { "fn": "unfold_v3_path",
                                         "args": [{ "from": "$.args.path" },
                                                  { "literal": "first_token" }] },
          "outputToken.amount.kind":   { "literal": "exact" },
          "outputToken.amount.value":  { "from": "$.args.amountOut" },
          "recipient":                 { "from": "$.args.recipient" }
        }
      },
      "0x04": {
        "name": "SWEEP",
        "category": "misc",
        "action": "transfer",
        "fields": {
          "token.asset.kind":        { "literal": "erc20" },
          "token.asset.address":     { "from": "$.args.token" },
          "token.amount.kind":       { "literal": "min" },
          "token.amount.value":      { "from": "$.args.amountMin" },
          "from":                    { "from": "$.args.recipient" },
          "recipient":               { "from": "$.args.recipient" }
        }
      },
      "0x08": {
        "name": "V2_SWAP_EXACT_IN",
        "category": "dex",
        "action": "swap",
        "fields": {
          "inputToken.asset.kind":     { "literal": "erc20" },
          "inputToken.asset.address":  { "fn": "select_address",
                                         "args": [{ "from": "$.args.path" },
                                                  { "literal": 0 }] },
          "inputToken.amount.kind":    { "literal": "exact" },
          "inputToken.amount.value":   { "from": "$.args.amountIn" },
          "outputToken.asset.kind":    { "literal": "erc20" },
          "outputToken.asset.address": { "fn": "select_address",
                                         "args": [{ "from": "$.args.path" },
                                                  { "literal": -1 }] },
          "outputToken.amount.kind":   { "literal": "min" },
          "outputToken.amount.value":  { "from": "$.args.amountOutMin" },
          "recipient":                 { "from": "$.args.recipient" }
        }
      },
      "0x09": {
        "name": "V2_SWAP_EXACT_OUT",
        "category": "dex",
        "action": "swap",
        "fields": {
          "inputToken.asset.kind":     { "literal": "erc20" },
          "inputToken.asset.address":  { "fn": "select_address",
                                         "args": [{ "from": "$.args.path" },
                                                  { "literal": 0 }] },
          "inputToken.amount.kind":    { "literal": "max" },
          "inputToken.amount.value":   { "from": "$.args.amountInMax" },
          "outputToken.asset.kind":    { "literal": "erc20" },
          "outputToken.asset.address": { "fn": "select_address",
                                         "args": [{ "from": "$.args.path" },
                                                  { "literal": -1 }] },
          "outputToken.amount.kind":   { "literal": "exact" },
          "outputToken.amount.value":  { "from": "$.args.amountOut" },
          "recipient":                 { "from": "$.args.recipient" }
        }
      },
      "0x0a": {
        "name": "PERMIT2_PERMIT",
        "category": "misc",
        "action": "permit",
        "fields": {
          "permitKind":            { "literal": "permit2_single" },
          "token.kind":            { "literal": "erc20" },
          "token.address":         { "from": "$.args.permitSingle[0][0]" },
          "owner":                 { "from": "$.args.permitSingle[0][0]" },
          "spender":               { "from": "$.args.permitSingle[1]" },
          "amount.kind":           { "literal": "max" },
          "amount.value":          { "from": "$.args.permitSingle[0][1]" },
          "validity.expiresAt":    { "from": "$.args.permitSingle[0][2]" },
          "validity.source":       { "literal": "grant-expiration" },
          "signatureValidity.expiresAt": { "from": "$.args.permitSingle[2]" },
          "signatureValidity.source":    { "literal": "signature-deadline" }
        }
      },
      "0x0b": {
        "name": "WRAP_ETH",
        "category": "misc",
        "action": "wrap",
        "fields": {
          "nativeAsset.asset.kind":     { "literal": "native" },
          "nativeAsset.amount.kind":    { "literal": "min" },
          "nativeAsset.amount.value":   { "from": "$.args.amountMin" },
          "wrappedAsset.asset.kind":    { "literal": "erc20" },
          "wrappedAsset.amount.kind":   { "literal": "min" },
          "wrappedAsset.amount.value":  { "from": "$.args.amountMin" },
          "recipient":                  { "from": "$.args.recipient" }
        }
      },
      "0x0c": {
        "name": "UNWRAP_WETH",
        "category": "misc",
        "action": "unwrap",
        "fields": {
          "wrappedAsset.asset.kind":    { "literal": "erc20" },
          "wrappedAsset.amount.kind":   { "literal": "min" },
          "wrappedAsset.amount.value":  { "from": "$.args.amountMin" },
          "nativeAsset.asset.kind":     { "literal": "native" },
          "nativeAsset.amount.kind":    { "literal": "min" },
          "nativeAsset.amount.value":   { "from": "$.args.amountMin" },
          "recipient":                  { "from": "$.args.recipient" }
        }
      }
    }
  },
  "requires": {
    "imperative": ["universal-router-dispatcher@^1.0"],
    "host_capabilities": ["host:token_metadata"],
    "extension": ">=0.1.0"
  }
}
