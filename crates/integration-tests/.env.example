# v3 decode harness — local secrets template.
# Copy this file to `.env` and fill in real values, then load it before the
# Etherscan flow in README.md §3.B:
#   cp crates/integration-tests/.env.example crates/integration-tests/.env
#   # edit .env, then:
#   set -a; source crates/integration-tests/.env; set +a
#
# Free Etherscan API key: https://etherscan.io/myapikey  (v2 multichain — one key, all chains)
ETHERSCAN_API_KEY=<your-etherscan-api-key>
