POLICY_SERVER_ADDR=0.0.0.0:8788
PUBLIC_API_URL=https://dambi-policy.duckdns.org
DASHBOARD_URL=https://dambi-policy.duckdns.org
CORS_ALLOWED_ORIGINS=https://dambi-policy.duckdns.org,chrome-extension://<published-extension-id>
CORS_ALLOW_PRIVATE_NETWORK=false
DATABASE_URL=postgres://dambi:dambi@postgres:5432/dambi
REDIS_URL=redis://redis:6379/0
REDIS_EVENTS_CHANNEL=policy-server:events
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://dambi-policy.duckdns.org/auth/google/callback
JWT_SECRET=
DAMBI_SYNC_CONFIG=/app/dambi-sync.toml
REQUIRE_SYNC_CONFIG=true
RUN_MIGRATIONS_ON_STARTUP=false
ETHERSCAN_API_KEY=
COINGECKO_API_KEY=
SYNC_WORKER_TICK_SECS=30
SYNC_LOCK_TTL_SECS=120
RUST_LOG=info,policy_server=debug,policy_sync=info
