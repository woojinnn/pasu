POLICY_SERVER_ADDR=0.0.0.0:8788
PUBLIC_API_URL=https://api.scopeball.dev
DASHBOARD_URL=https://app.scopeball.dev
CORS_ALLOWED_ORIGINS=https://app.scopeball.dev,chrome-extension://<published-extension-id>
CORS_ALLOW_PRIVATE_NETWORK=false
DATABASE_URL=postgres://scopeball:scopeball@postgres:5432/scopeball
REDIS_URL=redis://redis:6379/0
REDIS_EVENTS_CHANNEL=policy-server:events
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.scopeball.dev/auth/google/callback
JWT_SECRET=
PASU_SYNC_CONFIG=/app/pasu-sync.toml
REQUIRE_SYNC_CONFIG=true
RUN_MIGRATIONS_ON_STARTUP=false
ETHERSCAN_API_KEY=
COINGECKO_API_KEY=
SYNC_WORKER_TICK_SECS=30
SYNC_LOCK_TTL_SECS=120
RUST_LOG=info,policy_server=debug,policy_sync=info
