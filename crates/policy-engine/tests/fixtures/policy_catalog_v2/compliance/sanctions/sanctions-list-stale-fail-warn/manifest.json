{
  "id": "sanctions-list-stale-fail-warn",
  "schema_version": 2,
  "trigger": { "where": { "action.domain": { "eq": "unknown" } } },
  "policy_rpc": [{
    "id": "sanctions-freshness",
    "method": "address.sanctions",
    "params": { "address": "$.action.target" },
    "outputs": [{ "kind": "context", "field": "sanctionsFresh", "type": "Bool", "from": "$.result.sanctionsFresh", "required": false }],
    "optional": true
  }],
  "custom_context": { "fields": { "sanctionsFresh": "Bool" } }
}
