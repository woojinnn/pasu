{
  "id": "ctr-threshold-swap-warn",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "swap" } } },
  "policy_rpc": [{
    "id": "swap-input-usd",
    "method": "oracle.usd_value",
    "params": {
      "chain_id": "$.root.chain_id",
      "asset": "$.action.tokenIn",
      "amount": "$.action.direction.amountIn"
    },
    "outputs": [{ "kind": "context", "field": "usdValue", "type": "Decimal", "from": "$.result.usd", "required": false }],
    "optional": true
  }],
  "custom_context": { "fields": { "usdValue": "decimal" } }
}
