{
  "id": "approve-spender-fresh-contract",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "erc20_approve" } } },
  "policy_rpc": [{
    "id": "spender-activity",
    "method": "address.activity",
    "params": { "chain_id": "$.root.chain_id", "address": "$.action.spender" },
    "outputs": [
      { "kind": "context", "field": "isContract", "type": "Bool", "from": "$.result.isContract", "required": false },
      { "kind": "context", "field": "firstSeenTs", "type": "Long", "from": "$.result.firstSeenTs", "required": false }
    ],
    "optional": true
  }],
  "custom_context": { "fields": { "isContract": "Bool", "firstSeenTs": "Long" } }
}
