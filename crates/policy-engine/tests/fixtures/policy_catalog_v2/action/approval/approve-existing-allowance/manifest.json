{
  "id": "approve-existing-allowance",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "erc20_approve" } } },
  "policy_rpc": [{
    "id": "existing-allowance",
    "method": "approval.allowance",
    "params": {
      "chain_id": "$.root.chain_id",
      "owner": "$.root.from",
      "asset": "$.action.token",
      "spender": "$.action.spender"
    },
    "outputs": [{
      "kind": "context",
      "field": "hasExistingAllowance",
      "type": "Bool",
      "from": "$.result.hasExisting",
      "required": false
    }],
    "optional": true
  }],
  "custom_context": { "fields": { "hasExistingAllowance": "Bool" } }
}
