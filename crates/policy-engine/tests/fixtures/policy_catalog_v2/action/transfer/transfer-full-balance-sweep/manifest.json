{
  "id": "transfer-full-balance-sweep",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "erc20_transfer" } } },
  "policy_rpc": [{
    "id": "owner-balance",
    "method": "portfolio.balance",
    "params": {
      "chain_id": "$.root.chain_id",
      "owner": "$.root.from",
      "asset": "$.action.token"
    },
    "outputs": [{ "kind": "context", "field": "balance", "type": "String", "from": "$.result.balance", "required": false }],
    "optional": true
  }],
  "custom_context": { "fields": { "balance": "String" } }
}
