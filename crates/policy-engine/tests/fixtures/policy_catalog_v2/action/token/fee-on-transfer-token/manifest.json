{
  "id": "fee-on-transfer-token",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "erc20_transfer" } } },
  "policy_rpc": [{
    "id": "token-meta",
    "method": "token.metadata",
    "params": { "chain_id": "$.root.chain_id", "asset": "$.action.token" },
    "outputs": [{ "kind": "context", "field": "feeBps", "type": "Long", "from": "$.result.feeBps", "required": false }],
    "optional": true
  }],
  "custom_context": { "fields": { "feeBps": "Long" } }
}
