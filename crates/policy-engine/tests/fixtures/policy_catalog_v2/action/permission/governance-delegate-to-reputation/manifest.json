{
  "id": "governance-delegate-to-reputation",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "delegate" } } },
  "policy_rpc": [{
    "id": "delegatee-rep",
    "method": "address.reputation",
    "params": { "chain_id": "$.root.chain_id", "address": "$.action.delegatee" },
    "outputs": [{ "kind": "context", "field": "delegateeFlagged", "type": "Bool", "from": "$.result.flagged", "required": false }],
    "optional": true
  }],
  "custom_context": { "fields": { "delegateeFlagged": "Bool" } }
}
