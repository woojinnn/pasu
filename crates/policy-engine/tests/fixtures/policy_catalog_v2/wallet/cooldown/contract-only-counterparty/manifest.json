{
  "id": "contract-only-counterparty",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "swap" } } },
  "policy_rpc": [{
    "id": "venue-activity",
    "method": "address.activity",
    "params": { "chain_id": "$.root.chain_id", "address": "$.action.venue.router" },
    "outputs": [{ "kind": "context", "field": "venueIsContract", "type": "Bool", "from": "$.result.isContract", "required": false }],
    "optional": true
  }],
  "custom_context": { "fields": { "venueIsContract": "Bool" } }
}
