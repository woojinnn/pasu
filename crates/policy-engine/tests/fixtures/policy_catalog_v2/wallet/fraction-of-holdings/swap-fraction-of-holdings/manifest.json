{
  "id": "swap-fraction-of-holdings",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "swap" } } },
  "policy_rpc": [{
    "id": "holdings-fraction",
    "method": "portfolio.input_fraction_bps",
    "params": {
      "chain_id": "$.root.chain_id",
      "owner": "$.root.from",
      "asset": "$.action.inputToken.asset",
      "amount": "$.action.inputToken.amount.value"
    },
    "outputs": [{ "kind": "context", "field": "holdingsBp", "type": "Long", "from": "$.result.bps", "required": false }],
    "optional": true
  }],
  "custom_context": { "fields": { "holdingsBp": "Long" } }
}
