{
  "id": "large-erc20-approve",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "erc20_approve" } } },
  "policy_rpc": [{
    "id": "approval-usd",
    "method": "oracle.usd_value",
    "params": {
      "chain_id": "$.root.chain_id",
      "asset": "$.action.token",
      "amount": "$.action.amount"
    },
    "outputs": [{
      "kind": "context",
      "field": "approvalUsd",
      "type": "Decimal",
      "from": "$.result.usd",
      "required": false
    }],
    "optional": true
  }],
  "custom_context": { "fields": { "approvalUsd": "decimal" } }
}
