{
  "id": "yield-deposit-usd-cap",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "mint_sy" } } },
  "policy_rpc": [{
    "id": "yield-deposit-usd",
    "method": "oracle.usd_value",
    "params": {
      "chain_id": "$.root.chain_id",
      "asset": "$.action.externalToken",
      "amount": "$.action.netTokenIn"
    },
    "outputs": [{ "kind": "context", "field": "yieldDepositUsd", "type": "Decimal", "from": "$.result.usd", "required": false }],
    "optional": true
  }],
  "custom_context": { "fields": { "yieldDepositUsd": "decimal" } }
}
