{
  "id": "perp-position-usd-cap",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "open_position" } } },
  "policy_rpc": [{
    "id": "position-usd",
    "method": "oracle.usd_value",
    "params": {
      "chain_id": "$.root.chain_id",
      "asset": "$.action.collateralToken",
      "amount": "$.action.collateralAmount"
    },
    "outputs": [{ "kind": "context", "field": "collateralUsd", "type": "Decimal", "from": "$.result.usd", "required": false }],
    "optional": true
  }],
  "custom_context": { "fields": { "collateralUsd": "decimal" } }
}
