{
  "id": "eigenlayer-delegate-to-operator-reputation",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "delegate_to" } } },
  "policy_rpc": [{
    "id": "operator-rep",
    "method": "address.reputation",
    "params": { "chain_id": "$.root.chain_id", "address": "$.action.operator" },
    "outputs": [{ "kind": "context", "field": "operatorFlagged", "type": "Bool", "from": "$.result.flagged", "required": false }],
    "optional": true
  }],
  "custom_context": { "fields": { "operatorFlagged": "Bool" } }
}
