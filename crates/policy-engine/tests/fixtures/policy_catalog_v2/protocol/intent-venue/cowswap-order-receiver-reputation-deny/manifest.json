{
  "id": "cowswap-order-receiver-reputation-deny",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "sign_intent_order" } } },
  "policy_rpc": [{
    "id": "receiver-rep",
    "method": "address.reputation",
    "params": { "chain_id": "$.root.chain_id", "address": "$.action.recipient" },
    "outputs": [{ "kind": "context", "field": "receiverFlagged", "type": "Bool", "from": "$.result.flagged", "required": false }],
    "optional": true
  }],
  "custom_context": { "fields": { "receiverFlagged": "Bool" } }
}
