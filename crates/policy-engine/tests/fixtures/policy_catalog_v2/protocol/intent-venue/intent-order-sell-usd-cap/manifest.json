{
  "id": "intent-order-sell-usd-cap",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "sign_intent_order" } } },
  "policy_rpc": [{
    "id": "sell-usd",
    "method": "oracle.usd_value",
    "params": {
      "chain_id": "$.root.chain_id",
      "asset": "$.action.sell",
      "amount": "$.action.sellAmount"
    },
    "outputs": [{ "kind": "context", "field": "sellUsd", "type": "Decimal", "from": "$.result.usd", "required": false }],
    "optional": true
  }],
  "custom_context": { "fields": { "sellUsd": "decimal" } }
}
