{
  "id": "compound-allow-manager-reputation-deny",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "protocol_authorization" } } },
  "policy_rpc": [{
    "id": "manager-rep",
    "method": "address.reputation",
    "params": { "chain_id": "$.root.chain_id", "address": "$.action.authorized" },
    "outputs": [{ "kind": "context", "field": "managerFlagged", "type": "Bool", "from": "$.result.flagged", "required": false }],
    "optional": true
  }],
  "custom_context": { "fields": { "managerFlagged": "Bool" } }
}
