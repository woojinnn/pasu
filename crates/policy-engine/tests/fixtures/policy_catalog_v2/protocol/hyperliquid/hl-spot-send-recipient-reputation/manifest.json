{
  "id": "hl-spot-send-recipient-reputation",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "hl_spot_send" } } },
  "policy_rpc": [{
    "id": "dest-rep",
    "method": "address.reputation",
    "params": { "chain_id": "$.root.chain_id", "address": "$.action.destination" },
    "outputs": [{ "kind": "context", "field": "reputationFlagged", "type": "Bool", "from": "$.result.flagged", "required": false }],
    "optional": true
  }],
  "custom_context": { "fields": { "reputationFlagged": "Bool" } }
}
