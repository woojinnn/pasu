{
  "id": "aave-set-emode-with-open-debt",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "set_e_mode" } } },
  "policy_rpc": [{
    "id": "post-emode-hf",
    "method": "lending.health_factor",
    "params": {
      "chain_id": "$.root.chain_id",
      "owner": "$.root.from",
      "venue": "$.action.venue"
    },
    "outputs": [{ "kind": "context", "field": "postActionHf", "type": "Decimal", "from": "$.result.postActionHf", "required": false }],
    "optional": true
  }],
  "custom_context": { "fields": { "postActionHf": "decimal" } }
}
