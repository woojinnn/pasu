{
  "id": "air-upfront-payment-warn",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "claim" } } },
  "policy_rpc": [
    {
      "id": "upfront-payment",
      "method": "claim.upfront_payment_required",
      "params": {
        "chain_id": "$.root.chain_id",
        "action": "$.action"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "requiresUpfrontPayment",
          "type": "Bool",
          "from": "$.result.requiresUpfrontPayment"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": { "fields": { "requiresUpfrontPayment": "Bool" } }
}
