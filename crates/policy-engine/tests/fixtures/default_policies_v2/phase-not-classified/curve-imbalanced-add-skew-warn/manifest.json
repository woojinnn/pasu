{
  "id": "curve-imbalanced-add-skew-warn",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "add_liquidity" } } },
  "policy_rpc": [
    {
      "id": "imbalance-skew",
      "method": "curve.imbalance_skew",
      "params": {
        "chain_id": "$.root.chain_id",
        "action": "$.action"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "imbalanceSkew",
          "type": "Decimal",
          "from": "$.result.skew"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": { "fields": { "imbalanceSkew": "decimal" } }
}
