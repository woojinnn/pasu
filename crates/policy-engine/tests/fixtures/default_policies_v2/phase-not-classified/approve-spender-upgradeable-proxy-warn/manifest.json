{
  "id": "approve-spender-upgradeable-proxy-warn",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "erc20_approve" } } },
  "policy_rpc": [
    {
      "id": "spender-proxy",
      "method": "approval.spender_is_mutable_proxy",
      "params": {
        "chain_id": "$.root.chain_id",
        "owner": "$.root.from",
        "action": "$.action"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "spenderMutableProxy",
          "type": "Bool",
          "from": "$.result.mutableProxy"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": { "fields": { "spenderMutableProxy": "Bool" } }
}
