{
  "id": "approve-cumulative-allowance-exposure-warn",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "erc20_approve" } } },
  "policy_rpc": [
    {
      "id": "cumulative-allowance",
      "method": "approval.cumulative_allowance_usd",
      "params": {
        "chain_id": "$.root.chain_id",
        "owner": "$.root.from",
        "token": "$.action.token",
        "spender": "$.action.spender",
        "added_amount": "$.action.amount"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "cumulativeAllowanceUsd",
          "type": "Decimal",
          "from": "$.result.cumulativeAllowanceUsd"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": { "fields": { "cumulativeAllowanceUsd": "decimal" } }
}
