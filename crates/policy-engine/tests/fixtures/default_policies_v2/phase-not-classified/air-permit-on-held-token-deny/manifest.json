{
  "id": "air-permit-on-held-token-deny",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "claim" } } },
  "policy_rpc": [
    {
      "id": "source-held-state",
      "method": "claim.source_held_state",
      "params": {
        "chain_id": "$.root.chain_id",
        "owner": "$.root.from",
        "action": "$.action"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "permitTokenIsHeld",
          "type": "Bool",
          "from": "$.result.tokenAlreadyHeld"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": { "fields": { "permitTokenIsHeld": "Bool" } }
}
