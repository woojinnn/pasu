{
  "id": "lido-rebasing-steth-to-contract-warn",
  "schema_version": 2,
  "trigger": {
    "where": {
      "action.tag": { "eq": "erc20_transfer" }
    }
  },
  "policy_rpc": [
    {
      "id": "token-rebasing",
      "method": "token.swap_special_token",
      "params": {
        "chain_id": "$.root.chain_id",
        "owner": "$.root.from",
        "asset": "$.action.token"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "tokenRebasing",
          "type": "Bool",
          "from": "$.result.special"
        }
      ],
      "optional": true
    },
    {
      "id": "recipient-is-contract",
      "method": "external.recipient_is_contract",
      "params": {
        "chain_id": "$.root.chain_id",
        "address": "$.action.recipient"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "recipientIsContract",
          "type": "Bool",
          "from": "$.result.isContract"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": {
    "fields": {
      "tokenRebasing": "Bool",
      "recipientIsContract": "Bool"
    }
  }
}
