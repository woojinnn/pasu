{
  "id": "curve-metapool-base-depeg-warn",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "add_liquidity" } } },
  "policy_rpc": [
    {
      "id": "base-pool-depeg",
      "method": "curve.base_pool_depeg",
      "params": {
        "chain_id": "$.root.chain_id",
        "action": "$.action"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "basePoolDepeg",
          "type": "Bool",
          "from": "$.result.basePoolDepeg"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": { "fields": { "basePoolDepeg": "Bool" } }
}
