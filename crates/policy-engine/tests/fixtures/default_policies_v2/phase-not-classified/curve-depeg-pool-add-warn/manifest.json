{
  "id": "curve-depeg-pool-add-warn",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "add_liquidity" } } },
  "policy_rpc": [
    {
      "id": "pool-depeg",
      "method": "curve.pool_depeg_state",
      "params": {
        "chain_id": "$.root.chain_id",
        "action": "$.action"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "pegDeviationBp",
          "type": "Long",
          "from": "$.result.pegDeviationBp"
        },
        {
          "kind": "context",
          "field": "compositionOutOfBand",
          "type": "Bool",
          "from": "$.result.compositionOutOfBand"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": {
    "fields": { "pegDeviationBp": "Long", "compositionOutOfBand": "Bool" }
  }
}
