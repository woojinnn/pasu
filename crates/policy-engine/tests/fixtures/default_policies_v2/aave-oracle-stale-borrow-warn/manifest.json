{
  "id": "aave-oracle-stale-borrow-warn",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "borrow" } } },
  "policy_rpc": [
    {
      "id": "oracle-freshness",
      "method": "external.oracle_freshness",
      "params": {
        "chain_id": "$.root.chain_id",
        "asset": "$.action.asset"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "oracleIsStale",
          "type": "Bool",
          "from": "$.result.isStale"
        },
        {
          "kind": "context",
          "field": "oracleAgeSecs",
          "type": "Long",
          "from": "$.result.ageSecs"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": { "fields": { "oracleIsStale": "Bool", "oracleAgeSecs": "Long" } }
}
