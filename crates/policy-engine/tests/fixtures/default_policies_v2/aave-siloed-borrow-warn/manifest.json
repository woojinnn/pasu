{
  "id": "aave-siloed-borrow-warn",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "borrow" } } },
  "policy_rpc": [
    {
      "id": "reserve-siloed",
      "method": "reserve.is_siloed",
      "params": {
        "chain_id": "$.root.chain_id",
        "venue": "$.action.venue",
        "asset": "$.action.asset"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "reserveIsSiloed",
          "type": "Bool",
          "from": "$.result.isSiloed"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": { "fields": { "reserveIsSiloed": "Bool" } }
}
