{
  "id": "daily-loss-limit-lockout-deny",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "open_position" } } },
  "policy_rpc": [
    {
      "id": "daily-loss-lockout",
      "method": "state.daily_loss_lockout",
      "params": {
        "chain_id": "$.root.chain_id",
        "owner": "$.root.from",
        "action": "$.action"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "lossLimitLockedToday",
          "type": "Bool",
          "from": "$.result.locked"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": { "fields": { "lossLimitLockedToday": "Bool" } }
}
