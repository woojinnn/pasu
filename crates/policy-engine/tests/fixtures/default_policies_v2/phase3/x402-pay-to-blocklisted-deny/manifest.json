{
  "id": "x402-pay-to-blocklisted-deny",
  "schema_version": 2,
  "trigger": {
    "where": {
      "action.tag": {
        "eq": "erc3009_transfer_with_auth"
      }
    }
  },
  "policy_rpc": [
    {
      "id": "pay-to-blocklisted",
      "method": "external.address_blocklisted",
      "params": {
        "chain_id": "$.root.chain_id",
        "address": "$.action.to"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "payToBlocklisted",
          "type": "Bool",
          "from": "$.result.blocklisted"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": {
    "fields": {
      "payToBlocklisted": "Bool"
    }
  }
}