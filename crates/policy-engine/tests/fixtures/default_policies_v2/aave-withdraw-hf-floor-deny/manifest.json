{
  "id": "aave-withdraw-hf-floor-deny",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "withdraw" } } },
  "policy_rpc": [
    {
      "id": "hf-after",
      "method": "position.health_factor_after",
      "params": {
        "chain_id": "$.root.chain_id",
        "owner": "$.root.from",
        "venue": "$.action.venue",
        "action": "$.action"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "healthFactorAfter",
          "type": "Decimal",
          "from": "$.result.healthFactor"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": { "fields": { "healthFactorAfter": "decimal" } }
}
