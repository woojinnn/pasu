{
  "id": "large-swap-usd-warning",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "swap" } } },
  "policy_rpc": [
    {
      "id": "total-input-usd",
      "method": "oracle.usd_value",
      "params": {
        "chain_id": "$.root.chain_id",
        "asset": "$.action.tokenIn",
        "amount": "$.action.amountIn"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "totalInputUsd",
          "type": "Decimal",
          "from": "$.result.usd"
        }
      ]
    }
  ],
  "custom_context": { "fields": { "totalInputUsd": "decimal" } }
}
