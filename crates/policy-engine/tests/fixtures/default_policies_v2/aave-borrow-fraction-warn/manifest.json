{
  "id": "aave-borrow-fraction-warn",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "borrow" } } },
  "policy_rpc": [
    {
      "id": "borrow-fraction",
      "method": "position.borrow_fraction_bps",
      "params": {
        "chain_id": "$.root.chain_id",
        "owner": "$.root.from",
        "action": "$.action"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "borrowFractionBps",
          "type": "Long",
          "from": "$.result.bps"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": { "fields": { "borrowFractionBps": "Long" } }
}
