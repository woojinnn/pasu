{
  "id": "transfer-unknown-recipient-warn",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "erc20_transfer" } } },
  "policy_rpc": [
    {
      "id": "recipient-seen-before",
      "method": "external.recipient_seen_before",
      "params": {
        "chain_id": "$.root.chain_id",
        "owner": "$.root.from",
        "recipient": "$.action.recipient"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "recipientFirstSeen",
          "type": "Bool",
          "from": "$.result.first_seen"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": { "fields": { "recipientFirstSeen": "Bool" } }
}
