{
  "id": "perp-concentration-warn",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "open_position" } } },
  "policy_rpc": [
    {
      "id": "notional-ratio",
      "method": "perp.notional_to_collateral",
      "params": {
        "chain_id": "$.root.chain_id",
        "owner": "$.root.from",
        "action": "$.action"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "notionalToCollateralRatio",
          "type": "Decimal",
          "from": "$.result.ratio"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": { "fields": { "notionalToCollateralRatio": "decimal" } }
}
