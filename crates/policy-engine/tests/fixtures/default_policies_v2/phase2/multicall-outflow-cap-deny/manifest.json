{
  "id": "multicall-outflow-cap-deny",
  "schema_version": 2,
  "trigger": { "where": { "action.domain": { "eq": "multicall" } } },
  "policy_rpc": [
    {
      "id": "tx-net-outflow",
      "method": "valuation.tx_total_usd",
      "params": {
        "chain_id": "$.root.chain_id",
        "owner": "$.root.from",
        "action": "$.action"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "txNetOutflowUsd",
          "type": "Decimal",
          "from": "$.result.usd"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": { "fields": { "txNetOutflowUsd": "decimal" } }
}
