{
  "id": "swap-out-token-honeypot-warn",
  "schema_version": 2,
  "trigger": {
    "where": {
      "action.tag": {
        "eq": "swap"
      }
    }
  },
  "policy_rpc": [
    {
      "id": "out-token-classification",
      "method": "token.swap_out_classification",
      "params": {
        "chain_id": "$.root.chain_id",
        "owner": "$.root.from",
        "asset": "$.action.tokenOut"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "outTokenUnclassified",
          "type": "Bool",
          "from": "$.result.unclassified"
        },
        {
          "kind": "context",
          "field": "outTokenHoneypot",
          "type": "Bool",
          "from": "$.result.honeypot"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": {
    "fields": {
      "outTokenUnclassified": "Bool",
      "outTokenHoneypot": "Bool"
    }
  }
}
