{
  "id": "permit-allowance-horizon-warn",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "erc20_permit" } } },
  "policy_rpc": [
    {
      "id": "permit-allowance-horizon",
      "method": "permit.allowance_horizon",
      "params": {
        "chain_id": "$.root.chain_id",
        "token": "$.action.token",
        "amount": "$.action.amount",
        "deadline": "$.action.deadline"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "permitAllowanceUsd",
          "type": "Decimal",
          "from": "$.result.allowanceUsd"
        },
        {
          "kind": "context",
          "field": "permitExpiryHorizonSec",
          "type": "Long",
          "from": "$.result.expiryHorizonSec"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": {
    "fields": {
      "permitAllowanceUsd": "decimal",
      "permitExpiryHorizonSec": "Long"
    }
  }
}
