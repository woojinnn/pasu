{
  "id": "bridge-permission-change-deny",
  "schema_version": 2,
  "trigger": { "where": { "action.domain": { "eq": "unknown" } } },
  "policy_rpc": [
    {
      "id": "permission-change",
      "method": "bridge.permission_change",
      "params": {
        "chain_id": "$.root.chain_id",
        "target": "$.action.target",
        "calldata": "$.action.calldata"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "permissionChangeUnsafe",
          "type": "Bool",
          "from": "$.result.permissionChangeUnsafe"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": { "fields": { "permissionChangeUnsafe": "Bool" } }
}
