{
  "id": "fefta-designated-party-payment-deny",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "erc20_transfer" } } },
  "policy_rpc": [
    {
      "id": "recipient-fefta-designated",
      "method": "external.address_blocklisted",
      "params": {
        "chain_id": "$.root.chain_id",
        "address": "$.action.recipient",
        "list": "jp_mof_fefta_asset_freeze"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "recipientFeftaDesignated",
          "type": "Bool",
          "from": "$.result.blocklisted"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": { "fields": { "recipientFeftaDesignated": "Bool" } }
}
