{
  "id": "transfer-first-time-recipient-warn",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "erc20_transfer" } } },
  "policy_rpc": [
    {
      "id": "recipient-first-seen",
      "method": "external.recipient_first_seen",
      "params": {
        "chain_id": "$.root.chain_id",
        "from": "$.root.from",
        "recipient": "$.action.recipient"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "firstTimeRecipient",
          "type": "Bool",
          "from": "$.result.first_time"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": { "fields": { "firstTimeRecipient": "Bool" } }
}
