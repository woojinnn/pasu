{
  "id": "values-interest-bearing-exclude-warn",
  "schema_version": 2,
  "trigger": {
    "where": {
      "action.tag": {
        "eq": "swap"
      }
    }
  },
  "policy_rpc": [
    {
      "id": "interest-bearing",
      "method": "token.interest_bearing",
      "params": {
        "chain_id": "$.root.chain_id",
        "asset": "$.action.tokenOut"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "tokenIsInterestBearing",
          "type": "Bool",
          "from": "$.result.isInterestBearing"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": {
    "fields": {
      "tokenIsInterestBearing": "Bool"
    }
  }
}
