        "target": "$.action.target",
        "calldata": "$.action.calldata"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "minOutHaircutBp",
          "type": "Long",
          "from": "$.result.haircutBp"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": { "fields": { "minOutHaircutBp": "Long" } }
}
