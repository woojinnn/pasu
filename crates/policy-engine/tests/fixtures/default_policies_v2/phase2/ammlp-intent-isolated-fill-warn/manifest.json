{
  "id": "ammlp-intent-isolated-fill-warn",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "sign_intent_order" } } },
  "policy_rpc": [
    {
      "id": "isolated-fill-risk",
      "method": "intent.isolated_fill_risk",
      "params": {
        "chain_id": "$.root.chain_id",
        "action": "$.action"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "isolatedFillRisk",
          "type": "Bool",
          "from": "$.result.isolatedFillRisk"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": { "fields": { "isolatedFillRisk": "Bool" } }
}
