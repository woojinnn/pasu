{
  "id": "ammlp-uni-v3v4-out-of-range-warn",
  "schema_version": 2,
  "trigger": {
    "where": {
      "action.tag": {
        "eq": "add_liquidity"
      },
      "action.venue": {
        "in": [
          "uniswap_v3",
          "uniswap_v4"
        ]
      }
    }
  },
  "policy_rpc": [
    {
      "id": "range-out-of-position",
      "method": "lp.range_out_of_position",
      "params": {
        "chain_id": "$.root.chain_id",
        "action": "$.action"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "lpOutOfRange",
          "type": "Bool",
          "from": "$.result.outOfRange"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": {
    "fields": {
      "lpOutOfRange": "Bool"
    }
  }
}
