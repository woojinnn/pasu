{
  "id": "stk-unstake-cooldown-warn",
  "schema_version": 2,
  "trigger": { "where": { "action.domain": { "eq": "unknown" } } },
  "policy_rpc": [
    {
      "id": "unlock-eta",
      "method": "stake.unlock_eta",
      "params": {
        "chain_id": "$.root.chain_id",
        "owner": "$.root.from",
        "action": "$.action"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "stakeHasLockup",
          "type": "Bool",
          "from": "$.result.hasLockup"
        },
        {
          "kind": "context",
          "field": "stakeUnlockEtaSecs",
          "type": "Long",
          "from": "$.result.unlockEtaSecs"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": { "fields": { "stakeHasLockup": "Bool", "stakeUnlockEtaSecs": "Long" } }
}
