{
  "id": "swap-permit2-spender-not-router-deny",
  "schema_version": 2,
  "trigger": {
    "where": {
      "action.tag": {
        "eq": "swap"
      }
    }
  },
  "policy_rpc": [
    {
      "id": "permit-spender-router",
      "method": "external.permit2_spender_is_router",
      "params": {
        "chain_id": "$.root.chain_id",
        "action": "$.action"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "permitSpenderIsRouter",
          "type": "Bool",
          "from": "$.result.spenderIsRouter"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": {
    "fields": {
      "permitSpenderIsRouter": "Bool"
    }
  }
}
