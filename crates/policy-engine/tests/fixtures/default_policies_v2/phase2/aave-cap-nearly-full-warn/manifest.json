{
  "id": "aave-cap-nearly-full-warn",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "borrow" }, "action.venue": { "eq": "aave_v3" } } },
  "policy_rpc": [
    {
      "id": "borrow-cap-used",
      "method": "reserve.cap_used_bp",
      "params": {
        "chain_id": "$.root.chain_id",
        "cap_kind": "borrow",
        "action": "$.action"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "borrowCapUsedBp",
          "type": "Long",
          "from": "$.result.capUsedBp"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": { "fields": { "borrowCapUsedBp": "Long" } }
}
