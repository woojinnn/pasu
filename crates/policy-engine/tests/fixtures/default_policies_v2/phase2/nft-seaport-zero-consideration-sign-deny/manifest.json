        "calldata": "$.action.calldata",
        "target": "$.action.target"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "seaportConsiderationNearZero",
          "type": "Bool",
          "from": "$.result.considerationNearZero"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": {
    "fields": {
      "seaportConsiderationNearZero": "Bool"
    }
  }
}
