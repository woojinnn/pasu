{
  "id": "stk-lst-depeg-sell-warn",
  "schema_version": 2,
  "trigger": {
    "where": {
      "action.tag": {
        "eq": "swap"
      }
    }
  },
  "policy_rpc": [
    {
      "id": "lst-peg",
      "method": "token.peg_ratio",
      "params": {
        "chain_id": "$.root.chain_id",
        "asset": "$.action.tokenIn"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "lstPegRatio",
          "type": "Decimal",
          "from": "$.result.pegRatio"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": {
    "fields": {
      "lstPegRatio": "decimal"
    }
  }
}
