{
  "id": "ammlp-cancel-target-missing-warn",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "cancel_intent_order" } } },
  "policy_rpc": [
    {
      "id": "cancel-target-missing",
      "method": "intent.cancel_target_missing",
      "params": {
        "chain_id": "$.root.chain_id",
        "owner": "$.root.from",
        "order_hash": "$.action.orderHash"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "cancelTargetMissing",
          "type": "Bool",
          "from": "$.result.targetMissing"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": { "fields": { "cancelTargetMissing": "Bool" } }
}
