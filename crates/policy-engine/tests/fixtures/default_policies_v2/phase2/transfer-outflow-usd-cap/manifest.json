{
  "id": "transfer-outflow-usd-cap",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "erc20_transfer" } } },
  "policy_rpc": [
    {
      "id": "outflow-usd",
      "method": "oracle.usd_value",
      "params": {
        "chain_id": "$.root.chain_id",
        "asset": "$.action.token",
        "amount": "$.action.amount"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "outflowAssetUsd",
          "type": "Decimal",
          "from": "$.result.usd"
        }
      ]
    }
  ],
  "custom_context": { "fields": { "outflowAssetUsd": "decimal" } }
}
