{
  "id": "intent-validity-horizon-warn",
  "schema_version": 2,
  "trigger": {
    "where": {
      "action.tag": {
        "eq": "sign_intent_order"
      }
    }
  },
  "policy_rpc": [
    {
      "id": "validity-horizon",
      "method": "intent.validity_horizon_sec",
      "params": {
        "valid_until": "$.action.validUntil"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "validityHorizonSec",
          "type": "Long",
          "from": "$.result.horizonSec"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": {
    "fields": {
      "validityHorizonSec": "Long"
    }
  }
}
