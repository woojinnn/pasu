{
  "id": "behav-fomo-pump-chase-warn",
  "schema_version": 2,
  "trigger": {
    "where": {
      "action.tag": {
        "eq": "swap"
      }
    }
  },
  "policy_rpc": [
    {
      "id": "recent-return",
      "method": "external.token_recent_return_pct",
      "params": {
        "chain_id": "$.root.chain_id",
        "asset": "$.action.tokenOut",
        "window_days": 5
      },
      "outputs": [
        {
          "kind": "context",
          "field": "recentReturnPct",
          "type": "Decimal",
          "from": "$.result.returnPct"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": {
    "fields": {
      "recentReturnPct": "decimal"
    }
  }
}
