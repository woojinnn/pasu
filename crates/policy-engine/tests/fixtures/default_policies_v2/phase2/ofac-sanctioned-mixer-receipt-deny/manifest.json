{
  "id": "ofac-sanctioned-mixer-receipt-deny",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "erc20_transfer" } } },
  "policy_rpc": [
    {
      "id": "ofac-cvc-mixer-screen",
      "method": "external.address_blocklisted",
      "params": {
        "chain_id": "$.root.chain_id",
        "address": "$.action.recipient",
        "list": "ofac_cvc_mixer"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "ofacMixerListed",
          "type": "Bool",
          "from": "$.result.blocklisted"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": { "fields": { "ofacMixerListed": "Bool" } }
}
