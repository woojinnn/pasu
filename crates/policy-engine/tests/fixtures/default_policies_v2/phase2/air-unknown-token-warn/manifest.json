{
  "id": "air-unknown-token-warn",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "claim" } } },
  "policy_rpc": [
    {
      "id": "token-unrecognized",
      "method": "claim.token_unrecognized",
      "params": {
        "chain_id": "$.root.chain_id",
        "owner": "$.root.from",
        "token": "$.action.claimToken"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "claimTokenUnknown",
          "type": "Bool",
          "from": "$.result.tokenUnknown"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": { "fields": { "claimTokenUnknown": "Bool" } }
}
