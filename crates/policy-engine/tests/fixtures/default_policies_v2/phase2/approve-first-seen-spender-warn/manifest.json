{
  "id": "approve-first-seen-spender-warn",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "erc20_approve" } } },
  "policy_rpc": [
    {
      "id": "spender-first-seen",
      "method": "approval.spender_first_seen",
      "params": {
        "chain_id": "$.root.chain_id",
        "owner": "$.root.from",
        "token": "$.action.token",
        "spender": "$.action.spender"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "spenderIsFirstSeen",
          "type": "Bool",
          "from": "$.result.isFirstSeen"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": { "fields": { "spenderIsFirstSeen": "Bool" } }
}
