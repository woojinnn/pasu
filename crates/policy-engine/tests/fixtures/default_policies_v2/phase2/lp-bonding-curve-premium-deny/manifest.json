{
  "id": "lp-bonding-curve-premium-deny",
  "schema_version": 2,
  "trigger": {
    "where": {
      "action.tag": {
        "eq": "commit"
      }
    }
  },
  "policy_rpc": [
    {
      "id": "curve-premium",
      "method": "launchpad.curve_premium_bp",
      "params": {
        "chain_id": "$.root.chain_id",
        "action": "$.action"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "curvePremiumBp",
          "type": "Long",
          "from": "$.result.premiumBp"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": {
    "fields": {
      "curvePremiumBp": "Long"
    }
  }
}
