{
  "id": "kr-terror-financing-designated-recipient-deny",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "erc20_transfer" } } },
  "policy_rpc": [
    {
      "id": "recipient-kr-designated",
      "method": "external.address_blocklisted",
      "params": {
        "chain_id": "$.root.chain_id",
        "address": "$.action.recipient",
        "list": "kr_kofiu_designated_and_un_sanctions"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "recipientKrDesignated",
          "type": "Bool",
          "from": "$.result.blocklisted"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": { "fields": { "recipientKrDesignated": "Bool" } }
}
