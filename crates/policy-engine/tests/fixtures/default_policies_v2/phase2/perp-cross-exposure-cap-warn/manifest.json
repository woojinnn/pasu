{
  "id": "perp-cross-exposure-cap-warn",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "open_position" } } },
  "policy_rpc": [
    {
      "id": "cross-exposure",
      "method": "perp.cross_total_exposure_ratio",
      "params": {
        "chain_id": "$.root.chain_id",
        "owner": "$.root.from",
        "action": "$.action"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "crossTotalExposureRatio",
          "type": "Decimal",
          "from": "$.result.ratio"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": { "fields": { "crossTotalExposureRatio": "decimal" } }
}
