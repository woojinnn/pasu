{
  "id": "aave-repay-swap-slippage-deny",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "repay" }, "action.venue": { "eq": "aave_v3" } } },
  "policy_rpc": [
    {
      "id": "repay-swap-slippage",
      "method": "external.repay_swap_slippage_bps",
      "params": {
        "chain_id": "$.root.chain_id",
        "owner": "$.root.from",
        "action": "$.action"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "repaySwapSlippageBps",
          "type": "Long",
          "from": "$.result.slippageBps"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": { "fields": { "repaySwapSlippageBps": "Long" } }
}
