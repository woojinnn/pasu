{
  "id": "perp-isolated-to-cross-warn",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "change_margin_mode" } } },
  "policy_rpc": [
    {
      "id": "mode-transition",
      "method": "perp.margin_mode_transition",
      "params": {
        "chain_id": "$.root.chain_id",
        "owner": "$.root.from",
        "market": "$.action.market",
        "action": "$.action"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "isolatedToCross",
          "type": "Bool",
          "from": "$.result.isolatedToCross"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": { "fields": { "isolatedToCross": "Bool" } }
}
