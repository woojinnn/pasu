{
  "id": "perp-stop-trigger-misplaced-warn",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "place_stop_order" } } },
  "policy_rpc": [
    {
      "id": "stop-trigger",
      "method": "perp.stop_trigger_misplaced",
      "params": {
        "chain_id": "$.root.chain_id",
        "owner": "$.root.from",
        "action": "$.action"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "stopTriggerMisplaced",
          "type": "Bool",
          "from": "$.result.misplaced"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": { "fields": { "stopTriggerMisplaced": "Bool" } }
}
