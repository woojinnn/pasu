{
  "id": "send-wrong-network-mismatch-deny",
  "schema_version": 2,
  "trigger": {
    "where": {
      "action.tag": {
        "eq": "erc20_transfer"
      }
    }
  },
  "policy_rpc": [
    {
      "id": "network-mismatch",
      "method": "external.network_mismatch_loss",
      "params": {
        "chain_id": "$.root.chain_id",
        "address": "$.action.recipient",
        "token_key": "$.action.token.key"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "networkMismatch",
          "type": "Bool",
          "from": "$.result.mismatch"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": {
    "fields": {
      "networkMismatch": "Bool"
    }
  }
}
