{
  "id": "nft-zero-price-sale-deny",
  "schema_version": 2,
  "trigger": { "where": { "action.domain": { "eq": "unknown" } } },
  "policy_rpc": [
    {
      "id": "consideration-vs-floor",
      "method": "external.nft_floor",
      "params": {
        "chain_id": "$.root.chain_id",
        "owner": "$.root.from",
        "calldata": "$.action.calldata",
        "target": "$.action.target"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "considerationVsFloor",
          "type": "Decimal",
          "from": "$.result.orderVsFloor"
        },
        {
          "kind": "context",
          "field": "ownedNftListed",
          "type": "Bool",
          "from": "$.result.ownedNftListed"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": {
    "fields": {
      "considerationVsFloor": "decimal",
      "ownedNftListed": "Bool"
    }
  }
}
