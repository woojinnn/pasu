{
  "id": "intent-dutch-decay-warn",
  "schema_version": 2,
  "trigger": {
    "where": {
      "action.tag": {
        "eq": "sign_intent_order"
      }
    }
  },
  "policy_rpc": [
    {
      "id": "fill-vs-floor",
      "method": "intent.fill_vs_floor",
      "params": {
        "chain_id": "$.root.chain_id",
        "action": "$.action"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "fillVsFloorBp",
          "type": "Long",
          "from": "$.result.fillVsFloorBp"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": {
    "fields": {
      "fillVsFloorBp": "Long"
    }
  }
}
