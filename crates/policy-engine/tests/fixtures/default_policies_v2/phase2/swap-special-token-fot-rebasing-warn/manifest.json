{
  "id": "swap-special-token-fot-rebasing-warn",
  "schema_version": 2,
  "trigger": {
    "where": {
      "action.tag": {
        "eq": "swap"
      }
    }
  },
  "policy_rpc": [
    {
      "id": "special-token",
      "method": "token.swap_special_token",
      "params": {
        "chain_id": "$.root.chain_id",
        "owner": "$.root.from",
        "asset": "$.action.tokenIn"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "specialToken",
          "type": "Bool",
          "from": "$.result.special"
        },
        {
          "kind": "context",
          "field": "feeOnTransfer",
          "type": "Bool",
          "from": "$.result.feeOnTransfer"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": {
    "fields": {
      "specialToken": "Bool",
      "feeOnTransfer": "Bool"
    }
  }
}
