{
  "id": "gas-cost-usd-cap-deny",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "swap" } } },
  "policy_rpc": [
    {
      "id": "gas-cost-usd",
      "method": "valuation.gas_cost_usd",
      "params": {
        "chain_id": "$.root.chain_id",
        "gas_estimate": "$.action.gasEstimate"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "gasCostUsd",
          "type": "Decimal",
          "from": "$.result.usd"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": { "fields": { "gasCostUsd": "decimal" } }
}
