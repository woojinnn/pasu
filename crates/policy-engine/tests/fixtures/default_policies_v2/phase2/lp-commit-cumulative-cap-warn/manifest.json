{
  "id": "lp-commit-cumulative-cap-warn",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "commit" } } },
  "policy_rpc": [
    {
      "id": "cumulative-committed",
      "method": "launchpad.cumulative_committed_usd",
      "params": {
        "chain_id": "$.root.chain_id",
        "owner": "$.root.from",
        "action": "$.action"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "cumulativePaidUsd",
          "type": "Decimal",
          "from": "$.result.usd"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": { "fields": { "cumulativePaidUsd": "decimal" } }
}
