{
  "id": "gov-redelegate-large-power-warn",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "delegate" } } },
  "policy_rpc": [
    {
      "id": "voting-power-at-risk",
      "method": "governance.voting_power_at_risk",
      "params": {
        "chain_id": "$.root.chain_id",
        "owner": "$.root.from",
        "token": "$.action.token",
        "action": "$.action"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "votingPowerAtRisk",
          "type": "Decimal",
          "from": "$.result.votingPowerAtRisk"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": { "fields": { "votingPowerAtRisk": "decimal" } }
}
