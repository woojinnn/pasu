{
  "id": "perp-reduce-only-flip-deny",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "decrease_position" } } },
  "policy_rpc": [
    {
      "id": "crosses-zero",
      "method": "perp.crosses_zero",
      "params": {
        "chain_id": "$.root.chain_id",
        "owner": "$.root.from",
        "action": "$.action"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "crossesZero",
          "type": "Bool",
          "from": "$.result.crossesZero"
        }
      ],
      "optional": true
    }
  ],
  "custom_context": { "fields": { "crossesZero": "Bool" } }
}
