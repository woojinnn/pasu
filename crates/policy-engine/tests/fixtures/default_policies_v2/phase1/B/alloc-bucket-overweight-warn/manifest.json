{
  "id": "alloc-bucket-overweight-warn",
  "schema_version": 2,
  "trigger": { "where": { "action.tag": { "eq": "swap" } } },
  "policy_rpc": [
    {
      "id": "bucket-share-after",
      "method": "portfolio.group_pct",
      "params": {
        "chain_id": "$.root.chain_id",
        "owner": "$.root.from",
        "group_axis": "category",
        "asset": "$.action.tokenOut",
        "basis": "state2"
      },
      "outputs": [
        { "kind": "context", "field": "bucketPctAfter", "type": "Decimal", "from": "$.result.pct" }
      ],
      "optional": true
    }
  ],
  "custom_context": { "fields": { "bucketPctAfter": "decimal" } }
}
