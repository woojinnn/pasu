  "_meta": {
    "purpose": "Curated Curve factory-pool targets — input to gen-from-sourcify.ts. Each pool is a verified on-chain deployment whose bytecode contains all 6 selectors of its pool-type _template (except where 'skip' lists exceptions).",
    "audited_at": "2026-05-24",
    "sources": {
      "api": "https://api.curve.finance/v1/getPools/{ethereum,base}/{factory-stable-ng,factory-twocrypto,factory-crypto}",
      "rpc_ethereum": "https://ethereum-rpc.publicnode.com",
      "rpc_base": "https://base-rpc.publicnode.com",
      "selector_keccak": "cast keccak '<signature>' on canonical Vyper sigs (see _template/*.json abi_fragment)"
    },
    "selector_coverage_check": "For each pool, eth_getCode bytecode must contain hex(selector) for every template manifest emitted. Pools missing a selector are listed in the 'skip' array with reason.",
    "templates_referenced": [
      "manifests/curve/stableswap-ng-factory/_template/*.json",
      "manifests/curve/twocrypto/_template/*.json",
      "manifests/curve/factory-crypto/_template/*.json"
    ]
  },

