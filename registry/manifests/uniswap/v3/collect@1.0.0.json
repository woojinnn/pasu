{
  "type": "adapter_function",
  "id": "uniswap/v3/collect@1.0.0",
  "publisher": "uniswap.eth",
  "match": {
    "chain_ids": [1, 8453, 10, 42161, 137],
    "to": ["0xC36442b4a4522E871399CD717aBDD847Ab11FE88"],
    "selector": "0xfc6f7865"
  },
  "abi_fragment": {
    "function_name": "collect",
    "abi": {
      "name": "collect",
      "type": "function",
      "inputs": [
        {
          "name": "params",
          "type": "tuple",
          "components": [
            { "name": "tokenId",    "type": "uint256" },
            { "name": "recipient",  "type": "address" },
            { "name": "amount0Max", "type": "uint128" },
            { "name": "amount1Max", "type": "uint128" }
          ]
        }
      ]
    }
  },
  "emit": {
    "strategy": "single_emit",
    "category": "dex",
    "action": "claim_rewards",
    "fields": {
      "source.address":            { "from": "$.tx.to" },
      "nft.kind":                  { "literal": "erc721" },
      "nft.address":               { "from": "$.tx.to" },
      "nft.tokenId":               { "from": "$.args.params.tokenId" },
      "tokenId":                   { "from": "$.args.params.tokenId" },
      "from":                      { "from": "$.tx.from" },
      "recipient":                 { "from": "$.args.params.recipient" }
    }
  },
  "requires": {
    "imperative": [],
    "adapter_capabilities": ["token_metadata"],
    "host_capabilities": [],
    "extension": ">=0.1.0"
  }
}
