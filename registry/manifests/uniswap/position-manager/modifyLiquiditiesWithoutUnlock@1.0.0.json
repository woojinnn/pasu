          "inputTokens[0].asset.address": { "from": "$.args.poolKey[0]" },
          "inputTokens[0].amount.kind": { "literal": "max" },
          "inputTokens[0].amount.value": { "from": "$.args.amount0Max" },
          "inputTokens[1].asset.kind": { "literal": "erc20" },
          "inputTokens[1].asset.address": { "from": "$.args.poolKey[1]" },
          "inputTokens[1].amount.kind": { "literal": "max" },
