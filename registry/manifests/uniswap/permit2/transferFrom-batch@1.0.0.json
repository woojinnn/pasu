{
  "type": "adapter_function",
  "id": "uniswap/permit2/transferFrom-batch@1.0.0",
  "publisher": "uniswap.eth",
  "schema_version": "2",
  "match": {
    "selector": "0x0d58b1db",
    "chain_to_addresses": {
      "1": ["0x000000000022D473030F116dDEE9F6B43aC78BA3"],
      "8453": ["0x000000000022D473030F116dDEE9F6B43aC78BA3"]
    }
  },
  "abi_fragment": {
    "function_name": "transferFrom",
    "abi": {
      "name": "transferFrom",
      "type": "function",
      "inputs": [
        {
          "name": "transferDetails",
          "type": "tuple[]",
          "components": [
            { "name": "from", "type": "address" },
            { "name": "to", "type": "address" },
            { "name": "amount", "type": "uint160" },
            { "name": "token", "type": "address" }
          ]
        }
      ]
    }
  },
  "emit": {
    "strategy": "array_emit",
    "category": "misc",
    "action": "transfer",
    "array_path": "$.args.transferDetails",
    "max_elements": 64,
    "fields": {
      "token.asset.kind": { "literal": "erc20" },
      "token.asset.address": { "from": "$.args.element[3]" },
      "token.amount.kind": { "literal": "exact" },
      "token.amount.value": { "from": "$.args.element[2]" },
      "from": { "from": "$.args.element[0]" },
      "recipient": { "from": "$.args.element[1]" }
    }
  },
  "requires": {
    "imperative": [],
    "adapter_capabilities": ["token_metadata"],
    "host_capabilities": [],
    "extension": ">=0.1.0"
  }
}
