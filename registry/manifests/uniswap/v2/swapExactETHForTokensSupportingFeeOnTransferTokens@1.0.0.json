{
  "type": "adapter_function",
  "id": "uniswap/v2/swapExactETHForTokensSupportingFeeOnTransferTokens@1.0.0",
  "publisher": "uniswap.eth",
  "match": {
    "chain_ids": [
      1
    ],
    "to": [
      "0x7a250d5630B4cF539739dF2C5dAcb4c659F2488D"
    ],
    "selector": "0xb6f9de95"
  },
  "abi_fragment": {
    "function_name": "swapExactETHForTokensSupportingFeeOnTransferTokens",
    "abi": {
      "name": "swapExactETHForTokensSupportingFeeOnTransferTokens",
      "type": "function",
      "stateMutability": "payable",
      "inputs": [
        {
          "name": "amountOutMin",
          "type": "uint256"
        },
        {
          "name": "path",
          "type": "address[]"
        },
        {
          "name": "to",
          "type": "address"
        },
        {
          "name": "deadline",
          "type": "uint256"
        }
      ]
    }
  },
  "emit": {
    "strategy": "single_emit",
    "category": "dex",
    "action": "swap",
    "fields": {
      "swapMode": {
        "literal": "exact_in"
      },
      "inputToken.asset.kind": {
        "literal": "native"
      },
      "inputToken.amount.kind": {
        "literal": "exact"
      },
      "inputToken.amount.value": {
        "from": "$.tx.value_wei"
      },
      "outputToken.asset.kind": {
        "literal": "erc20"
      },
      "outputToken.asset.address": {
        "fn": "select_address",
        "args": [
          {
            "from": "$.args.path"
          },
          {
            "literal": -1
          }
        ]
      },
      "outputToken.amount.kind": {
        "literal": "min"
      },
      "outputToken.amount.value": {
        "from": "$.args.amountOutMin"
      },
      "recipient": {
        "from": "$.args.to"
      },
      "validity.expiresAt": {
        "from": "$.args.deadline"
      },
      "validity.source": {
        "literal": "tx-deadline"
      }
    }
  },
  "requires": {
    "imperative": [],
    "adapter_capabilities": [
      "token_metadata"
    ],
    "host_capabilities": [],
    "extension": ">=0.1.0"
  }
}
