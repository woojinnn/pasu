{
  "type": "adapter_function",
  "id": "uniswap/v2-router-02/swapETHForExactTokens@1.0.0",
  "publisher": "uniswap.eth",
  "schema_version": "2",
  "match": {
    "selector": "0xfb3bdb41",
    "chain_to_addresses": {
      "1": ["0x7a250d5630B4cF539739dF2C5dAcb4c659F2488D"],
      "8453": ["0x4752ba5DBc23f44D87826276BF6Fd6b1C372ad24"]
    }
  },
  "abi_fragment": {
    "function_name": "swapETHForExactTokens",
    "abi": {
      "name": "swapETHForExactTokens",
      "type": "function",
      "stateMutability": "payable",
      "inputs": [
        { "name": "amountOut", "type": "uint256" },
        { "name": "path", "type": "address[]" },
        { "name": "to", "type": "address" },
        { "name": "deadline", "type": "uint256" }
      ]
    }
  },
  "emit": {
    "strategy": "single_emit",
    "category": "dex",
    "action": "swap",
    "fields": {
      "swapMode": { "literal": "exact_out" },
      "inputToken.asset.kind": { "literal": "native" },
      "inputToken.amount.kind": { "literal": "max" },
      "inputToken.amount.value": { "from": "$.tx.value_wei" },
      "outputToken.asset.kind": { "literal": "erc20" },
      "outputToken.asset.address": {
        "fn": "select_address",
        "args": [{ "from": "$.args.path" }, { "literal": -1 }]
      },
      "outputToken.amount.kind": { "literal": "exact" },
      "outputToken.amount.value": { "from": "$.args.amountOut" },
      "recipient": { "from": "$.args.to" },
      "validity.expiresAt": { "from": "$.args.deadline" },
      "validity.source": { "literal": "tx-deadline" }
    }
  },
  "requires": {
    "imperative": [],
    "adapter_capabilities": ["token_metadata"],
    "host_capabilities": [],
    "extension": ">=0.1.0"
  }
}
