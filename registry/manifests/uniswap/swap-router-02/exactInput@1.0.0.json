{
  "type": "adapter_function",
  "id": "uniswap/swap-router-02/exactInput@1.0.0",
  "publisher": "uniswap.eth",
  "match": {
    "chain_ids": [
      1,
      10,
      137,
      42161
    ],
    "to": [
      "0x68b3465833fb72A70ecDF485E0e4C7bD8665Fc45"
    ],
    "selector": "0xb858183f"
  },
  "abi_fragment": {
    "function_name": "exactInput",
    "abi": {
      "name": "exactInput",
      "type": "function",
      "inputs": [
        {
          "name": "params",
          "type": "tuple",
          "components": [
            {
              "name": "path",
              "type": "bytes"
            },
            {
              "name": "recipient",
              "type": "address"
            },
            {
              "name": "amountIn",
              "type": "uint256"
            },
            {
              "name": "amountOutMinimum",
              "type": "uint256"
            }
          ]
        }
      ]
    }
  },
  "emit": {
    "strategy": "single_emit",
    "category": "dex",
    "action": "swap",
    "fields": {
      "swapMode": {
        "literal": "exact_in"
      },
      "inputToken.asset.kind": {
        "literal": "erc20"
      },
      "inputToken.asset.address": {
        "fn": "unfold_v3_path",
        "args": [
          {
            "from": "$.args.path"
          },
          {
            "literal": "first_token"
          }
        ]
      },
      "inputToken.amount.kind": {
        "literal": "exact"
      },
      "inputToken.amount.value": {
        "from": "$.args.amountIn"
      },
      "outputToken.asset.kind": {
        "literal": "erc20"
      },
      "outputToken.asset.address": {
        "fn": "unfold_v3_path",
        "args": [
          {
            "from": "$.args.path"
          },
          {
            "literal": "last_token"
          }
        ]
      },
      "outputToken.amount.kind": {
        "literal": "min"
      },
      "outputToken.amount.value": {
        "from": "$.args.amountOutMinimum"
      },
      "recipient": {
        "from": "$.args.recipient"
      }
    }
  },
  "requires": {
    "imperative": [],
    "adapter_capabilities": [
      "token_metadata"
    ],
    "host_capabilities": [],
    "extension": ">=0.1.0"
  }
}
