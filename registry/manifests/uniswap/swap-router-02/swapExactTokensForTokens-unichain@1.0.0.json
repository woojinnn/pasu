{
  "type": "adapter_function",
  "id": "uniswap/swap-router-02/swapExactTokensForTokens-unichain@1.0.0",
  "publisher": "uniswap.eth",
  "match": {
    "chain_ids": [
      130
    ],
    "to": [
      "0x73855d06DE49d0fe4A9c42636Ba96c62da12FF9C"
    ],
    "selector": "0x472b43f3"
  },
  "abi_fragment": {
    "function_name": "swapExactTokensForTokens",
    "abi": {
      "name": "swapExactTokensForTokens",
      "type": "function",
      "inputs": [
        {
          "name": "amountIn",
          "type": "uint256"
        },
        {
          "name": "amountOutMin",
          "type": "uint256"
        },
        {
          "name": "path",
          "type": "address[]"
        },
        {
          "name": "to",
          "type": "address"
        }
      ]
    }
  },
  "emit": {
    "strategy": "single_emit",
    "category": "dex",
    "action": "swap",
    "fields": {
      "swapMode": {
        "literal": "exact_in"
      },
      "inputToken.asset.kind": {
        "literal": "erc20"
      },
      "inputToken.asset.address": {
        "fn": "select_address",
        "args": [
          {
            "from": "$.args.path"
          },
          {
            "literal": 0
          }
        ]
      },
      "inputToken.amount.kind": {
        "literal": "exact"
      },
      "inputToken.amount.value": {
        "from": "$.args.amountIn"
      },
      "outputToken.asset.kind": {
        "literal": "erc20"
      },
      "outputToken.asset.address": {
        "fn": "select_address",
        "args": [
          {
            "from": "$.args.path"
          },
          {
            "literal": -1
          }
        ]
      },
      "outputToken.amount.kind": {
        "literal": "min"
      },
      "outputToken.amount.value": {
        "from": "$.args.amountOutMin"
      },
      "recipient": {
        "from": "$.args.to"
      }
    }
  },
  "requires": {
    "imperative": [],
    "adapter_capabilities": [
      "token_metadata"
    ],
    "host_capabilities": [],
    "extension": ">=0.1.0"
  }
}
