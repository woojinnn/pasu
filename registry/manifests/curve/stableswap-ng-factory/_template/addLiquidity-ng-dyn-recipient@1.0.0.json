{
  "type": "adapter_function",
  "id": "curve/stableswap-ng-factory/_template/addLiquidity-ng-dyn-recipient@1.0.0",
  "publisher": "curve.fi",
  "match": {
    "chain_ids": [1],
    "to": ["0x1111111111111111111111111111111111111111"],
    "selector": "0xa7256d09"
  },
  "abi_fragment": {
    "function_name": "add_liquidity",
    "abi": {
      "name": "add_liquidity",
      "type": "function",
      "inputs": [
        { "name": "_amounts",         "type": "uint256[]" },
        { "name": "_min_mint_amount", "type": "uint256"   },
        { "name": "_receiver",        "type": "address"   }
      ]
    }
  },
  "emit": {
    "strategy": "single_emit",
    "category": "dex",
    "action": "add_liquidity",
    "fields": {
      "pool.address":                 { "literal": "0x1111111111111111111111111111111111111111" },
      "inputTokens[0].asset.kind":    { "literal": "erc20" },
      "inputTokens[0].asset.address": { "literal": "0xaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa1" },
      "inputTokens[1].asset.kind":    { "literal": "erc20" },
      "inputTokens[1].asset.address": { "literal": "0xaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa2" },
      "inputTokens[0].amount.kind":   { "literal": "max" },
      "inputTokens[0].amount.value":  { "from": "$.args._amounts[0]" },
      "inputTokens[1].amount.kind":   { "literal": "max" },
      "inputTokens[1].amount.value":  { "from": "$.args._amounts[1]" },
      "outputLp.asset.kind":          { "literal": "erc20" },
      "outputLp.asset.address":       { "literal": "0x1111111111111111111111111111111111111111" },
      "outputLp.amount.kind":         { "literal": "min" },
      "outputLp.amount.value":        { "from": "$.args._min_mint_amount" },
      "recipient":                    { "from": "$.args._receiver" }
    }
  },
  "requires": {
    "imperative":        [],
    "host_capabilities": ["host:token_metadata"],
    "extension":         ">=0.1.0"
  }
}
