{
  "type": "adapter_function",
  "id": "curve/stableswap-ng-factory/_template/exchange-ng-receiver@1.0.0",
  "publisher": "curve.fi",
  "match": {
    "chain_ids": [1],
    "to": ["0x1111111111111111111111111111111111111111"],
    "selector": "0xddc1f59d"
  },
  "abi_fragment": {
    "function_name": "exchange",
    "abi": {
      "name": "exchange",
      "type": "function",
      "inputs": [
        { "name": "i",         "type": "int128"  },
        { "name": "j",         "type": "int128"  },
        { "name": "_dx",       "type": "uint256" },
        { "name": "_min_dy",   "type": "uint256" },
        { "name": "_receiver", "type": "address" }
      ]
    }
  },
  "emit": {
    "strategy": "single_emit",
    "category": "dex",
    "action": "swap",
    "fields": {
      "swapMode":                  { "literal": "exact_in" },
      "inputToken.asset.kind":     { "literal": "erc20" },
      "inputToken.asset.address":  {
        "fn": "select_from_literal_array",
        "args": [
          { "literal": [
            "0xaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa1",
            "0xaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa2"
          ] },
          { "from": "$.args.i" }
        ]
      },
      "inputToken.amount.kind":    { "literal": "exact" },
      "inputToken.amount.value":   { "from": "$.args._dx" },
      "outputToken.asset.kind":    { "literal": "erc20" },
      "outputToken.asset.address": {
        "fn": "select_from_literal_array",
        "args": [
          { "literal": [
            "0xaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa1",
            "0xaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa2"
          ] },
          { "from": "$.args.j" }
        ]
      },
      "outputToken.amount.kind":   { "literal": "min" },
      "outputToken.amount.value":  { "from": "$.args._min_dy" },
      "recipient":                 { "from": "$.args._receiver" }
    }
  },
  "requires": {
    "imperative":        [],
    "host_capabilities": ["host:token_metadata"],
    "extension":         ">=0.1.0"
  }
}
