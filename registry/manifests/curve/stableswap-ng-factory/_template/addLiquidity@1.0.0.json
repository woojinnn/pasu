{
  "type": "adapter_function",
  "id": "curve/stableswap-ng-factory/_template/addLiquidity@1.0.0",
  "publisher": "curve.fi",
  "schema_version": "2",
  "match": {
    "selector": "0x0b4c7e4d",
    "chain_to_addresses": {
      "__CHAIN_ID__": ["__POOL_ADDRESS__"]
    }
  },
  "abi_fragment": {
    "function_name": "add_liquidity",
    "abi": {
      "name": "add_liquidity",
      "type": "function",
      "inputs": [
        { "name": "_amounts",         "type": "uint256[2]" },
        { "name": "_min_mint_amount", "type": "uint256"    }
      ]
    }
  },
  "emit": {
    "strategy": "single_emit",
    "category": "dex",
    "action": "add_liquidity",
    "fields": {
      "pool.address":                 { "literal": "__POOL_ADDRESS__" },
      "inputTokens[0].asset.kind":    { "literal": "erc20" },
      "inputTokens[0].asset.address": { "literal": "__COIN0__" },
      "inputTokens[1].asset.kind":    { "literal": "erc20" },
      "inputTokens[1].asset.address": { "literal": "__COIN1__" },
      "inputTokens[0].amount.kind":   { "literal": "max" },
      "inputTokens[0].amount.value":  { "from": "$.args._amounts[0]" },
      "inputTokens[1].amount.kind":   { "literal": "max" },
      "inputTokens[1].amount.value":  { "from": "$.args._amounts[1]" },
      "outputLp.asset.kind":          { "literal": "erc20" },
      "outputLp.asset.address":       { "literal": "__LP_TOKEN__" },
      "outputLp.amount.kind":         { "literal": "min" },
      "outputLp.amount.value":        { "from": "$.args._min_mint_amount" },
      "recipient":                    { "from": "$.tx.from" }
    }
  },
  "requires": {
    "imperative": [],
    "adapter_capabilities": ["token_metadata"],
    "host_capabilities": [],
    "extension": ">=0.1.0"
  }
}
