{
  "type": "adapter_function",
  "id": "curve/factory-crypto/_template/removeLiquidity@1.0.0",
  "publisher": "curve.fi",
  "schema_version": "2",
  "match": {
    "selector": "0x5b36389c",
    "chain_to_addresses": {
      "__CHAIN_ID__": ["__POOL_ADDRESS__"]
    }
  },
  "abi_fragment": {
    "function_name": "remove_liquidity",
    "abi": {
      "name": "remove_liquidity",
      "type": "function",
      "inputs": [
        { "name": "_amount",     "type": "uint256"    },
        { "name": "min_amounts", "type": "uint256[2]" }
      ]
    }
  },
  "emit": {
    "strategy": "single_emit",
    "category": "dex",
    "action": "remove_liquidity",
    "fields": {
      "exitMode":                      { "literal": "proportional" },
      "pool.address":                  { "literal": "__POOL_ADDRESS__" },
      "inputLp.asset.kind":            { "literal": "erc20" },
      "inputLp.asset.address":         { "literal": "__LP_TOKEN__" },
      "inputLp.amount.kind":           { "literal": "exact" },
      "inputLp.amount.value":          { "from": "$.args._amount" },
      "outputTokens[0].asset.kind":    { "literal": "erc20" },
      "outputTokens[0].asset.address": { "literal": "__COIN0__" },
      "outputTokens[1].asset.kind":    { "literal": "erc20" },
      "outputTokens[1].asset.address": { "literal": "__COIN1__" },
      "outputTokens[0].amount.kind":   { "literal": "min" },
      "outputTokens[0].amount.value":  { "from": "$.args.min_amounts[0]" },
      "outputTokens[1].amount.kind":   { "literal": "min" },
      "outputTokens[1].amount.value":  { "from": "$.args.min_amounts[1]" },
      "recipient":                     { "from": "$.tx.from" }
    }
  },
  "requires": {
    "imperative": [],
    "adapter_capabilities": ["token_metadata"],
    "host_capabilities": [],
    "extension": ">=0.1.0"
  }
}
