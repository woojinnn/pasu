{
  "type": "adapter_function",
  "id": "curve/router-ng/exchange-xlayer@1.0.0",
  "publisher": "curve.fi",
  "match": {
    "chain_ids": [196],
    "to": ["0xBFab8ebc836E1c4D81837798FC076D219C9a1855"],
    "selector": "0xaad348a2"
  },
  "abi_fragment": {
    "function_name": "exchange",
    "abi": {
      "name": "exchange",
      "type": "function",
      "inputs": [
        { "name": "_route",       "type": "address[11]"   },
        { "name": "_swap_params", "type": "uint256[4][5]" },
        { "name": "_amount",      "type": "uint256"       },
        { "name": "_expected",    "type": "uint256"       }
      ]
    }
  },
  "emit": {
    "strategy": "single_emit",
    "category": "dex",
    "action": "swap",
    "fields": {
      "swapMode":                  { "literal": "exact_in" },
      "inputToken.asset.kind":     { "literal": "erc20" },
      "inputToken.asset.address":  {
        "fn": "select_address",
        "args": [
          { "from": "$.args._route" },
          { "literal": 0 }
        ]
      },
      "inputToken.amount.kind":    { "literal": "exact" },
      "inputToken.amount.value":   { "from": "$.args._amount" },
      "outputToken.asset.kind":    { "literal": "erc20" },
      "outputToken.asset.address": {
        "fn": "curve_route_last_token",
        "args": [{ "from": "$.args._route" }]
      },
      "outputToken.amount.kind":   { "literal": "min" },
      "outputToken.amount.value":  { "from": "$.args._expected" },
      "recipient":                 { "from": "$.tx.from" }
    }
  },
  "requires": {
    "imperative":        [],
    "host_capabilities": ["host:token_metadata"],
    "extension":         ">=0.1.0"
  }
}
