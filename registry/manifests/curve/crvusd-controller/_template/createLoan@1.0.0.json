{
  "type": "adapter_function",
  "id": "curve/crvusd-controller/_template/createLoan@1.0.0",
  "publisher": "curve.fi",
  "schema_version": "2",
  "match": {
    "selector": "0x23cfed03",
    "chain_to_addresses": {
      "__CHAIN_ID__": ["__CONTROLLER_ADDRESS__"]
    }
  },
  "abi_fragment": {
    "function_name": "create_loan",
    "abi": {
      "name": "create_loan",
      "type": "function",
      "inputs": [
        { "name": "collateral", "type": "uint256" },
        { "name": "debt",       "type": "uint256" },
        { "name": "N",          "type": "uint256" }
      ]
    }
  },
  "emit": {
    "strategy": "single_emit",
    "category": "lending",
    "action": "borrow",
    "fields": {
      "market.address":          { "literal": "__CONTROLLER_ADDRESS__" },
      "market.label":            { "literal": "Curve crvUSD Controller" },
      "asset.kind":              { "literal": "erc20" },
      "asset.address":           { "literal": "0xf939e0a03fb07f59a73314e73794be0e57ac1b4e" },
      "amount.kind":             { "literal": "exact" },
      "amount.value":            { "from": "$.args.debt" },
      "collateralAsset.kind":    { "literal": "erc20" },
      "collateralAsset.address": { "literal": "__COLLATERAL_ADDRESS__" },
      "collateralAmount.kind":   { "literal": "exact" },
      "collateralAmount.value":  { "from": "$.args.collateral" },
      "recipient":               { "from": "$.tx.from" },
      "onBehalf":                { "from": "$.tx.from" }
    }
  },
  "requires": {
    "imperative": [],
    "adapter_capabilities": ["token_metadata"],
    "host_capabilities": [],
    "extension": ">=0.1.0"
  }
}
