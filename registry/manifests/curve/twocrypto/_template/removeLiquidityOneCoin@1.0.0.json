{
  "type": "adapter_function",
  "id": "curve/twocrypto/_template/removeLiquidityOneCoin@1.0.0",
  "publisher": "curve.fi",
  "schema_version": "2",
  "match": {
    "selector": "0x0fbcee6e",
    "chain_to_addresses": {
      "__CHAIN_ID__": ["__POOL_ADDRESS__"]
    }
  },
  "abi_fragment": {
    "function_name": "remove_liquidity_one_coin",
    "abi": {
      "name": "remove_liquidity_one_coin",
      "type": "function",
      "inputs": [
        { "name": "token_amount", "type": "uint256" },
        { "name": "i",            "type": "uint256" },
        { "name": "min_amount",   "type": "uint256" },
        { "name": "receiver",     "type": "address" }
      ]
    }
  },
  "emit": {
    "strategy": "single_emit",
    "category": "dex",
    "action": "remove_liquidity",
    "fields": {
      "exitMode":                      { "literal": "single_asset" },
      "pool.address":                  { "literal": "__POOL_ADDRESS__" },
      "inputLp.asset.kind":            { "literal": "erc20" },
      "inputLp.asset.address":         { "literal": "__LP_TOKEN__" },
      "inputLp.amount.kind":           { "literal": "exact" },
      "inputLp.amount.value":          { "from": "$.args.token_amount" },
      "outputTokens[0].asset.kind":    { "literal": "erc20" },
      "outputTokens[0].asset.address": {
        "fn": "select_from_literal_array",
        "args": [
          { "literal": ["__COIN0__", "__COIN1__"] },
          { "from": "$.args.i" }
        ]
      },
      "outputTokens[0].amount.kind":   { "literal": "min" },
      "outputTokens[0].amount.value":  { "from": "$.args.min_amount" },
      "recipient":                     { "from": "$.args.receiver" }
    }
  },
  "requires": {
    "imperative": [],
    "adapter_capabilities": ["token_metadata"],
    "host_capabilities": [],
    "extension": ">=0.1.0"
  }
}
