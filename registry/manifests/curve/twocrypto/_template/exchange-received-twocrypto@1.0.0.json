{
  "type": "adapter_function",
  "id": "curve/twocrypto/_template/exchange-received-twocrypto@1.0.0",
  "publisher": "curve.fi",
  "match": {
    "chain_ids": [1],
    "to": ["0x1111111111111111111111111111111111111111"],
    "selector": "0x767691e7"
  },
  "abi_fragment": {
    "function_name": "exchange_received",
    "abi": {
      "name": "exchange_received",
      "type": "function",
      "inputs": [
        { "name": "i",         "type": "uint256" },
        { "name": "j",         "type": "uint256" },
        { "name": "dx",        "type": "uint256" },
        { "name": "min_dy",    "type": "uint256" },
        { "name": "receiver",  "type": "address" }
      ]
    }
  },
  "emit": {
    "strategy": "single_emit",
    "category": "dex",
    "action": "swap",
    "fields": {
      "swapMode":                  { "literal": "exact_in" },
      "inputToken.asset.kind":     { "literal": "erc20" },
      "inputToken.asset.address":  {
        "fn": "select_from_literal_array",
        "args": [
          { "literal": [
            "0xaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa1",
            "0xaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa2"
          ] },
          { "from": "$.args.i" }
        ]
      },
      "inputToken.amount.kind":    { "literal": "exact" },
      "inputToken.amount.value":   { "from": "$.args.dx" },
      "outputToken.asset.kind":    { "literal": "erc20" },
      "outputToken.asset.address": {
        "fn": "select_from_literal_array",
        "args": [
          { "literal": [
            "0xaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa1",
            "0xaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa2"
          ] },
          { "from": "$.args.j" }
        ]
      },
      "outputToken.amount.kind":   { "literal": "min" },
      "outputToken.amount.value":  { "from": "$.args.min_dy" },
      "recipient":                 { "from": "$.args.receiver" }
    }
  },
  "requires": {
    "imperative":        [],
    "host_capabilities": ["host:token_metadata"],
    "extension":         ">=0.1.0"
  }
}
