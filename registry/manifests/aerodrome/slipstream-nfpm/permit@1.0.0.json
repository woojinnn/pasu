{
  "type": "adapter_function",
  "id": "aerodrome/slipstream-nfpm/permit@1.0.0",
  "publisher": "aerodrome.eth",
  "schema_version": "2",
  "match": {
    "selector": "0x7ac2ff7b",
    "chain_to_addresses": {
      "8453": ["0x827922686190790b37229fd06084350E74485b72"]
    }
  },
  "abi_fragment": {
    "function_name": "permit",
    "abi": {
      "name": "permit",
      "type": "function",
      "stateMutability": "payable",
      "inputs": [
        { "name": "spender",  "type": "address" },
        { "name": "tokenId",  "type": "uint256" },
        { "name": "deadline", "type": "uint256" },
        { "name": "v",        "type": "uint8"   },
        { "name": "r",        "type": "bytes32" },
        { "name": "s",        "type": "bytes32" }
      ]
    }
  },
  "emit": {
    "strategy": "single_emit",
    "category": "misc",
    "action": "permit",
