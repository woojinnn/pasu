      "owner":              { "from": "$.tx.from" },
      "spender":            { "from": "$.args.spender" },
      "validity.expiresAt": { "from": "$.args.deadline" },
      "validity.source":    { "literal": "signature-deadline" }
    }
  },
  "requires": {
    "imperative": [],
    "adapter_capabilities": ["token_metadata"],
    "host_capabilities": [],
    "extension": ">=0.1.0"
  }
}
