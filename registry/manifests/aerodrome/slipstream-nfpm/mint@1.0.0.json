      "inputTokens[0].amount.kind":    { "literal": "min" },
      "inputTokens[0].amount.value":   { "from": "$.args.amount0Min" },
      "inputTokens[1].asset.kind":     { "literal": "erc20" },
      "inputTokens[1].asset.address":  { "from": "$.args.token1" },
      "inputTokens[1].amount.kind":    { "literal": "min" },
      "inputTokens[1].amount.value":   { "from": "$.args.amount1Min" },
      "recipient":                     { "from": "$.args.recipient" },
      "validity.expiresAt":            { "from": "$.args.deadline" },
      "validity.source":               { "literal": "tx-deadline" }
    }
  },
  "requires": {
    "imperative": [],
    "adapter_capabilities": ["token_metadata"],
    "host_capabilities": [],
    "extension": ">=0.1.0"
  }
