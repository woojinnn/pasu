{
  "type": "adapter_function",
  "id": "aerodrome/voting-escrow/safeTransferFrom@1.0.0",
  "publisher": "aerodrome.finance",
  "schema_version": "2",
  "match": {
    "selector": "0x42842e0e",
    "chain_to_addresses": {
      "8453": ["0xeBf418Fe2512e7E6bd9b87a8F0f294aCDC67e6B4"]
    }
  },
  "abi_fragment": {
    "function_name": "safeTransferFrom",
    "abi": {
      "name": "safeTransferFrom",
      "type": "function",
      "stateMutability": "nonpayable",
      "inputs": [
        { "name": "_from",    "type": "address" },
        { "name": "_to",      "type": "address" },
        { "name": "_tokenId", "type": "uint256" }
      ]
    }
  },
  "emit": {
    "strategy": "single_emit",
    "category": "misc",
    "action": "transfer",
    "fields": {
      "token.asset.kind":    { "literal": "erc721" },
      "token.asset.address": { "from": "$.tx.to" },
      "token.asset.tokenId": { "from": "$.args._tokenId" },
      "token.amount.kind":   { "literal": "exact" },
      "token.amount.value":  { "literal": "1" },
      "from":                { "from": "$.args._from" },
      "recipient":           { "from": "$.args._to" }
    }
  },
  "requires": {
    "imperative": [],
    "adapter_capabilities": ["token_metadata"],
    "host_capabilities": [],
    "extension": ">=0.1.0"
  }
}
