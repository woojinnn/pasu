{
  "type": "adapter_function",
  "id": "aerodrome/v2/swapExactETHForTokens@1.0.0",
  "publisher": "aerodrome.finance",
  "match": {
    "chain_ids": [8453],
    "to": ["0xcF77a3Ba9A5CA399B7c97c74d54e5b1Beb874E43"],
    "selector": "0x903638a4"
  },
  "abi_fragment": {
    "function_name": "swapExactETHForTokens",
    "abi": {
      "name": "swapExactETHForTokens",
      "type": "function",
      "stateMutability": "payable",
      "inputs": [
        { "name": "amountOutMin", "type": "uint256" },
        {
          "name": "routes",
          "type": "tuple[]",
          "components": [
            { "name": "from",    "type": "address" },
            { "name": "to",      "type": "address" },
            { "name": "stable",  "type": "bool"    },
            { "name": "factory", "type": "address" }
          ]
        },
        { "name": "to",       "type": "address" },
        { "name": "deadline", "type": "uint256" }
      ]
    }
  },
  "emit": {
    "strategy": "single_emit",
    "category": "dex",
    "action": "swap",
    "fields": {
      "inputToken.asset.kind":     { "literal": "native" },
      "inputToken.amount.kind":    { "literal": "exact" },
      "inputToken.amount.value":   { "from": "$.tx.value_wei" },
      "outputToken.asset.kind":    { "literal": "erc20" },
      "outputToken.asset.address": { "from": "$.args.routes[-1][1]" },
      "outputToken.amount.kind":   { "literal": "min" },
      "outputToken.amount.value":  { "from": "$.args.amountOutMin" },
      "recipient":                 { "from": "$.args.to" },
      "validity.expiresAt":        { "from": "$.args.deadline" },
      "validity.source":           { "literal": "tx-deadline" }
    }
  },
  "requires": {
    "imperative": [],
    "adapter_capabilities": ["token_metadata"],
    "host_capabilities": [],
    "extension": ">=0.1.0"
  }
}
