{
  "type": "adapter_function",
  "id": "aerodrome/v2/removeLiquidityETH@1.0.0",
  "publisher": "aerodrome.finance",
  "match": {
    "chain_ids": [8453],
    "to": ["0xcF77a3Ba9A5CA399B7c97c74d54e5b1Beb874E43"],
    "selector": "0xd7b0e0a5"
  },
  "abi_fragment": {
    "function_name": "removeLiquidityETH",
    "abi": {
      "name": "removeLiquidityETH",
      "type": "function",
      "inputs": [
        { "name": "token",          "type": "address" },
        { "name": "stable",         "type": "bool"    },
        { "name": "liquidity",      "type": "uint256" },
        { "name": "amountTokenMin", "type": "uint256" },
        { "name": "amountETHMin",   "type": "uint256" },
        { "name": "to",             "type": "address" },
        { "name": "deadline",       "type": "uint256" }
      ]
    }
  },
  "emit": {
    "strategy": "single_emit",
    "category": "dex",
    "action": "remove_liquidity",
    "fields": {
      "exitMode":                           { "literal": "proportional" },
      "pool.address":                       { "literal": "0x0000000000000000000000000000000000000000" },
      "inputLp.asset.kind":                 { "literal": "erc20" },
      "inputLp.amount.kind":                { "literal": "exact" },
      "inputLp.amount.value":               { "from": "$.args.liquidity" },
      "outputTokens[0].asset.kind":         { "literal": "erc20" },
      "outputTokens[0].asset.address":      { "from": "$.args.token" },
      "outputTokens[0].amount.kind":        { "literal": "min" },
      "outputTokens[0].amount.value":       { "from": "$.args.amountTokenMin" },
      "outputTokens[1].asset.kind":         { "literal": "native" },
      "outputTokens[1].amount.kind":        { "literal": "min" },
      "outputTokens[1].amount.value":       { "from": "$.args.amountETHMin" },
      "recipient":                          { "from": "$.args.to" },
      "validity.expiresAt":                 { "from": "$.args.deadline" },
      "validity.source":                    { "literal": "tx-deadline" }
    }
  },
  "requires": {
    "imperative": [],
    "adapter_capabilities": ["token_metadata"],
    "host_capabilities": [],
    "extension": ">=0.1.0"
  }
}
