{
  "type": "adapter_function",
  "id": "aerodrome/slipstream/exactInput@1.0.0",
  "publisher": "aerodrome.eth",
  "match": {
    "chain_ids": [8453],
    "to": ["0xBE6D8f0d05cc4be24d5167a3eF062215bE6D18a5"],
    "selector": "0xc04b8d59"
  },
  "abi_fragment": {
    "function_name": "exactInput",
    "abi": {
      "name": "exactInput",
      "type": "function",
      "inputs": [
        {
          "name": "params",
          "type": "tuple",
          "components": [
            { "name": "path",             "type": "bytes"   },
            { "name": "recipient",        "type": "address" },
            { "name": "deadline",         "type": "uint256" },
            { "name": "amountIn",         "type": "uint256" },
            { "name": "amountOutMinimum", "type": "uint256" }
          ]
        }
      ]
    }
  },
  "emit": {
    "strategy": "single_emit",
    "category": "dex",
    "action": "swap",
    "fields": {
      "swapMode":                  { "literal": "exact_in" },
      "inputToken.asset.kind":     { "literal": "erc20" },
      "inputToken.asset.address":  {
        "fn": "unfold_slipstream_path",
        "args": [{ "from": "$.args.params[0]" }, { "literal": "first_token" }]
      },
      "inputToken.amount.kind":    { "literal": "exact" },
      "inputToken.amount.value":   { "from": "$.args.params[3]" },
      "outputToken.asset.kind":    { "literal": "erc20" },
      "outputToken.asset.address": {
        "fn": "unfold_slipstream_path",
        "args": [{ "from": "$.args.params[0]" }, { "literal": "last_token" }]
      },
      "outputToken.amount.kind":   { "literal": "min" },
      "outputToken.amount.value":  { "from": "$.args.params[4]" },
      "recipient":                 { "from": "$.args.params[1]" },
      "validity.expiresAt":        { "from": "$.args.params[2]" },
      "validity.source":           { "literal": "tx-deadline" }
    }
  },
  "requires": {
    "imperative": [],
    "adapter_capabilities": ["token_metadata"],
    "host_capabilities": [],
    "extension": ">=0.1.0"
  }
}
