{
  "module": "action::kind",
  "source": "src/action/kind.rs",
  "description": "ActionType — 구체적인 atomic 종류. 1:1로 타입화된 ActionFields에 매핑. v0.1 보강에서 16종 → 72종으로 확장. Bridge·Perp는 의도적 제외 (v0.2 후보).",
  "imports": ["category::ActionCategory"],
  "enums": {
    "ActionType": {
      "doc": "구체적인 atomic 종류 (72종). 1:1로 타입화된 ActionFields에 매핑.",
      "derives": ["Debug", "Clone", "Copy", "PartialEq", "Eq", "Hash", "Serialize", "Deserialize"],
      "serde_rename_all": "snake_case",
      "variants": [
        { "name": "RouterPlan",              "serde_rename": "router_plan",              "category": "Aggregation",    "section": "v1 보존",         "doc": "Universal Router execute(...)의 의미적 컨테이너 (promote = false)." },
        { "name": "Swap",                    "serde_rename": "swap",                     "category": "Swap",           "section": "v1 보존",         "doc": "일반 swap (V2/V3 single 또는 multi-hop, single-protocol)." },
        { "name": "Wrap",                    "serde_rename": "wrap",                     "category": "Swap",           "section": "v1 보존",         "doc": "1:1 토큰 변환 (예: ETH → WETH, stETH → wstETH). SwapFields 재사용." },
        { "name": "Unwrap",                  "serde_rename": "unwrap",                   "category": "Swap",           "section": "v1 보존",         "doc": "1:1 역변환 (WETH → ETH, wstETH → stETH)." },
        { "name": "Approval",                "serde_rename": "approval",                 "category": "Utility",        "section": "v1 보존",         "doc": "ERC20 approve(spender, amount) 호출." },
        { "name": "Permit",                  "serde_rename": "permit",                   "category": "Utility",        "section": "v1 보존",         "doc": "EIP-2612 permit(...) 인라인 호출 (calldata 안의 self-permit)." },
        { "name": "Transfer",                "serde_rename": "transfer",                 "category": "Utility",        "section": "v1 보존",         "doc": "ERC20 / ERC721 / ERC1155 transfer / safeTransferFrom." },
        { "name": "AddLiquidity",            "serde_rename": "add_liquidity",            "category": "Liquidity",      "section": "v1 보존",         "doc": "V2 / Aerodrome V1 add_liquidity." },
        { "name": "RemoveLiquidity",         "serde_rename": "remove_liquidity",         "category": "Liquidity",      "section": "v1 보존",         "doc": "V2 / Aerodrome V1 remove_liquidity." },
        { "name": "JoinPool",                "serde_rename": "join_pool",                "category": "Liquidity",      "section": "v1 보존",         "doc": "Balancer V2 joinPool." },
        { "name": "ExitPool",                "serde_rename": "exit_pool",                "category": "Liquidity",      "section": "v1 보존",         "doc": "Balancer V2 exitPool." },
        { "name": "BatchSwap",               "serde_rename": "batch_swap",               "category": "Swap",           "section": "v1 보존",         "doc": "Balancer V2 batchSwap 또는 멀티-protocol split (PancakeSwap SmartRouter)." },
        { "name": "HookedOperation",         "serde_rename": "hooked_operation",         "category": "Swap",           "section": "v1 보존",         "doc": "V4 hook을 거치는 swap (PoolKey.hooks ≠ 0). hook 의미가 외부 의존." },
        { "name": "Unknown",                 "serde_rename": "unknown",                  "category": "Unknown",        "section": "v1 보존",         "doc": "분류 실패 catch-all." },

        { "name": "Supply",                  "serde_rename": "supply",                   "category": "Lending",        "section": "Lending",         "doc": "Aave/Morpho supply(asset, amount, onBehalfOf, ...)." },
        { "name": "Borrow",                  "serde_rename": "borrow",                   "category": "Lending",        "section": "Lending",         "doc": "Aave/Morpho borrow(asset, amount, ..., onBehalfOf)." },
        { "name": "Repay",                   "serde_rename": "repay",                    "category": "Lending",        "section": "Lending",         "doc": "Aave/Morpho repay(asset, amount, ...)." },
