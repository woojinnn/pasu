# Overrides .env for the `ext` profile — put shared secrets (GOOGLE_*,
# JWT_SECRET, DATABASE_URL, …) in .env, not here.
#
# Profile: BROWSER EXTENSION OAUTH TESTING.
# `scripts/start-policy-server.sh ext` sources `.env` first, then this
# overlay. Use it when testing the extension's options page OAuth flow: the
# dashboard there calls `chrome.identity.launchWebAuthFlow` (via the SW),
# which captures the final redirect URL when it matches
# `https://<extension-id>.chromiumapp.org/*` — that URL is unreachable by the
# browser but Chrome intercepts it and hands the tokens back to the extension.
#
# The fixed extension id is pinned by the `__chrome__key` field in
# `browser-extension/backend/manifest.json` — see that file if you rotate the
# local signing key (`.dambi-extension-key.pem`).
#
# In Google Cloud Console register BOTH GOOGLE_REDIRECT_URI below AND the
# chromiumapp.org origin as Authorized redirect URIs.
#
# Copy to `.env.ext`.

# Server's OAuth callback — must match Google Cloud Console exactly.
GOOGLE_REDIRECT_URI=http://127.0.0.1:8788/auth/google/callback

# launchWebAuthFlow captures this URL. The extension id MUST match the one
# derived from .dambi-extension-key.pem (see manifest's __chrome__key).
DASHBOARD_URL=https://fbadoakiikjmgdpdhpcohaddifhaggki.chromiumapp.org

# CORS — the extension's options page origin is allowed. The 5173 origin
# stays in the list so you can still hit the same server from the dev
# dashboard for read-only API smoke tests; only OAuth diverges.
CORS_ALLOWED_ORIGINS=chrome-extension://fbadoakiikjmgdpdhpcohaddifhaggki,http://127.0.0.1:5173,http://localhost:5173
