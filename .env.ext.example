# Server profile: BROWSER EXTENSION OAUTH TESTING.
#
# Copy to `.env.ext` and fill in the GOOGLE_* + JWT_SECRET values.
# `yarn server:ext` (or `scripts/start-policy-server.sh ext`) loads this
# file and starts the policy-rpc server.
#
# Use this profile when testing the extension's options page OAuth
# flow. The dashboard there calls `chrome.identity.launchWebAuthFlow`
# (via the SW), which captures the final redirect URL when it matches
# `https://<extension-id>.chromiumapp.org/*` — that URL is unreachable
# by the browser but Chrome intercepts it and hands the tokens back to
# the extension.
#
# The fixed extension id is pinned by the `__chrome__key` field in
# `browser-extension/backend/manifest.json` — see that file if you
# rotate the local signing key (`.pasu-extension-key.pem`).

# Google OAuth 2.0 Web client. Register BOTH the GOOGLE_REDIRECT_URI
# below AND the chromiumapp.org origin as Authorized redirect URIs.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

JWT_SECRET=

GOOGLE_REDIRECT_URI=http://127.0.0.1:8788/auth/google/callback

# launchWebAuthFlow captures this URL. The extension id MUST match the
# one derived from .pasu-extension-key.pem (see manifest's
# __chrome__key).
DASHBOARD_URL=https://fbadoakiikjmgdpdhpcohaddifhaggki.chromiumapp.org

POLICY_SERVER_ADDR=127.0.0.1:8788
PUBLIC_API_URL=http://127.0.0.1:8788

# CORS — the extension's options page origin is allowed. The 5173 origin
# stays in the list so you can still hit the same server from the dev
# dashboard for read-only API smoke tests; only OAuth diverges.
CORS_ALLOWED_ORIGINS=chrome-extension://fbadoakiikjmgdpdhpcohaddifhaggki,http://127.0.0.1:5173,http://localhost:5173
CORS_ALLOW_PRIVATE_NETWORK=true

DATABASE_URL=
REDIS_URL=

PASU_SYNC_CONFIG=./pasu-sync.toml
SYNC_WORKER_TICK_SECS=30

ETHERSCAN_API_KEY=
