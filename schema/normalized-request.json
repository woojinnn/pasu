{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema_v260510a/normalized-request.json",
  "title": "NormalizedRequest",
  "description": "최상위 컨테이너 — request envelope + decoded calls + N actions[] + extensions + confidence + raw. Per docs/05-schema-spec.md §9.",

  "type": "object",
  "properties": {
    "schemaVersion": { "const": "2.1.0" },
    "request": { "$ref": "envelope.json#/$defs/RequestEnvelope" },
    "targets": {
      "type": "array",
      "items": { "$ref": "envelope.json#/$defs/ContractTarget" }
    },
    "decodedCalls": {
      "type": "array",
      "items": { "$ref": "envelope.json#/$defs/DecodedCall" }
    },
    "actions": {
      "type": "array",
      "items": { "$ref": "action.json" }
    },
    "extensions": {
      "type": "array",
      "items": { "$ref": "extension.json" }
    },
    "confidence": {
      "type": "object",
      "properties": {
        "request": { "$ref": "_common.json#/$defs/ConfidenceLevel" },
        "targetIdentification": { "$ref": "_common.json#/$defs/ConfidenceLevel" },
        "abiDecode": { "$ref": "_common.json#/$defs/ConfidenceLevel" },
        "protocolDecode": { "$ref": "_common.json#/$defs/ConfidenceLevel" },
        "semanticAction": { "$ref": "_common.json#/$defs/ConfidenceLevel" },
        "routeDecode": { "$ref": "_common.json#/$defs/ConfidenceLevel" },
        "amountInterpretation": { "$ref": "_common.json#/$defs/ConfidenceLevel" },
        "overall": { "$ref": "_common.json#/$defs/ConfidenceLevel" },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "raw": { "$ref": "envelope.json#/$defs/RawRequestData" }
  },
  "required": ["schemaVersion", "request", "targets", "decodedCalls", "actions", "confidence", "raw"]
}
