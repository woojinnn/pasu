{
  "id": "schema::DEX/swap/enrichment",
  "schema_version": 1,
  "requires": [
    {
      "id": "swap-total-input-usd",
      "when": { "action": "swap" },
      "method": "oracle.usd_value",
      "params": {
        "chain_id": "$.root.chain_id",
        "asset": "$.action.inputToken.asset",
        "amount": "$.action.inputToken.amount.value"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "totalInputUsd",
          "type": "UsdValuation",
          "from": "$.result",
          "required": false
        }
      ],
      "optional": true
    },
    {
      "id": "swap-total-min-output-usd",
      "when": { "action": "swap" },
      "method": "oracle.usd_value",
      "params": {
        "chain_id": "$.root.chain_id",
        "asset": "$.action.outputToken.asset",
        "amount": "$.action.outputToken.amount.value"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "totalMinOutputUsd",
          "type": "UsdValuation",
          "from": "$.result",
          "required": false
        }
      ],
      "optional": true
    },
    {
      "id": "swap-effective-rate-vs-oracle-bps",
      "when": { "action": "swap" },
      "method": "oracle.effective_rate_bps",
      "params": {
        "chain_id": "$.root.chain_id",
        "token_in": "$.action.inputToken.asset",
        "amount_in": "$.action.inputToken.amount.value",
        "token_out": "$.action.outputToken.asset",
        "amount_out": "$.action.outputToken.amount.value"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "effectiveRateVsOracleBps",
          "type": "Long",
          "from": "$.result.bps",
          "required": false
        }
      ],
      "optional": true
    },
    {
      "id": "swap-input-fraction-of-portfolio-bps",
      "when": { "action": "swap" },
      "method": "portfolio.input_fraction_bps",
      "params": {
        "chain_id": "$.root.chain_id",
        "owner": "$.root.from",
        "asset": "$.action.inputToken.asset",
        "amount": "$.action.inputToken.amount.value"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "totalInputFractionOfPortfolioBps",
          "type": "Long",
          "from": "$.result.bps",
          "required": false
        }
      ],
      "optional": true
    },
    {
      "id": "swap-window-stats",
      "when": { "action": "swap" },
      "method": "stat_window.swap_stats",
      "params": {
        "owner": "$.root.from",
        "action": "swap"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "windowStats",
          "type": "WindowStats",
          "from": "$.result",
          "required": false
        }
      ],
      "optional": true
    },
    {
      "id": "swap-validity-delta-sec",
      "when": { "action": "swap" },
      "method": "clock.validity_delta_sec",
      "params": {
        "expires_at": "$.action.validity.expiresAt",
        "block_timestamp": "$.root.block_timestamp"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "validityDeltaSec",
          "type": "Long",
          "from": "$.result.delta_sec",
          "required": false
        }
      ],
      "optional": true
    },
    {
      "id": "swap-recipient-is-contract",
      "when": { "action": "swap" },
      "method": "chain.is_contract",
      "params": {
        "chain_id": "$.root.chain_id",
        "address": "$.action.recipient"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "recipientIsContract",
          "type": "Bool",
          "from": "$.result.is_contract",
          "required": false
        }
      ],
      "optional": true
    }
  ]
}
