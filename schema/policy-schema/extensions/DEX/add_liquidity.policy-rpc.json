{
  "id": "schema::DEX/add_liquidity/enrichment",
  "schema_version": 1,
  "requires": [
    {
      "id": "add-liquidity-total-input-usd",
      "when": { "action": "add_liquidity" },
      "method": "oracle.usd_value",
      "params": {
        "chain_id": "$.root.chain_id",
        "inputTokens": "$.action.inputTokens"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "totalInputUsd",
          "type": "UsdValuation",
          "from": "$.result",
          "required": false
        }
      ]
    },
    {
      "id": "add-liquidity-total-min-output-usd",
      "when": { "action": "add_liquidity" },
      "method": "oracle.usd_value",
      "params": {
        "chain_id": "$.root.chain_id",
        "asset": "$.action.outputLp.asset",
        "amount": "$.action.outputLp.amount.value"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "totalMinOutputUsd",
          "type": "UsdValuation",
          "from": "$.result",
          "required": false
        }
      ],
      "optional": true
    },
    {
      "id": "add-liquidity-effective-rate-vs-oracle-bps",
      "when": { "action": "add_liquidity" },
      "method": "oracle.effective_rate_bps",
      "params": {
        "chain_id": "$.root.chain_id",
        "inputTokens": "$.action.inputTokens",
        "outputLp": "$.action.outputLp"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "effectiveRateVsOracleBps",
          "type": "Long",
          "from": "$.result.bps",
          "required": false
        }
      ]
    },
    {
      "id": "add-liquidity-total-input-fraction-of-portfolio-bps",
      "when": { "action": "add_liquidity" },
      "method": "portfolio.input_fraction_bps",
      "params": {
        "chain_id": "$.root.chain_id",
        "owner": "$.root.from",
        "inputTokens": "$.action.inputTokens"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "totalInputFractionOfPortfolioBps",
          "type": "Long",
          "from": "$.result.bps",
          "required": false
        }
      ]
    },
    {
      "id": "add-liquidity-window-stats",
      "when": { "action": "add_liquidity" },
      "method": "stat_window.add_liquidity_stats",
      "params": {
        "owner": "$.root.from",
        "action": "add_liquidity"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "windowStats",
          "type": "WindowStats",
          "from": "$.result",
          "required": false
        }
      ]
    }
  ]
}
