{
  "id": "schema::DEX/remove_liquidity/enrichment",
  "schema_version": 1,
  "requires": [
    {
      "id": "remove-liquidity-total-input-usd",
      "when": { "action": "remove_liquidity" },
      "method": "oracle.usd_value",
      "params": {
        "chain_id": "$.root.chain_id",
        "asset": "$.action.inputLp.asset",
        "amount": "$.action.inputLp.amount.value"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "totalInputUsd",
          "type": "UsdValuation",
          "from": "$.result",
          "required": false
        }
      ],
      "optional": true
    },
    {
      "id": "remove-liquidity-total-min-output-usd",
      "when": { "action": "remove_liquidity" },
      "method": "oracle.usd_value",
      "params": {
        "chain_id": "$.root.chain_id",
        "outputTokens": "$.action.outputTokens"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "totalMinOutputUsd",
          "type": "UsdValuation",
          "from": "$.result",
          "required": false
        }
      ],
      "optional": true
    },
    {
      "id": "remove-liquidity-effective-rate-vs-oracle-bps",
      "when": { "action": "remove_liquidity" },
      "method": "oracle.effective_rate_bps",
      "params": {
        "chain_id": "$.root.chain_id",
        "inputLp": "$.action.inputLp",
        "outputTokens": "$.action.outputTokens"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "effectiveRateVsOracleBps",
          "type": "Long",
          "from": "$.result.bps",
          "required": false
        }
      ]
    },
    {
      "id": "remove-liquidity-window-stats",
      "when": { "action": "remove_liquidity" },
      "method": "stat_window.remove_liquidity_stats",
      "params": {
        "owner": "$.root.from",
        "action": "remove_liquidity"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "windowStats",
          "type": "WindowStats",
          "from": "$.result",
          "required": false
        }
      ]
    }
  ]
}
