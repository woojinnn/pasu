{
  "id": "schema::DEX/burn_liquidity_nft/enrichment",
  "schema_version": 1,
  "requires": [
    {
      "id": "burn-liquidity-nft-total-input-usd",
      "when": { "action": "burn_liquidity_nft" },
      "method": "oracle.usd_value",
      "params": {
        "chain_id": "$.root.chain_id",
        "nft": "$.action.nft"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "totalInputUsd",
          "type": "UsdValuation",
          "from": "$.result",
          "required": false
        }
      ]
    },
    {
      "id": "burn-liquidity-nft-total-min-output-usd",
      "when": { "action": "burn_liquidity_nft" },
      "method": "oracle.usd_value",
      "params": {
        "chain_id": "$.root.chain_id",
        "outputTokens": "$.action.outputTokens"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "totalMinOutputUsd",
          "type": "UsdValuation",
          "from": "$.result",
          "required": false
        }
      ],
      "optional": true
    },
    {
      "id": "burn-liquidity-nft-effective-rate-vs-oracle-bps",
      "when": { "action": "burn_liquidity_nft" },
      "method": "oracle.effective_rate_bps",
      "params": {
        "chain_id": "$.root.chain_id",
        "nft": "$.action.nft",
        "outputTokens": "$.action.outputTokens"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "effectiveRateVsOracleBps",
          "type": "Long",
          "from": "$.result.bps",
          "required": false
        }
      ],
      "optional": true
    },
    {
      "id": "burn-liquidity-nft-nft-owner-is-actor",
      "when": { "action": "burn_liquidity_nft" },
      "method": "nft.owner_is_actor",
      "params": {
        "chain_id": "$.root.chain_id",
        "nft": "$.action.nft"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "nftOwnerIsActor",
          "type": "Bool",
          "from": "$.result.ownerIsActor",
          "required": false
        }
      ]
    },
    {
      "id": "burn-liquidity-nft-window-stats",
      "when": { "action": "burn_liquidity_nft" },
      "method": "stat_window.burn_liquidity_nft_stats",
      "params": {
        "owner": "$.root.from",
        "action": "burn_liquidity_nft"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "windowStats",
          "type": "WindowStats",
          "from": "$.result",
          "required": false
        }
      ]
    }
  ],
  "context_extensions": {
    "burn_liquidity_nft": {
      "totalInputUsd": "UsdValuation",
      "totalMinOutputUsd": "UsdValuation",
      "effectiveRateVsOracleBps": "Long",
      "nftOwnerIsActor": "Bool",
      "windowStats": "WindowStats"
    }
  }
}
