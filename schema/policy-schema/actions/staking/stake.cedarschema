type StakeContext = {
  tokenIn: AssetRef,
  receiptToken: AssetRef,

  amountIn: AmountConstraint,
  amountOut?: AmountConstraint,

  recipient: String,
  custom?: StakeCustomContext,
};

type StakeCustomContext = {};

action "stake" appliesTo {
  principal: Wallet,
  resource: Protocol,
  context: StakeContext,
};
