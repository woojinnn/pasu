type ApproveContext = {
  approvalKind: String,

  token: AssetRef,
  spender: String,

  amount: AmountConstraint,

  validity?: Validity,
  custom?: ApproveCustomContext,
};

type ApproveCustomContext = {};

action "approve" appliesTo {
  principal: Wallet,
  resource: Protocol,
  context: ApproveContext,
};
