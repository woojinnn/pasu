type SetApprovalForAllContext = {
  collection: AssetRef,
  operator: String,

  approved: Bool,
  custom?: SetApprovalForAllCustomContext,
};

type SetApprovalForAllCustomContext = {};

action "set_approval_for_all" appliesTo {
  principal: Wallet,
  resource: Protocol,
  context: SetApprovalForAllContext,
};
