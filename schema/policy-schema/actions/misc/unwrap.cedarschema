type UnwrapContext = {
  wrappedAsset: AssetRefWithAmountConstraint,
  nativeAsset: AssetRefWithAmountConstraint,
  recipient: String,
  custom?: UnwrapCustomContext,
};

type UnwrapCustomContext = {};

action "unwrap" appliesTo {
  principal: Wallet,
  resource: Protocol,
  context: UnwrapContext,
};
