type LockIncreaseContext = {
  votingEscrow: String,
  tokenId?: String,
  kind: String,
  additionalAmount?: AmountConstraint,
  newLockDurationSec?: String,
  newUnlockTime?: String,
  recipient?: String,
};

action "lock_increase" appliesTo {
  principal: Wallet,
  resource: Protocol,
  context: LockIncreaseContext,
};
