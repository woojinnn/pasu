type PermitContext = {
  permitKind: String,
  token: AssetRef,
  owner: String,
  spender?: String,
  recipient?: String,
  amount?: AmountConstraint,
  requestedAmount?: AmountConstraint,
  operator?: String,
  approved?: Bool,
  validity: Validity,
  signatureValidity?: Validity,
  custom?: PermitCustomContext,
};

type PermitCustomContext = {};

action "permit" appliesTo {
  principal: Wallet,
  resource: Protocol,
  context: PermitContext,
};
