type SignMessageContext = {
  signer: String,
  requestChainId: Long,
  domainChainId: Long,
  verifyingContract: String,
  primaryType: String,
  nowTs: Long,

  messageDigest: String,
  custom?: SignMessageCustomContext,
};

type SignMessageCustomContext = {};

action "sign_message" appliesTo {
  principal: Wallet,
  resource: Protocol,
  context: SignMessageContext,
};
