type ClaimRewardsContext = {
  sourceAddress: String,
  sourceLabel?: String,

  nft?: AssetRef,

  from: String,
  recipient: String,

  rewards?: Set<AssetRefWithAmountConstraint>,

  totalRewardsUsd?: UsdValuation,
  nftOwnerIsActor?: Bool,
};

action "claim_rewards" appliesTo {
  principal: Wallet,
  resource: Protocol,
  context: ClaimRewardsContext,
};
