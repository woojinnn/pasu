// Governance::Cancel — cancel a governance proposal.

namespace Governance {
  type CancelContext = {
    meta: Core::ActionMeta,
    venue: GovernanceVenue,
    proposalId: String,
    custom?: CancelCustomContext,
  };

  type CancelCustomContext = {};

  action "Cancel" appliesTo {
    principal: Wallet,
    resource: Protocol,
    context: CancelContext,
  };
}
