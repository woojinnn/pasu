// Governance::StartVote — start proposal vote collection.

namespace Governance {
  type StartVoteContext = {
    meta: Core::ActionMeta,
    venue: GovernanceVenue,
    proposalId: String,
    custom?: StartVoteCustomContext,
  };

  type StartVoteCustomContext = {};

  action "StartVote" appliesTo {
    principal: Wallet,
    resource: Protocol,
    context: StartVoteContext,
  };
}
