// Governance::CloseVote — close vote collection and send results.

namespace Governance {
  type CloseVoteContext = {
    meta: Core::ActionMeta,
    venue: GovernanceVenue,
    proposalId: String,
    custom?: CloseVoteCustomContext,
  };

  type CloseVoteCustomContext = {};

  action "CloseVote" appliesTo {
    principal: Wallet,
    resource: Protocol,
    context: CloseVoteContext,
  };
}
