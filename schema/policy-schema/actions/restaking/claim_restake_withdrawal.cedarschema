type ClaimRestakeWithdrawalContext = {
  tokenOut: AssetRef,
  amountOut?: AmountConstraint,

  recipient: String,
  custom?: ClaimRestakeWithdrawalCustomContext,
};

type ClaimRestakeWithdrawalCustomContext = {};

action "claim_restake_withdrawal" appliesTo {
  principal: Wallet,
  resource: Protocol,
  context: ClaimRestakeWithdrawalContext,
};
