type RestakeContext = {
  tokenIn: AssetRef,
  receiptToken?: AssetRef,

  amountIn: AmountConstraint,
  amountOut?: AmountConstraint,

  strategy?: Pool,

  recipient: String,
  custom?: RestakeCustomContext,
};

type RestakeCustomContext = {};

action "restake" appliesTo {
  principal: Wallet,
  resource: Protocol,
  context: RestakeContext,
};
