type RequestRestakeWithdrawalContext = {
  tokenOut?: AssetRef,
  receiptToken?: AssetRef,

  amountIn: AmountConstraint,
  amountOut?: AmountConstraint,

  strategy?: Pool,

  recipient: String,
  custom?: RequestRestakeWithdrawalCustomContext,
};

type RequestRestakeWithdrawalCustomContext = {};

action "request_restake_withdrawal" appliesTo {
  principal: Wallet,
  resource: Protocol,
  context: RequestRestakeWithdrawalContext,
};
