type BurnLiquidityNftContext = {
  nft: AssetRef,
  burnKind: String,
  outputTokens?: Set<AssetRefWithAmountConstraint>,
  recipient?: String,
  validity?: Validity,
  custom?: BurnLiquidityNftCustomContext,
};

type BurnLiquidityNftCustomContext = {};

action "burn_liquidity_nft" appliesTo {
  principal: Wallet,
  resource: Protocol,
  context: BurnLiquidityNftContext,
};
