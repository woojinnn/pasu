type DecreaseLiquidityContext = {
  nft: AssetRef,
  liquidityDelta: AmountConstraint,
  outputTokens: Set<AssetRefWithAmountConstraint>,
  recipient?: String,
  validity?: Validity,

  totalInputUsd?: UsdValuation,
  totalMinOutputUsd?: UsdValuation,
  effectiveRateVsOracleBps?: Long,
  nftOwnerIsActor?: Bool,
  recipientIsContract?: Bool,
  windowStats?: WindowStats,
};

action "decrease_liquidity" appliesTo {
  principal: Wallet,
  resource: Protocol,
  context: DecreaseLiquidityContext,
};
