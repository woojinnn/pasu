type AddLiquidityContext = {
  pool: Pool,
  inputTokens: Set<AssetRefWithAmountConstraint>,
  outputLp: AssetRefWithAmountConstraint,
  recipient: String,
  validity?: Validity,
  custom?: AddLiquidityCustomContext,
};

type AddLiquidityCustomContext = {};

action "add_liquidity" appliesTo {
  principal: Wallet,
  resource: Protocol,
  context: AddLiquidityContext,
};
