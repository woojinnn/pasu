type RemoveLiquidityContext = {
  exitMode: String,
  pool: Pool,
  inputLp: AssetRefWithAmountConstraint,
  outputTokens: Set<AssetRefWithAmountConstraint>,
  recipient: String,
  validity?: Validity,
  custom?: RemoveLiquidityCustomContext,
};

type RemoveLiquidityCustomContext = {};

action "remove_liquidity" appliesTo {
  principal: Wallet,
  resource: Protocol,
  context: RemoveLiquidityContext,
};
