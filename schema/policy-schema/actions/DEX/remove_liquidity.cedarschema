type RemoveLiquidityContext = {
  exitMode: String,
  pool: Pool,
  inputLp: AssetRefWithAmountConstraint,
  outputTokens: Set<AssetRefWithAmountConstraint>,
  recipient: String,
  validity?: Validity,

  totalInputUsd?: UsdValuation,
  totalMinOutputUsd?: UsdValuation,
  effectiveRateVsOracleBps?: Long,
  recipientIsContract?: Bool,
  windowStats?: WindowStats,
};

action "remove_liquidity" appliesTo {
  principal: Wallet,
  resource: Protocol,
  context: RemoveLiquidityContext,
};
