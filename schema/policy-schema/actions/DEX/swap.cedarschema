type SwapContext = {
  swapMode: String,
  inputToken: AssetRefWithAmountConstraint,
  outputToken: AssetRefWithAmountConstraint,
  recipient: String,
  validity?: Validity,
  feeBps?: Long,
  custom?: SwapCustomContext,
};

type SwapCustomContext = {};

action "swap" appliesTo {
  principal: Wallet,
  resource: Protocol,
  context: SwapContext,
};
