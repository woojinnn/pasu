type MintLiquidityNftContext = {
  pool: Pool,
  feeBps: Long,
  tickRange: TickRange,
  inputTokens: Set<AssetRefWithAmountConstraint>,
  recipient: String,
  validity?: Validity,
  custom?: MintLiquidityNftCustomContext,
};

type MintLiquidityNftCustomContext = {};

action "mint_liquidity_nft" appliesTo {
  principal: Wallet,
  resource: Protocol,
  context: MintLiquidityNftContext,
};
