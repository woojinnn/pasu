type DonateContext = {
  pool: Pool,
  inputTokens: Set<AssetRefWithAmountConstraint>,
  from?: String,
  validity?: Validity,
  hooks?: String,
  hookPermissions?: HookPermissions,
  isDynamicFee?: Bool,
  hookDataLen?: Long,
  hookDataSelector?: String,
  custom?: DonateCustomContext,
};

type DonateCustomContext = {};

action "donate" appliesTo {
  principal: Wallet,
  resource: Protocol,
  context: DonateContext,
};
