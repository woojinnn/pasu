type IncreaseLiquidityContext = {
  nft: AssetRef,
  inputTokens: Set<AssetRefWithAmountConstraint>,
  validity?: Validity,
  custom?: IncreaseLiquidityCustomContext,
};

type IncreaseLiquidityCustomContext = {};

action "increase_liquidity" appliesTo {
  principal: Wallet,
  resource: Protocol,
  context: IncreaseLiquidityContext,
};
