type SignAuthorizationContext = {
  market?: Pool,
  authorizer: String,
  authorized: String,
  isAuthorized: Bool,
  authorizationScope: String,
  amount?: AmountConstraint,
  nonce?: String,
  validity: Validity,
  custom?: SignAuthorizationCustomContext,
};

type SignAuthorizationCustomContext = {};

action "sign_authorization" appliesTo {
  principal: Wallet,
  resource: Protocol,
  context: SignAuthorizationContext,
};
