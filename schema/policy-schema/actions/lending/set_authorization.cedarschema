type SetAuthorizationContext = {
  market?: Pool,
  authorizer: String,
  authorized: String,
  isAuthorized: Bool,
  authorizationScope: String,
  amount?: AmountConstraint,
  custom?: SetAuthorizationCustomContext,
};

type SetAuthorizationCustomContext = {};

action "set_authorization" appliesTo {
  principal: Wallet,
  resource: Protocol,
  context: SetAuthorizationContext,
};
