type SupplyContext = {
  market?: Pool,
  asset: AssetRef,
  amount: AmountConstraint,
  amountMode?: String,
  recipient: String,
  from?: String,
  validity?: Validity,

  totalInputUsd?: UsdValuation,
  totalInputFractionOfPortfolioBps?: Long,
  allowancesCoverInputs?: Bool,
  hasUnlimitedAllowance?: Bool,
  recipientIsContract?: Bool,
};

action "supply" appliesTo {
  principal: Wallet,
  resource: Protocol,
  context: SupplyContext,
};
