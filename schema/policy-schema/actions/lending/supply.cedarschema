type SupplyContext = {
  market?: Pool,
  asset: AssetRef,
  amount: AmountConstraint,
  amountMode?: String,
  recipient: String,
  from?: String,
  validity?: Validity,
  custom?: SupplyCustomContext,
};

type SupplyCustomContext = {};

action "supply" appliesTo {
  principal: Wallet,
  resource: Protocol,
  context: SupplyContext,
};
