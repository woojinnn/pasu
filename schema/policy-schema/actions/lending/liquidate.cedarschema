type LiquidateContext = {
  market?: Pool,
  borrower: String,
  collateralAsset?: AssetRef,
  debtAsset: AssetRef,
  debtToCover?: AmountConstraint,
  seizedCollateralAmount?: AmountConstraint,
  liquidationKind: String,
  liquidateMode?: String,
  recipient?: String,
  receiveAToken?: Bool,
  custom?: LiquidateCustomContext,
};

type LiquidateCustomContext = {};

action "liquidate" appliesTo {
  principal: Wallet,
  resource: Protocol,
  context: LiquidateContext,
};
