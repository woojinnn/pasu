type RepayContext = {
  market?: Pool,
  asset: AssetRef,
  amount: AmountConstraint,
  amountMode?: String,
  onBehalf: String,
  repayKind: String,
  validity?: Validity,

  totalRepaidUsd?: UsdValuation,
  allowancesCoverInputs?: Bool,
};

action "repay" appliesTo {
  principal: Wallet,
  resource: Protocol,
  context: RepayContext,
};
