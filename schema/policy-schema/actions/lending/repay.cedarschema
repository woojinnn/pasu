type RepayContext = {
  market?: Pool,
  asset: AssetRef,
  amount: AmountConstraint,
  amountMode?: String,
  onBehalf: String,
  repayKind: String,
  validity?: Validity,
  custom?: RepayCustomContext,
};

type RepayCustomContext = {};

action "repay" appliesTo {
  principal: Wallet,
  resource: Protocol,
  context: RepayContext,
};
