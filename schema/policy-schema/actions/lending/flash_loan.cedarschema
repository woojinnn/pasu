type FlashLoanContext = {
  pool?: Pool,
  assets: Set<AssetRefWithAmountConstraint>,
  receiver: String,
  onBehalf?: String,
  flashLoanKind: String,
  fee?: AmountConstraint,
  custom?: FlashLoanCustomContext,
};

type FlashLoanCustomContext = {};

action "flash_loan" appliesTo {
  principal: Wallet,
  resource: Protocol,
  context: FlashLoanContext,
};
