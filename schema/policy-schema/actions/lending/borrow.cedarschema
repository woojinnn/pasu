type BorrowContext = {
  market?: Pool,
  asset: AssetRef,
  amount: AmountConstraint,
  amountMode?: String,
  recipient: String,
  onBehalf: String,
  collateralAsset?: AssetRef,
  collateralAmount?: AmountConstraint,
  validity?: Validity,
  custom?: BorrowCustomContext,
};

type BorrowCustomContext = {};

action "borrow" appliesTo {
  principal: Wallet,
  resource: Protocol,
  context: BorrowContext,
};
