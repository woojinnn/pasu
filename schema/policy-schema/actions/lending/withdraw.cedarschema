type WithdrawContext = {
  market?: Pool,
  asset: AssetRef,
  amount: AmountConstraint,
  amountMode?: String,
  recipient: String,
  onBehalf?: String,
  custom?: WithdrawCustomContext,
};

type WithdrawCustomContext = {};

action "withdraw" appliesTo {
  principal: Wallet,
  resource: Protocol,
  context: WithdrawContext,
};
