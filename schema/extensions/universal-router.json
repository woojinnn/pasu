{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema_v260510a/extensions/universal-router.json",
  "title": "UniversalRouterExtension",
  "description": "namespace = 'uniswap.universalRouter'. v260509 1:1 port. UR commands 표는 spec 참조 (★ D4 fix: V4 분리는 dispatch 수준).",

  "type": "object",
  "properties": {
    "commands": {
      "$ref": "../_common.json#/$defs/Hex",
      "x-source": "adapter:metadata",
      "description": "raw commands bytes (1 byte per opcode)."
    },
    "commandSequence": {
      "type": "array",
      "items": { "$ref": "#/$defs/UniversalRouterCommand" },
      "x-source": "adapter:metadata"
    },
    "deadline": {
      "$ref": "../_common.json#/$defs/DecimalString",
      "x-source": "adapter:metadata"
    },

    "payPortions": {
      "type": "array",
      "items": { "$ref": "#/$defs/PayPortion" },
      "x-source": "adapter:metadata",
      "description": "PAY_PORTION (opcode 0x06) / PAY_PORTION_FULL_PRECISION (0x07). Frontend fee bips 송금 — recipient 외부 가능. ★ ADR-007 SD-1."
    },
    "sweeps": {
      "type": "array",
      "items": { "$ref": "#/$defs/Sweep" },
      "x-source": "adapter:metadata",
      "description": "SWEEP (opcode 0x04) — 잔여 router token 회수. recipient 외부 가능. ★ ADR-007 SD-2."
    },
    "transfers": {
      "type": "array",
      "items": { "$ref": "#/$defs/Transfer" },
      "x-source": "adapter:metadata",
      "description": "TRANSFER (opcode 0x05) — UR 내부에서 외부 송금. ★ ADR-007 SD-2."
    },
    "balanceChecks": {
      "type": "array",
      "items": { "$ref": "#/$defs/BalanceCheck" },
      "x-source": "adapter:metadata",
      "description": "BALANCE_CHECK_ERC20 (opcode 0x0e) — 잔액 검증. 정책 영향 ✗ 이지만 audit 차원 보존. ★ ADR-007 SD-2."
    },
    "batchTransferFromEntries": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "from": { "$ref": "../_common.json#/$defs/Address" },
          "to": { "$ref": "../_common.json#/$defs/Address" },
          "amount": { "$ref": "../_common.json#/$defs/DecimalString" },
          "token": { "$ref": "../_common.json#/$defs/Address" }
        },
        "required": ["from", "to", "amount", "token"]
      },
      "x-source": "adapter:metadata",
      "description": "PERMIT2_TRANSFER_FROM_BATCH (opcode 0x0d) 의 N entries — classifier 작성 (Phase 4 v3.0) 까지 raw 보존. ★ ADR-009 SD-13."
    }
  },
  "required": ["commands", "commandSequence"],

  "$defs": {
    "UniversalRouterCommand": {
      "type": "object",
      "properties": {
        "inputIndex": { "type": "integer" },
        "rawByte": { "$ref": "../_common.json#/$defs/Hex" },
        "opcode": { "type": "integer", "description": "하위 7 bits (0x7f). 상위 1 bit (0x80) 는 FLAG_ALLOW_REVERT." },
        "name": { "type": "string", "description": "예: 'V3_SWAP_EXACT_IN', 'V4_SWAP'." },
        "allowRevert": { "type": "boolean" },
        "rawInput": { "$ref": "../_common.json#/$defs/Hex" },
        "decodedInput": { "description": "opcode 별 decode 결과 (free-form)." }
      },
      "required": ["inputIndex", "rawByte", "opcode", "name", "allowRevert", "rawInput"]
    },

    "PayPortion": {
      "type": "object",
      "properties": {
        "commandIndex": { "type": "integer", "minimum": 0 },
        "precision": {
          "type": "string",
          "enum": ["bips", "full"],
          "description": "bips = PAY_PORTION (10000 base), full = PAY_PORTION_FULL_PRECISION (1e18 base)."
        },
        "token": { "$ref": "../_common.json#/$defs/Address" },
        "recipient": { "$ref": "../_common.json#/$defs/Address" },
        "recipientResolved": {
          "$ref": "../_common.json#/$defs/Address",
          "description": "sentinel (0x...0001 / 0x...0002) resolved 후 final 주소. aggregator 가 채움."
        },
        "recipientEqualsActor": {
          "type": ["boolean", "null"],
          "description": "recipient (resolve 후) == actor. aggregator 의 has_external_recipient 도출에 사용 (★ ADR-007 SD-1)."
        },
        "bips": { "type": "integer", "minimum": 0 }
      },
      "required": ["commandIndex", "precision", "token", "recipient", "bips"]
    },

    "Sweep": {
      "type": "object",
      "properties": {
        "commandIndex": { "type": "integer", "minimum": 0 },
        "token": { "$ref": "../_common.json#/$defs/Address" },
        "recipient": { "$ref": "../_common.json#/$defs/Address" },
        "recipientResolved": { "$ref": "../_common.json#/$defs/Address" },
        "recipientEqualsActor": { "type": ["boolean", "null"] },
        "amountMin": { "$ref": "../_common.json#/$defs/DecimalString" }
      },
      "required": ["commandIndex", "token", "recipient", "amountMin"]
    },

    "Transfer": {
      "type": "object",
      "properties": {
        "commandIndex": { "type": "integer", "minimum": 0 },
        "token": { "$ref": "../_common.json#/$defs/Address" },
        "recipient": { "$ref": "../_common.json#/$defs/Address" },
        "recipientResolved": { "$ref": "../_common.json#/$defs/Address" },
        "recipientEqualsActor": { "type": ["boolean", "null"] },
        "amount": { "$ref": "../_common.json#/$defs/DecimalString" }
      },
      "required": ["commandIndex", "token", "recipient", "amount"]
    },

    "BalanceCheck": {
      "type": "object",
      "properties": {
        "commandIndex": { "type": "integer", "minimum": 0 },
        "token": { "$ref": "../_common.json#/$defs/Address" },
        "owner": { "$ref": "../_common.json#/$defs/Address" },
        "minBalance": { "$ref": "../_common.json#/$defs/DecimalString" }
      },
      "required": ["commandIndex", "token", "owner", "minBalance"]
    }
  }
}
