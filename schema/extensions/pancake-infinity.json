{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema_v260510a/extensions/pancake-infinity.json",
  "title": "PancakeInfinityExtension",
  "description": "namespace = 'pancakeswap.infinity'. v260509 1:1 port. CL/Bin pool. bit layout 미공개 부분은 raw 보존.",

  "type": "object",
  "properties": {
    "poolType": {
      "type": "string",
      "enum": ["cl", "bin", "unknown"],
      "x-source": "adapter:metadata"
    },
    "poolKey": {
      "type": "object",
      "properties": {
        "currency0": { "$ref": "../_common.json#/$defs/Address" },
        "currency1": { "$ref": "../_common.json#/$defs/Address" },
        "fee": { "type": "integer" },
        "parameters": {
          "$ref": "../_common.json#/$defs/Hex",
          "description": "bytes32 packed — CL: tickSpacing + hook bitmap; Bin: binStep + hook bitmap. ★ Uniswap V4 의 tickSpacing(int24) 자리 일반화."
        },
        "hooks": { "$ref": "../_common.json#/$defs/Address" },
        "poolManager": {
          "$ref": "../_common.json#/$defs/Address",
          "description": "어느 PM (CL or Bin) 인지 식별. ★ Uniswap V4 PoolKey 와 다른 점."
        }
      },
      "x-source": "adapter:metadata"
    },
    "hookData": { "$ref": "../_common.json#/$defs/Hex", "x-source": "adapter:metadata" },

    "swapParams": {
      "type": "object",
      "properties": {
        "zeroForOne": { "type": "boolean" },
        "amountSpecified": { "$ref": "../_common.json#/$defs/IntDecimalString" },
        "sqrtPriceLimitX96": { "$ref": "../_common.json#/$defs/DecimalString" },
        "swapForY": { "type": "boolean", "description": "Bin pool 의 swap 방향 (zeroForOne 와 동등)." }
      },
      "x-source": "adapter:metadata",
      "description": "CL = (zeroForOne, amountSpecified, sqrtPriceLimitX96). Bin = (swapForY, amountSpecified)."
    },

    "modifyLiquidityParams": {
      "type": "object",
      "properties": {
        "tickLower": { "type": "integer" },
        "tickUpper": { "type": "integer" },
        "liquidityDelta": { "$ref": "../_common.json#/$defs/IntDecimalString" },
        "salt": { "$ref": "../_common.json#/$defs/Hex" }
      },
      "x-source": "adapter:metadata",
      "description": "CL PoolManager.modifyLiquidity params."
    },

    "binParams": {
      "type": "object",
      "properties": {
        "activeId": { "type": "integer" },
        "ids": { "type": "array", "items": { "$ref": "../_common.json#/$defs/DecimalString" } },
        "amountsToBurn": { "type": "array", "items": { "$ref": "../_common.json#/$defs/DecimalString" } },
        "liquidityConfigs": { "type": "array", "items": { "$ref": "../_common.json#/$defs/Hex" } },
        "amountIn": { "$ref": "../_common.json#/$defs/Hex" },
        "salt": { "$ref": "../_common.json#/$defs/Hex" }
      },
      "x-source": "adapter:metadata",
      "description": "Bin PoolManager 의 mint/burn/initialize params."
    }
  },
  "required": ["poolType"]
}
