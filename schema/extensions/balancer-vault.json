{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema_v260510a/extensions/balancer-vault.json",
  "title": "BalancerVaultExtension",
  "description": "namespace = 'balancer.vault'. v260509 1:1 port. bigint → DecimalString.",

  "type": "object",
  "properties": {
    "operation": {
      "type": "string",
      "enum": ["swap", "batchSwap", "joinPool", "exitPool", "manageUserBalance"],
      "x-source": "adapter:metadata"
    },
    "poolId": { "$ref": "../_common.json#/$defs/Hex", "x-source": "adapter:metadata" },
    "poolIds": {
      "type": "array",
      "items": { "$ref": "../_common.json#/$defs/Hex" },
      "x-source": "adapter:metadata"
    },
    "swapKind": {
      "type": "string",
      "enum": ["GIVEN_IN", "GIVEN_OUT"],
      "x-source": "adapter:metadata"
    },
    "assets": {
      "type": "array",
      "items": { "$ref": "../_common.json#/$defs/Address" },
      "x-source": "adapter:metadata",
      "description": "swap 의 asset list. 0x0 sentinel = native ETH (Vault 컨벤션)."
    },
    "limits": {
      "type": "array",
      "items": { "$ref": "../_common.json#/$defs/IntDecimalString" },
      "x-source": "adapter:metadata",
      "description": "batchSwap 의 limits (양/음수)."
    },
    "funds": {
      "type": "object",
      "properties": {
        "sender": { "$ref": "../_common.json#/$defs/Address" },
        "fromInternalBalance": { "type": "boolean" },
        "recipient": { "$ref": "../_common.json#/$defs/Address" },
        "toInternalBalance": { "type": "boolean" }
      },
      "required": ["sender", "fromInternalBalance", "recipient", "toInternalBalance"],
      "x-source": "adapter:metadata"
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "poolId": { "$ref": "../_common.json#/$defs/Hex" },
          "assetInIndex": { "type": "integer" },
          "assetOutIndex": { "type": "integer" },
          "amount": { "$ref": "../_common.json#/$defs/DecimalString" },
          "userData": { "$ref": "../_common.json#/$defs/Hex" }
        },
        "required": ["poolId", "assetInIndex", "assetOutIndex", "amount", "userData"]
      },
      "x-source": "adapter:metadata"
    },
    "maxAmountsIn": {
      "type": "array",
      "items": { "$ref": "../_common.json#/$defs/DecimalString" },
      "x-source": "adapter:metadata"
    },
    "minAmountsOut": {
      "type": "array",
      "items": { "$ref": "../_common.json#/$defs/DecimalString" },
      "x-source": "adapter:metadata"
    },
    "userData": { "$ref": "../_common.json#/$defs/Hex", "x-source": "adapter:metadata" },

    "fundManagement": {
      "type": "object",
      "properties": {
        "fromInternalBalance": { "type": "boolean" },
        "toInternalBalance": { "type": "boolean" }
      },
      "x-source": "adapter:metadata",
      "description": "Balancer Vault swap/batchSwap 의 FundManagement flags + joinPool/exitPool 의 internal balance 사용 여부. ★ ADR-009 SD-11."
    },

    "poolIdParts": {
      "type": "object",
      "properties": {
        "address": { "$ref": "../_common.json#/$defs/Address" },
        "specialization": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2,
          "description": "0=GeneralPool / 1=MinimalSwapInfoPool / 2=TwoTokenPool."
        },
        "nonce": { "type": "integer", "minimum": 0 }
      },
      "x-source": "adapter:metadata",
      "description": "poolId (bytes32) = address(20B) + specialization(2B) + nonce(10B) 분해. ★ ADR-009 SD-12."
    }
  },
  "required": ["operation"]
}
