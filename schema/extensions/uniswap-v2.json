{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema_v260510a/extensions/uniswap-v2.json",
  "title": "UniswapV2Extension",
  "description": "namespace = 'uniswap.v2'. v260509 1:1 port.",

  "type": "object",
  "properties": {
    "path": {
      "type": "array",
      "items": { "$ref": "../_common.json#/$defs/Address" },
      "x-source": "adapter:metadata",
      "description": "address[] path 그대로."
    },
    "supportingFeeOnTransfer": {
      "type": "boolean",
      "x-source": "adapter:metadata",
      "description": "SupportingFeeOnTransferTokens 계열 사용 여부."
    },

    "permit": {
      "type": "object",
      "properties": {
        "approveMax": {
          "type": "boolean",
          "description": "true 면 max approval (uint256.max), false 면 정확히 liquidity 양만 approve."
        },
        "v": { "type": "integer", "minimum": 0, "maximum": 255 },
        "r": { "$ref": "../_common.json#/$defs/Hex" },
        "s": { "$ref": "../_common.json#/$defs/Hex" },
        "deadline": { "$ref": "../_common.json#/$defs/DecimalString" }
      },
      "required": ["approveMax", "v", "r", "s"],
      "x-source": "adapter:metadata",
      "description": "removeLiquidityWithPermit / removeLiquidityETHWithPermit / FOT 변형 의 EIP-2612 permit signature. ★ ADR-007 SD-3."
    }
  },
  "required": ["path"]
}
