{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema_v260510a/extensions/uniswap-v3.json",
  "title": "UniswapV3Extension",
  "description": "namespace = 'uniswap.v3'. v260509 1:1 port. bigint → DecimalString (ADR-005).",

  "type": "object",
  "properties": {
    "encodedPath": {
      "$ref": "../_common.json#/$defs/Hex",
      "x-source": "adapter:metadata",
      "description": "exactInput / exactOutput 의 raw bytes path."
    },
    "decodedPath": {
      "type": "array",
      "items": { "$ref": "#/$defs/UniswapV3PathHop" },
      "x-source": "adapter:metadata"
    },
    "feeTier": {
      "type": "integer",
      "x-source": "adapter:metadata",
      "description": "exactInputSingle 등 single 함수의 fee tier."
    },
    "sqrtPriceLimitX96": {
      "$ref": "../_common.json#/$defs/DecimalString",
      "x-source": "adapter:metadata",
      "description": "uint160 sqrt price limit (decimal string)."
    },

    "unwrapFee": {
      "type": "object",
      "properties": {
        "bips": { "type": "integer", "minimum": 0, "maximum": 10000 },
        "recipient": { "$ref": "../_common.json#/$defs/Address" }
      },
      "required": ["bips", "recipient"],
      "x-source": "adapter:metadata",
      "description": "V3 unwrapWETH9WithFee (selector 0x9b2c0a37) 의 frontend fee — bips 비율로 unwrap 결과의 일부를 recipient 에 송금. ★ ADR-007 SD-5."
    }
  },

  "$defs": {
    "UniswapV3PathHop": {
      "type": "object",
      "properties": {
        "tokenIn": { "$ref": "../_common.json#/$defs/Address" },
        "tokenOut": { "$ref": "../_common.json#/$defs/Address" },
        "fee": {
          "type": "integer",
          "description": "500 / 3000 / 10000 등."
        }
      },
      "required": ["tokenIn", "tokenOut", "fee"]
    }
  }
}
