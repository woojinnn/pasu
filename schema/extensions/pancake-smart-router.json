{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema_v260510a/extensions/pancake-smart-router.json",
  "title": "PancakeSmartRouterExtension",
  "description": "namespace = 'pancakeswap.smartRouter'. v260509 1:1 port.",

  "type": "object",
  "properties": {
    "family": {
      "type": "string",
      "enum": ["v2", "v3", "stable", "mixed", "unknown"],
      "x-source": "adapter:metadata"
    },
    "v2Path": {
      "type": "array",
      "items": { "$ref": "../_common.json#/$defs/Address" },
      "x-source": "adapter:metadata"
    },
    "v3EncodedPath": {
      "$ref": "../_common.json#/$defs/Hex",
      "x-source": "adapter:metadata"
    },
    "v3DecodedPath": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "tokenIn": { "$ref": "../_common.json#/$defs/Address" },
          "tokenOut": { "$ref": "../_common.json#/$defs/Address" },
          "fee": { "type": "integer" }
        },
        "required": ["tokenIn", "tokenOut", "fee"]
      },
      "x-source": "adapter:metadata"
    }
  },
  "required": ["family"]
}
