{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema_v260510a/extension.json",
  "title": "Extension",
  "description": "protocol-specific raw 정보 보존 wrapper. NormalizedRequest.extensions[]. Per docs/05-schema-spec.md §8.",

  "type": "object",
  "properties": {
    "id": { "type": "string" },
    "scope": {
      "type": "object",
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "kind": { "type": "string", "const": "target" },
            "targetId": { "type": "string" }
          },
          "required": ["kind", "targetId"]
        },
        {
          "type": "object",
          "properties": {
            "kind": { "type": "string", "const": "call" },
            "callId": { "type": "string" }
          },
          "required": ["kind", "callId"]
        },
        {
          "type": "object",
          "properties": {
            "kind": { "type": "string", "const": "action" },
            "actionId": { "type": "string" }
          },
          "required": ["kind", "actionId"]
        }
      ],
      "discriminator": { "propertyName": "kind" }
    },
    "namespace": {
      "type": "string",
      "enum": [
        "uniswap.v2", "uniswap.v3", "uniswap.universalRouter", "uniswap.v4",
        "pancakeswap.smartRouter", "pancakeswap.stableSwap",
        "pancakeswap.universalRouter", "pancakeswap.infinity",
        "balancer.vault"
      ],
      "description": "★ B3 fix: dot notation. v2.1.0 DEX 한정 9 namespace. (DEX 외 23 namespace 는 v2.x 후속 시즌.)"
    },
    "version": { "type": "string" },
    "data": {
      "description": "namespace 별 schema 가 conditional 로 검증 (extensions/*.json 의 anyOf 또는 별도 dispatcher).",
      "type": "object"
    },
    "confidence": { "$ref": "_common.json#/$defs/ConfidenceLevel" }
  },
  "required": ["id", "scope", "namespace", "data", "confidence"]
}
