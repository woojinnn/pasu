    },
    "amount": {
      "$ref": "../_common.json#/$defs/AmountConstraint",
      "x-source": "action-derived",
      "description": "AmountConstraint.kind='unlimited' 가 max(uint256) 의미를 cover."
    },
    "approvalKind": {
      "type": "string",
      "enum": ["erc20", "erc20_increase", "erc20_decrease", "erc721", "erc1155", "permit2", "unknown"],
