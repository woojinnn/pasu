{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema_v260510a/action-fields/liquidity.json",
  "title": "LiquidityActionFields",
  "description": "8 liquidity ActionType 의 fields (add/remove/mint_position/increase/decrease/burn/join_pool/exit_pool). Per docs/05-schema-spec.md §5. ★ B2 fix: 4 추가 ActionType.",

  "type": "object",
  "properties": {
    "_kind": {
      "type": "string",
      "enum": [
        "add_liquidity", "remove_liquidity",
        "mint_position", "increase_liquidity", "decrease_liquidity", "burn_position",
        "join_pool", "exit_pool"
      ],
      "description": "discriminator. action.type 와 1:1 (★ §5 부록 invariant)."
    },

    "operation": {
      "type": "string",
      "enum": ["add", "remove", "join_pool", "exit_pool", "increase", "decrease", "mint_position", "burn_position"],
      "x-source": "action-derived",
      "description": "★ §5 부록의 _kind ↔ operation 1:1 표를 따른다."
    },

    "protocolId": {
      "type": "string",
      "enum": ["uniswap.v2", "uniswap.v3", "uniswap.v4", "pancakeswap.v2", "pancakeswap.v3", "pancakeswap.smartRouter", "pancakeswap.infinity", "balancer.v2", "unknown"],
      "x-source": "action-derived",
      "description": "★ B3 fix: dot notation 통일."
    },

    "pool": {
      "$ref": "../_common.json#/$defs/Address",
      "x-source": "adapter:metadata",
      "description": "V2 pair / V3 pool / V4 PoolKey-derived 단일 풀 주소 (있으면)."
    },
    "poolId": {
      "$ref": "../_common.json#/$defs/Hex",
      "x-source": "adapter:metadata",
      "description": "Balancer poolId / V4 PoolId (bytes32)."
    },

    "tokens": {
      "type": "array",
      "items": { "$ref": "../_common.json#/$defs/AssetRef" },
      "x-source": "action-derived",
      "description": "V2/V3/V4 길이 2, Balancer 길이 N. V3/V4 NPM increase/decrease 의 경우 빈 배열 (host:onchain 보강 필요)."
    },
    "amounts": {
      "type": "array",
      "items": { "$ref": "../_common.json#/$defs/AmountConstraint" },
      "x-source": "action-derived",
      "description": "tokens[i] 와 1:1. operation 별 의미는 docs/05 §5 부록의 amounts[] 의미 표 참조."
    },

    "positionTokenId": {
      "$ref": "../_common.json#/$defs/DecimalString",
      "x-source": "action-derived",
      "x-version": ["V3", "V4"],
      "description": "ERC721 position NFT id."
    },

    "feeTier": {
      "type": "integer",
      "x-source": "action-derived",
      "x-version": ["V3", "V4"]
    },
    "tickLower": {
      "type": "integer",
      "x-source": "action-derived",
      "x-version": ["V3", "V4"]
    },
    "tickUpper": {
      "type": "integer",
      "x-source": "action-derived",
      "x-version": ["V3", "V4"]
    },

    "liquidityDelta": {
      "$ref": "../_common.json#/$defs/IntDecimalString",
      "x-source": "action-derived",
      "x-version": ["V3", "V4"],
      "description": "V4 modifyLiquidity raw liquidityDelta — 음수=remove. V3 NPM 의 liquidity (uint128) 도 본 필드 (양수)."
    },

    "userData": {
      "$ref": "../_common.json#/$defs/Hex",
      "x-source": "adapter:metadata",
      "x-version": ["balancer.v2"],
      "description": "Balancer joinPool/exitPool 의 raw userData (JoinKind/ExitKind 식별 bytes)."
    },

    "recipient": { "$ref": "../_common.json#/$defs/Address", "x-source": "action-derived" },
    "sender": { "$ref": "../_common.json#/$defs/Address", "x-source": "action-derived" },
    "deadline": { "$ref": "../_common.json#/$defs/DecimalString", "x-source": "action-derived" },
    "recipientEqualsActor": {
      "type": "boolean",
      "x-source": "action-derived"
    },
    "deadlineHorizonSeconds": {
      "type": "integer",
      "x-source": "action-derived"
    },

    "valueWei": {
      "$ref": "../_common.json#/$defs/DecimalString",
      "x-source": "action-derived",
      "description": "envelope.value 의 copy. V3/V4 NPM mint/increaseLiquidity 같은 payable 함수에서 ETH 입력 측 input. SwapActionFields.valueWei 와 일관 (★ ADR-007 SD-4)."
    },

    "slippage": {
      "type": "object",
      "properties": {
        "minLiquidity": { "$ref": "../_common.json#/$defs/DecimalString" },
        "maxAmountIn": {
          "type": "array",
          "items": { "$ref": "../_common.json#/$defs/AmountConstraint" }
        },
        "minAmountOut": {
          "type": "array",
          "items": { "$ref": "../_common.json#/$defs/AmountConstraint" }
        },
        "source": {
          "type": "string",
          "enum": ["calldata", "quote", "derived", "unknown"]
        }
      },
      "x-source": "adapter:metadata"
    },

    "settlement": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["router", "manager", "vault", "direct_pool", "unknown"]
        }
      },
      "x-source": "adapter:metadata"
    },

    "totalInputUsd": {
      "$ref": "../_common.json#/$defs/UsdValuation",
      "x-source": "host:oracle"
    }
  },

  "required": ["_kind", "operation", "protocolId", "tokens"]
}
