{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema_v260510a/action-fields/permit.json",
  "title": "PermitActionFields",
  "description": "EIP-2612 / Permit2 / ERC721Permit. v260509 1:1 port + x-source. typed-data 본문은 raw 에 보존, 본 fields 는 wallet UI 표시용 핵심만. (★ G4 — v2.1.0 aggregator 매핑 미적용, informational only)",

  "type": "object",
  "properties": {
    "_kind": {
      "type": "string",
      "const": "permit"
    },
    "token": {
      "$ref": "../_common.json#/$defs/AssetRef",
      "x-source": "action-derived"
    },
    "owner": {
      "$ref": "../_common.json#/$defs/Address",
      "x-source": "action-derived"
    },
    "spender": {
      "$ref": "../_common.json#/$defs/Address",
      "x-source": "action-derived"
    },
    "value": {
      "$ref": "../_common.json#/$defs/DecimalString",
      "x-source": "action-derived",
      "description": "허용 수량 (decimal string). unlimited 케이스는 AmountConstraint.kind='unlimited' 로 표기 권장."
    },
    "deadline": {
      "$ref": "../_common.json#/$defs/DecimalString",
      "x-source": "action-derived",
      "description": "EIP-2612 deadline 또는 Permit2 expiration."
    },
    "signature": {
      "x-source": "action-derived",
      "description": "EIP-2612: { v, r, s }. Permit2: { kind: 'permit2' }, raw 본문은 typedData 에.",
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "v": { "type": "integer" },
            "r": { "$ref": "../_common.json#/$defs/Hex" },
            "s": { "$ref": "../_common.json#/$defs/Hex" }
          },
          "required": ["v", "r", "s"]
        },
        {
          "type": "object",
          "properties": {
            "kind": { "type": "string", "const": "permit2" }
          },
          "required": ["kind"]
        }
      ]
    },
    "permitDetails": {
      "type": "object",
      "properties": {
        "expiration": {
          "$ref": "../_common.json#/$defs/DecimalString",
          "description": "Permit2 PermitDetails.expiration (uint48) — approval 만료 시각."
        },
        "nonce": {
          "$ref": "../_common.json#/$defs/DecimalString",
          "description": "Permit2 PermitDetails.nonce (uint48) — anti-replay."
        }
      },
      "x-source": "action-derived",
      "description": "Permit2 한정 — PermitDetails 의 expiration + nonce. ★ ADR-009 SD-8."
    }
  },
  "required": ["_kind", "token", "owner", "spender"]
}
