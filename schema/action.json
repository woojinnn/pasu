{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema_v260510a/action.json",
  "title": "NormalizedAction",
  "description": "1 tx → N actions[] 의 leaf. fields 는 discriminated union (_kind). Per docs/05-schema-spec.md §3.",

  "type": "object",
  "properties": {
    "id": { "type": "string", "description": "내부 식별자 (예: 'a#0')." },
    "category": { "$ref": "#/$defs/ActionCategory" },
    "type": { "$ref": "#/$defs/ActionType" },
    "parentActionId": { "type": "string" },
    "childActionIds": { "type": "array", "items": { "type": "string" } },
    "primaryTargetId": { "type": "string" },
    "relatedTargetIds": { "type": "array", "items": { "type": "string" } },
    "derivedFromCallIds": {
      "type": "array",
      "items": { "type": "string" },
      "description": "본 action 이 어느 DecodedCall(s) 에서 도출되었는지 — UR opcode/multicall 추적용."
    },
    "protocol": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" },
        "component": { "type": "string" }
      },
      "description": "Optional 인포 — ★ canonical protocolId 는 fields.protocolId. 본 필드는 raw protocol metadata."
    },
    "fields": { "$ref": "#/$defs/ActionFields" },
    "extensionIds": { "type": "array", "items": { "type": "string" } },
    "confidence": { "$ref": "_common.json#/$defs/ConfidenceLevel" }
  },
  "required": ["id", "category", "type", "derivedFromCallIds", "confidence"],

  "$defs": {
    "ActionCategory": {
      "type": "string",
      "enum": [
        "swap", "liquidity",
        "lending", "liquid_staking", "restaking", "rwa",
        "bridge", "perp",
        "utility", "aggregation", "unknown"
      ]
    },

    "ActionType": {
      "type": "string",
      "enum": [
        "router_plan",
        "swap", "wrap", "unwrap", "approval", "permit", "transfer",
        "add_liquidity", "remove_liquidity",
        "mint_position", "increase_liquidity", "decrease_liquidity", "burn_position",
        "join_pool", "exit_pool",
        "batch_swap", "hooked_operation",
        "unknown",

        "supply", "borrow", "repay", "withdraw_collateral", "set_collateral", "liquidation_repay", "flash_loan",

        "stake", "unstake_request", "claim_unstake", "wrap_receipt", "unwrap_receipt",

        "restake", "delegate_operator", "undelegate", "queue_withdrawal", "claim_withdrawal",
        "mint_lrt", "request_lrt_redemption", "claim_lrt_redemption",

        "subscribe", "request_redemption", "claim_subscription", "claim_redemption",
        "cancel_request", "claim_cancel", "transfer_restricted", "claim_yield",

        "claim_rewards"
      ],
      "description": "★ B2 fix: mint_position/increase_liquidity/decrease_liquidity/burn_position 4종 추가 (V3 NPM/V4 PositionManager 호환)."
    },

    "ActionFields": {
      "type": "object",
      "oneOf": [
        { "$ref": "action-fields/swap.json" },
        { "$ref": "action-fields/liquidity.json" },
        { "$ref": "action-fields/wrap.json" },
        { "$ref": "action-fields/approval.json" },
        { "$ref": "action-fields/permit.json" },
        { "$ref": "action-fields/transfer.json" },
        { "$ref": "action-fields/router-plan.json" }
      ],
      "discriminator": { "propertyName": "_kind" },
      "description": "_kind discriminator + AJV `discriminator: true`. _kind 는 항상 NormalizedAction.type 와 동일 (도구 검증 invariant)."
    }
  }
}
