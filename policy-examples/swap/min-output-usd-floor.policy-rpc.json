{
  "id": "default::swap/min-output-usd-floor",
  "schema_version": 1,
  "requires": [
    {
      "id": "swap-min-output-usd",
      "when": { "action": "swap" },
      "method": "oracle.usd_value",
      "params": {
        "chain_id": "$.root.chain_id",
        "asset": "$.action.outputToken.asset",
        "amount": "$.action.outputToken.amount.value"
      },
      "outputs": [
        {
          "kind": "context",
          "field": "totalMinOutputUsd",
          "type": "UsdValuation",
          "from": "$.result",
          "required": true
        }
      ],
      "optional": true
    }
  ],
  "context_extensions": {
    "swap": {
      "totalMinOutputUsd": "UsdValuation"
    }
  }
}
