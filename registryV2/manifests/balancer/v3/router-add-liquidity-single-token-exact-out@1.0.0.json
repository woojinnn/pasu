{
  "type": "adapter_action",
  "id": "balancer/v3/router-add-liquidity-single-token-exact-out@1.0.0",
  "publisher": "balancer.eth",
  "schema_version": "3",
  "_note": "Balancer V3 Router.addLiquiditySingleTokenExactOut(address pool, address tokenIn, uint256 maxAmountIn, uint256 exactBptAmountOut, bool wethIsEth, bytes userData) — selector 0x72657d17. Source: balancer/balancer-deployments v3/tasks/20250307-v3-router-v2 Router artifact. Maps to Amm::AddLiquidity::Pooled. Single-token add: tokenIn + maxAmountIn are both in calldata (no pool-token resolver needed, unlike the proportional/unbalanced variants which are deferred). min_lp_out = exactBptAmountOut (exact BPT the user receives). pool address is $args.pool directly. Mainnet only.",
  "match": {
    "selector": "0x72657d17",
    "chain_to_addresses": {
      "1": ["0xAE563E3f8219521950555F5962419C8919758Ea2"]
    }
  },
  "abi_fragment": {
    "function_name": "addLiquiditySingleTokenExactOut",
    "abi": {
      "name": "addLiquiditySingleTokenExactOut",
      "type": "function",
      "stateMutability": "payable",
      "inputs": [
        { "name": "pool",              "type": "address" },
        { "name": "tokenIn",           "type": "address" },
        { "name": "maxAmountIn",       "type": "uint256" },
        { "name": "exactBptAmountOut", "type": "uint256" },
        { "name": "wethIsEth",         "type": "bool"    },
        { "name": "userData",          "type": "bytes"   }
      ],
      "outputs": [ { "name": "amountIn", "type": "uint256" } ]
    }
  },
  "emit": {
    "strategy": "single_emit",
    "body": {
      "domain": "amm",
      "amm": {
        "action": "add_liquidity",
        "add_liquidity": {
          "venue": {
            "name":      "balancer_v3",
            "chain":     "$chain",
            "pool_id":   "$args.pool",
            "pool_type": "weighted"
          },
          "params": {
            "kind": "pooled",
            "tokens": [
              [
                { "key": { "standard": "erc20", "chain": "$chain", "address": "$args.tokenIn" } },
                "$args.maxAmountIn"
              ]
            ],
            "min_lp_out": "$args.exactBptAmountOut",
            "recipient": "$tx.from"
          },
          "live_inputs": {
            "pool_state": {
              "source": {
                "kind":       "onchain_view",
                "chain":      "$chain",
                "contract":   "$args.pool",
                "function":   "getCurrentLiveBalances()",
                "decoder_id": "balancer_v3_pool_balances"
              },
              "ttl_s": 12
            },
            "current_price": {
              "source": {
                "kind":    "derived_from",
                "inputs":  [],
                "calc_id": "balancer_v3_pool_price"
              },
              "ttl_s": 12
            }
          }
        }
      }
    }
  },
  "requires": {
    "imperative": [],
    "adapter_capabilities": ["token_metadata"],
    "host_capabilities": [],
    "extension": ">=0.1.0"
  }
}
