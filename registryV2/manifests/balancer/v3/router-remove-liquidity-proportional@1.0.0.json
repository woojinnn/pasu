{
  "type": "adapter_action",
  "id": "balancer/v3/router-remove-liquidity-proportional@1.0.0",
  "publisher": "balancer.eth",
  "schema_version": "3",
  "_note": "Balancer V3 Router.removeLiquidityProportional(address pool, uint256 exactBptAmountIn, uint256[] minAmountsOut, bool wethIsEth, bytes userData) — selector 0x51682750. Source: balancer/balancer-deployments v3/tasks/20250307-v3-router-v2 Router artifact. ≈47% of permitBatchAndCall children (1st-party Etherscan 2026-06). minAmountsOut[i] is indexed by the pool's registered token list, NOT in calldata — resolved via the baked balancer_v3:pool_tokens map ($source.pool_tokens) + balancer_v3_zip_pool_tokens $fn. V3 BPT == pool contract, so lp_token = $args.pool. lp_amount = exactBptAmountIn. recipient = tx.from. Mainnet only; resolved as a permitBatchAndCall child too via multicall_recurse.",
  "match": {
    "selector": "0x51682750",
    "chain_to_addresses_source": "balancer_v3:pool_tokens",
    "chain_ids": [1]
  },
  "abi_fragment": {
    "function_name": "removeLiquidityProportional",
    "abi": {
      "name": "removeLiquidityProportional",
      "type": "function",
      "stateMutability": "payable",
      "inputs": [
        { "name": "pool",             "type": "address"   },
        { "name": "exactBptAmountIn", "type": "uint256"   },
        { "name": "minAmountsOut",    "type": "uint256[]" },
        { "name": "wethIsEth",        "type": "bool"      },
        { "name": "userData",         "type": "bytes"     }
      ],
      "outputs": [ { "name": "amountsOut", "type": "uint256[]" } ]
    }
  },
  "emit": {
    "strategy": "single_emit",
    "body": {
      "domain": "amm",
      "amm": {
        "action": "remove_liquidity",
        "remove_liquidity": {
          "venue": {
            "name":      "balancer_v3",
            "chain":     "$chain",
            "pool_id":   "$args.pool",
            "pool_type": "weighted"
          },
          "params": {
            "kind": "pooled_burn",
            "lp_token": {
              "key": { "standard": "erc20", "chain": "$chain", "address": "$args.pool" }
            },
            "lp_amount": "$args.exactBptAmountIn",
            "min_out": {
              "$fn": "balancer_v3_zip_pool_tokens",
              "$args": [ "$chain", "$args.pool", "$args.minAmountsOut", "$source.pool_tokens" ]
            },
            "recipient": "$tx.from"
          },
          "live_inputs": {
            "pool_state": {
              "source": {
                "kind":       "onchain_view",
                "chain":      "$chain",
                "contract":   "$args.pool",
                "function":   "getCurrentLiveBalances()",
                "decoder_id": "balancer_v3_pool_balances"
              },
              "ttl_s": 12
            },
            "fees_owed": {
              "source": {
                "kind":    "derived_from",
                "inputs":  [],
                "calc_id": "balancer_v3_fees_owed"
              },
              "ttl_s": 12
            }
          }
        }
      }
    }
  },
  "requires": {
    "imperative": [],
    "adapter_capabilities": ["token_metadata"],
    "host_capabilities": [],
    "extension": ">=0.1.0"
  },
  "source_materialize": {
    "kind": "per_address_context",
    "source": "balancer_v3:pool_tokens",
    "note": "build-index materializes the single mainnet V3 Router bundle and inlines $source.pool_tokens (the baked pool->tokens map from surface/balancer/_pool_universe.json)"
  }
}
