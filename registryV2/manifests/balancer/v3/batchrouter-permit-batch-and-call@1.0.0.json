{
  "type": "adapter_action",
  "id": "balancer/v3/batchrouter-permit-batch-and-call@1.0.0",
  "publisher": "balancer.eth",
  "schema_version": "3",
  "_note": "Balancer V3 BatchRouter.permitBatchAndCall(PermitApproval[] permitBatch, bytes[] permitSignatures, IAllowanceTransfer.PermitBatch permit2Batch, bytes permit2Signature, bytes[] multicallData) — selector 0x19c6989f, contract 0x136f1EFcC3f8f88516B9E94110D56FDBfB1778d1. Source: balancer/balancer-deployments v3 20241205-v3-batch-router. THE dominant BatchRouter entry (~68% of recent direct BatchRouter tx, 1st-party Etherscan 2026-06). Same wrapper as the V3 Router pbc but on the BatchRouter: bundles Permit2 approvals with a multicall of BatchRouter self-calls (chiefly swapExactIn). Decoded via multicall_recurse over the LAST bytes[] arg (multicallData) — each child re-enters the route against the BatchRouter, so bundled swapExactIn keeps its concrete Amm::Swap shape. LIMITATION: the bundled permit2Batch grant is not separately surfaced (same as the Router pbc). Mainnet only.",
  "match": {
    "selector": "0x19c6989f",
    "chain_to_addresses": {
      "1": ["0x136f1EFcC3f8f88516B9E94110D56FDBfB1778d1"]
    }
  },
  "abi_fragment": {
    "function_name": "permitBatchAndCall",
    "abi": {
      "name": "permitBatchAndCall",
      "type": "function",
      "stateMutability": "payable",
      "inputs": [
        {
          "name": "permitBatch",
          "type": "tuple[]",
          "components": [
            { "name": "token",    "type": "address" },
            { "name": "owner",    "type": "address" },
            { "name": "spender",  "type": "address" },
            { "name": "amount",   "type": "uint256" },
            { "name": "deadline", "type": "uint256" },
            { "name": "nonce",    "type": "uint256" }
          ]
        },
        { "name": "permitSignatures", "type": "bytes[]" },
        {
          "name": "permit2Batch",
          "type": "tuple",
          "components": [
            {
              "name": "details",
              "type": "tuple[]",
              "components": [
                { "name": "token",      "type": "address" },
                { "name": "amount",     "type": "uint160" },
                { "name": "expiration", "type": "uint48"  },
                { "name": "nonce",      "type": "uint48"  }
              ]
            },
            { "name": "spender",  "type": "address" },
            { "name": "sigDeadline", "type": "uint256" }
          ]
        },
        { "name": "permit2Signature", "type": "bytes"   },
        { "name": "multicallData",    "type": "bytes[]" }
      ],
      "outputs": [ { "name": "results", "type": "bytes[]" } ]
    }
  },
  "emit": {
    "strategy": "multicall_recurse",
    "recurse_rule_id": "self_array_bytes_last_arg",
    "recurse_arg": "multicallData",
    "max_depth": 3
  },
  "requires": {
    "imperative": ["multicall-recurse@^1.0"],
    "adapter_capabilities": [],
    "host_capabilities": [],
    "extension": ">=0.1.0"
  }
}
