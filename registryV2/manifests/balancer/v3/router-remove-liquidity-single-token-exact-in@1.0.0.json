{
  "type": "adapter_action",
  "id": "balancer/v3/router-remove-liquidity-single-token-exact-in@1.0.0",
  "publisher": "balancer.eth",
  "schema_version": "3",
  "_note": "Balancer V3 Router.removeLiquiditySingleTokenExactIn(address pool, uint256 exactBptAmountIn, address tokenOut, uint256 minAmountOut, bool wethIsEth, bytes userData) — selector 0xecb2182c. Source: balancer/balancer-deployments v3/tasks/20250307-v3-router-v2. Maps to Amm::RemoveLiquidity::PooledBurn. Single-token withdraw: tokenOut + minAmountOut are both in calldata (no pool-token resolver needed). lp_token = pool (BPT) address = $args.pool. lp_amount = exactBptAmountIn (exact BPT burned). Mainnet only.",
  "match": {
    "selector": "0xecb2182c",
    "chain_to_addresses": {
      "1": ["0xAE563E3f8219521950555F5962419C8919758Ea2"]
    }
  },
  "abi_fragment": {
    "function_name": "removeLiquiditySingleTokenExactIn",
    "abi": {
      "name": "removeLiquiditySingleTokenExactIn",
      "type": "function",
      "stateMutability": "payable",
      "inputs": [
        { "name": "pool",             "type": "address" },
        { "name": "exactBptAmountIn", "type": "uint256" },
        { "name": "tokenOut",         "type": "address" },
        { "name": "minAmountOut",     "type": "uint256" },
        { "name": "wethIsEth",        "type": "bool"    },
        { "name": "userData",         "type": "bytes"   }
      ],
      "outputs": [ { "name": "amountOut", "type": "uint256" } ]
    }
  },
  "emit": {
    "strategy": "single_emit",
    "body": {
      "domain": "amm",
      "amm": {
        "action": "remove_liquidity",
        "remove_liquidity": {
          "venue": {
            "name":      "balancer_v3",
            "chain":     "$chain",
            "pool_id":   "$args.pool",
            "pool_type": "weighted"
          },
          "params": {
            "kind": "pooled_burn",
            "lp_token": { "key": { "standard": "erc20", "chain": "$chain", "address": "$args.pool" } },
            "lp_amount": "$args.exactBptAmountIn",
            "min_out": [
              [
                { "key": { "standard": "erc20", "chain": "$chain", "address": "$args.tokenOut" } },
                "$args.minAmountOut"
              ]
            ],
            "recipient": "$tx.from"
          },
          "live_inputs": {
            "pool_state": {
              "source": {
                "kind":       "onchain_view",
                "chain":      "$chain",
                "contract":   "$args.pool",
                "function":   "getCurrentLiveBalances()",
                "decoder_id": "balancer_v3_pool_balances"
              },
              "ttl_s": 12
            },
            "fees_owed": {
              "source": {
                "kind":    "derived_from",
                "inputs":  [],
                "calc_id": "balancer_v3_fees_owed"
              },
              "ttl_s": 12
            }
          }
        }
      }
    }
  },
  "requires": {
    "imperative": [],
    "adapter_capabilities": ["token_metadata"],
    "host_capabilities": [],
    "extension": ">=0.1.0"
  }
}
