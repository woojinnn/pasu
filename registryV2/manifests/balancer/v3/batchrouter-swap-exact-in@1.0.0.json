{
  "type": "adapter_action",
  "id": "balancer/v3/batchrouter-swap-exact-in@1.0.0",
  "publisher": "balancer.eth",
  "schema_version": "3",
  "_note": "Balancer V3 BatchRouter.swapExactIn(SwapPathExactAmountIn[] paths, uint256 deadline, bool wethIsEth, bytes userData) — selector 0x286f580d, contract 0x136f1EFcC3f8f88516B9E94110D56FDBfB1778d1. Source: balancer/balancer-deployments v3 20241205-v3-batch-router. paths[i] = (tokenIn, (pool,tokenOut,isBuffer)[] steps, exactAmountIn, minAmountOut). Tokens ARE in calldata (tokenIn + each step's tokenOut) → no baked map needed; balancer_v3_swap_path_field extracts the aggregate Amm::Swap from paths[0]: token_in=tokenIn, token_out=LAST step's tokenOut, amount_in=exactAmountIn, min_out=minAmountOut. Coarse for true multi-path batches (first path) — correct for the dominant single-route multi-hop. recipient=tx.from. Mainnet only; resolved as a permitBatchAndCall child too via multicall_recurse.",
  "match": {
    "selector": "0x286f580d",
    "chain_to_addresses": {
      "1": ["0x136f1EFcC3f8f88516B9E94110D56FDBfB1778d1"]
    }
  },
  "abi_fragment": {
    "function_name": "swapExactIn",
    "abi": {
      "name": "swapExactIn",
      "type": "function",
      "stateMutability": "payable",
      "inputs": [
        {
          "name": "paths",
          "type": "tuple[]",
          "components": [
            { "name": "tokenIn",       "type": "address" },
            {
              "name": "steps",
              "type": "tuple[]",
              "components": [
                { "name": "pool",     "type": "address" },
                { "name": "tokenOut", "type": "address" },
                { "name": "isBuffer", "type": "bool"    }
              ]
            },
            { "name": "exactAmountIn", "type": "uint256" },
            { "name": "minAmountOut",  "type": "uint256" }
          ]
        },
        { "name": "deadline",  "type": "uint256" },
        { "name": "wethIsEth", "type": "bool"    },
        { "name": "userData",  "type": "bytes"   }
      ],
      "outputs": [
        { "name": "pathAmountsOut", "type": "uint256[]" },
        { "name": "tokensOut",      "type": "address[]" },
        { "name": "amountsOut",     "type": "uint256[]" }
      ]
    }
  },
  "emit": {
    "strategy": "single_emit",
    "body": {
      "domain": "amm",
      "amm": {
        "action": "swap",
        "swap": {
          "venue": {
            "name":      "balancer_v3",
            "chain":     "$chain",
            "pool_id":   { "$fn": "balancer_v3_swap_path_field", "$args": ["$args.paths", "pool"] },
            "pool_type": "weighted"
          },
          "params": {
            "token_in": {
              "key": {
                "standard": "erc20",
                "chain":    "$chain",
                "address":  { "$fn": "balancer_v3_swap_path_field", "$args": ["$args.paths", "token_in"] }
              }
            },
            "token_out": {
              "key": {
                "standard": "erc20",
                "chain":    "$chain",
                "address":  { "$fn": "balancer_v3_swap_path_field", "$args": ["$args.paths", "token_out"] }
              }
            },
            "direction": {
              "kind": "exact_input",
              "amount_in":      { "$fn": "balancer_v3_swap_path_field", "$args": ["$args.paths", "amount_in"] },
              "min_amount_out": { "$fn": "balancer_v3_swap_path_field", "$args": ["$args.paths", "min_out"] }
            },
            "recipient":   "$tx.from",
            "slippage_bp": 50
          },
          "live_inputs": {
            "route": {
              "source": {
                "kind":     "registry_api",
                "endpoint": "https://registry-api-v2-891268973493.asia-northeast3.run.app",
                "resource": {
                  "kind":      "pool_meta",
                  "chain":     "$chain",
                  "pool_addr": { "$fn": "balancer_v3_swap_path_field", "$args": ["$args.paths", "pool"] }
                },
                "version": "3"
              },
              "ttl_s": 86400
            },
            "expected_amount_out": {
              "source": {
                "kind":       "onchain_view",
                "chain":      "$chain",
                "contract":   "$to",
                "function":   "querySwapExactIn((address,(address,address,bool)[],uint256,uint256)[],address,bytes)",
                "decoder_id": "balancer_v3_query_batch_swap_exact_in"
              },
              "ttl_s": 12
            },
            "price_impact_bp": {
              "source": { "kind": "derived_from", "inputs": [], "calc_id": "balancer_v3_price_impact_bp" },
              "ttl_s": 12
            },
            "gas_estimate": {
              "source": { "kind": "oracle_feed", "provider": "pyth", "feed_id": "gas/ethereum" },
              "ttl_s": 6
            }
          }
        }
      }
    }
  },
  "requires": {
    "imperative": [],
    "adapter_capabilities": ["token_metadata"],
    "host_capabilities": [],
    "extension": ">=0.1.0"
  }
}
