{
  "type": "adapter_action",
  "id": "standard/erc20/transferFrom@1.0.0",
  "schema_version": "3",
  "match": {
    "selector": "0x23b872dd",
    "chain_to_addresses_source": "tokens:erc20",
    "chain_ids": [1, 10, 8453, 42161],
    "semantic_token_kind_exclude": ["debt_receipt"]
  },
  "abi_fragment": {
    "function_name": "transferFrom",
    "abi": {
      "name": "transferFrom",
      "type": "function",
      "stateMutability": "nonpayable",
      "inputs": [
        { "name": "from", "type": "address" },
        { "name": "to", "type": "address" },
        { "name": "amount", "type": "uint256" }
      ],
      "outputs": [
        { "name": "", "type": "bool" }
      ]
    }
  },
  "emit": {
    "strategy": "single_emit",
    "body": {
      "domain": "token",
      "token": {
        "action": "erc20_transfer",
        "erc20_transfer": {
          "token": {
            "key": {
              "standard": "erc20",
              "chain": "$chain",
              "address": "$to"
            }
          },
          "recipient": "$args.to",
          "amount": "$args.amount"
        }
      }
    },
    "live_inputs": {}
  },
  "requires": {
    "imperative": [],
    "adapter_capabilities": ["token_metadata"],
    "host_capabilities": [],
    "extension": ">=0.1.0"
  }
}
