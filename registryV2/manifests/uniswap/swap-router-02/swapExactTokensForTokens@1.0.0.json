                  {
                    "scope": "global",
                    "name": "uniswap_v2_pool_state"
                  }
                ],
                "calc_id": "uniswap_v2_price_impact_bp"
              },
              "ttl_s": 12
            },
            "gas_estimate": {
              "source": {
                "kind": "oracle_feed",
                "provider": "pyth",
                "feed_id": "gas/ethereum"
              },
              "ttl_s": 6
            }
          }
        }
      }
    }
  },
  "requires": {
