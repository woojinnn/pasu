{
  "type": "adapter_action",
  "id": "uniswap/permit2/invalidateNonces@1.0.0",
  "publisher": "uniswap.eth",
  "schema_version": "3",
  "match": {
    "selector": "0x65d9723c",
    "chain_to_addresses": {
      "1": ["0x000000000022d473030f116ddee9f6b43ac78ba3"],
      "10": ["0x000000000022d473030f116ddee9f6b43ac78ba3"],
