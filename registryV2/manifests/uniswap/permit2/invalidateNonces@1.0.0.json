      "42161": ["0x000000000022d473030f116ddee9f6b43ac78ba3"]
    }
  },
  "note": "Permit2 invalidateNonces(token,spender,newNonce) invalidates ordered allowance nonces for a token/spender pair. This is modeled as a permission revocation for policy purposes; the exact nonce floor is not represented in RevokeScope today.",
  "abi_fragment": {
    "function_name": "invalidateNonces",
    "abi": {
      "name": "invalidateNonces",
      "type": "function",
      "stateMutability": "nonpayable",
      "inputs": [
        { "name": "token", "type": "address" },
        { "name": "spender", "type": "address" },
        { "name": "newNonce", "type": "uint48" }
      ],
      "outputs": []
    }
  },
  "emit": {
    "strategy": "single_emit",
    "body": {
      "domain": "token",
      "token": {
        "action": "revoke_approval",
        "revoke_approval": {
          "scope": {
            "kind": "permit2_lockdown",
            "token": {
              "key": {
                "standard": "erc20",
