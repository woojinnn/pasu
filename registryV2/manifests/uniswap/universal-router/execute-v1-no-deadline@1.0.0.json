        "inputs_abi": "(((address,uint160,uint48,uint48)[],address,uint256) permitBatch, bytes signature)",
        "body": {
          "domain": "token",
          "token": {
            "action": "permit2_sign_allowance",
            "permit2_sign_allowance": {
              "token": {
                "key": {
                  "standard": "erc20",
                  "chain": "$chain",
                  "address": "$inputs.permitBatch[0][0][0]"
                }
              },
              "spender": "$inputs.permitBatch[1]",
              "amount": "$inputs.permitBatch[0][0][1]",
              "expires_at": "$inputs.permitBatch[0][0][2]",
              "sig_deadline": "$inputs.permitBatch[2]",
              "nonce": "$inputs.permitBatch[0][0][3]",
