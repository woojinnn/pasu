        "_note": "UNWRAP_WETH unwraps router's WETH balance to ETH (recipient receives native). Same schema limitation as WRAP_ETH — see open_question on native↔wrapped semantics."
      },
      "0x0d": {
        "name": "PERMIT2_TRANSFER_FROM_BATCH",
        "inputs_abi": "((address from, address to, uint160 amount, address token)[] transferDetails)",
