{
  "type": "adapter_action",
  "id": "uniswapx/reactor/execute-with-callback@1.0.0",
  "publisher": "uniswap.eth",
  "schema_version": "3",
  "note": "UniswapX reactor executeWithCallback((bytes,bytes),bytes) settlement entrypoint. SignedOrder.order is decoded by reactor address into Amm::SettleIntentOrder; callbackData remains filler strategy data and is preserved by calldata/audit outside the semantic order fields.",
  "match": {
    "selector": "0x0d335884",
    "chain_to_addresses": {
      "1": [
        "0x6000da47483062A0D734Ba3dc7576Ce6A0B645C4",
        "0x00000011F84B9aa48e5f8aa8B9897600006289Be"
      ],
      "42161": [
        "0xB274d5F4b833b61B340b654d600A864fB604a87c"
      ],
      "8453": [
        "0x000000001Ec5656dcdB24D90DFa42742738De729"
      ]
    }
  },
  "abi_fragment": {
    "function_name": "executeWithCallback",
    "abi": {
      "type": "function",
      "name": "executeWithCallback",
      "stateMutability": "payable",
      "inputs": [
        {
          "name": "order",
          "type": "tuple",
          "internalType": "struct SignedOrder",
          "components": [
            { "name": "order", "type": "bytes", "internalType": "bytes" },
            { "name": "sig", "type": "bytes", "internalType": "bytes" }
          ]
        },
        { "name": "callbackData", "type": "bytes", "internalType": "bytes" }
      ],
      "outputs": []
    }
  },
  "emit": {
    "strategy": "single_emit",
    "body": {
      "domain": "amm",
      "amm": {
        "action": "settle_intent_order",
        "settle_intent_order": {
          "venue": {
            "name": "uniswap_x",
            "chain": "$chain",
            "reactor": "$to"
          },
          "swapper": { "$fn": "uniswapx_reactor_order_field", "$args": ["$args.order[0]", "$to", "swapper"] },
          "sell": { "key": { "standard": "erc20", "chain": "$chain", "address": { "$fn": "uniswapx_reactor_order_field", "$args": ["$args.order[0]", "$to", "sell_token"] } } },
          "buy": { "key": { "standard": "erc20", "chain": "$chain", "address": { "$fn": "uniswapx_reactor_order_field", "$args": ["$args.order[0]", "$to", "buy_token"] } } },
          "sell_amount": { "$fn": "uniswapx_reactor_order_field", "$args": ["$args.order[0]", "$to", "sell_amount"] },
          "buy_min": { "$fn": "uniswapx_reactor_order_field", "$args": ["$args.order[0]", "$to", "buy_min"] },
          "order_kind": { "$fn": "uniswapx_reactor_order_field", "$args": ["$args.order[0]", "$to", "order_kind"] },
          "recipient": { "$fn": "uniswapx_reactor_order_field", "$args": ["$args.order[0]", "$to", "recipient"] },
          "valid_until": { "$fn": "uniswapx_reactor_order_field", "$args": ["$args.order[0]", "$to", "valid_until"] },
          "order_nonce": { "$fn": "uniswapx_reactor_order_field", "$args": ["$args.order[0]", "$to", "order_nonce"] },
          "signature": "$args.order[1]"
        }
      }
    }
  },
  "requires": {
    "imperative": [],
    "adapter_capabilities": [],
    "host_capabilities": [],
    "extension": ">=0.1.0"
  }
}
