{
  "type": "adapter_action",
  "id": "curve/cryptoswap/btcghoeth/remove_liquidity-receiver@1.0.0",
  "publisher": "curve.fi",
  "schema_version": "3",
  "match": {
    "selector": "0x1da3d238",
    "chain_to_addresses": {
      "1": [
        "0x8a4f252812dff2a8636e4f7eb249d8fc2e3bd77f"
      ]
    }
  },
  "abi_fragment": {
    "function_name": "remove_liquidity",
    "abi": {
      "name": "remove_liquidity",
      "type": "function",
      "stateMutability": "nonpayable",
      "inputs": [
        {
          "name": "_amount",
          "type": "uint256"
        },
        {
          "name": "min_amounts",
          "type": "uint256[3]"
        },
        {
          "name": "use_eth",
          "type": "bool"
        },
        {
          "name": "receiver",
          "type": "address"
        }
      ]
    }
  },
  "emit": {
    "strategy": "single_emit",
    "body": {
      "domain": "amm",
      "amm": {
        "action": "remove_liquidity",
        "remove_liquidity": {
          "venue": {
            "name": "curve_v2",
            "chain": "$chain",
            "pool": "$to"
          },
          "params": {
            "kind": "pooled_burn",
            "lp_token": {
              "key": {
                "standard": "erc20",
                "chain": "$chain",
                "address": "$to"
              }
            },
            "lp_amount": "$args._amount",
            "min_out": [
              [
                {
                  "key": {
                    "standard": "erc20",
                    "chain": "$chain",
                    "address": "0x40d16fc0246ad3160ccc09b8d0d3a2cd28ae6c2f"
                  }
                },
                "$args.min_amounts[0]"
              ],
              [
                {
                  "key": {
                    "standard": "erc20",
                    "chain": "$chain",
                    "address": "0xcbb7c0000ab88b473b1f5afd9ef808440eed33bf"
                  }
                },
                "$args.min_amounts[1]"
              ],
              [
                {
                  "key": {
                    "standard": "erc20",
                    "chain": "$chain",
                    "address": "0xc02aaa39b223fe8d0a0e5c4f27ead9083c756cc2"
                  }
                },
                "$args.min_amounts[2]"
              ]
            ],
            "recipient": "$args.receiver"
          },
          "live_inputs": {
            "pool_state": {
              "source": {
                "kind": "onchain_view",
                "chain": "$chain",
                "contract": "$to",
                "function": "get_balances()",
                "decoder_id": "curve_v2_balances"
              },
              "ttl_s": 12
            },
            "fees_owed": {
              "source": {
                "kind": "derived_from",
                "inputs": [
                  {
                    "scope": "global",
                    "name": "curve_v2_pool_state"
                  }
                ],
                "calc_id": "curve_v2_fees_owed"
              },
              "ttl_s": 12
            }
          }
        }
      }
    }
  },
  "requires": {
    "imperative": [],
    "adapter_capabilities": [
      "token_metadata"
    ],
    "host_capabilities": [],
    "extension": ">=0.1.0"
  }
}
