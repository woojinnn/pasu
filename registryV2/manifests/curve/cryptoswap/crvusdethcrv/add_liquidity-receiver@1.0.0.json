{
  "type": "adapter_action",
  "id": "curve/cryptoswap/crvusdethcrv/add_liquidity-receiver@1.0.0",
  "publisher": "curve.fi",
  "schema_version": "3",
  "match": {
    "selector": "0x5cecb5f7",
    "chain_to_addresses": {
      "1": [
        "0x4ebdf703948ddcea3b11f675b4d1fba9d2414a14"
      ]
    }
  },
  "abi_fragment": {
    "function_name": "add_liquidity",
    "abi": {
      "name": "add_liquidity",
      "type": "function",
      "stateMutability": "payable",
      "inputs": [
        {
          "name": "amounts",
          "type": "uint256[3]"
        },
        {
          "name": "min_mint_amount",
          "type": "uint256"
        },
        {
          "name": "use_eth",
          "type": "bool"
        },
        {
          "name": "receiver",
          "type": "address"
        }
      ]
    }
  },
  "emit": {
    "strategy": "single_emit",
    "body": {
      "domain": "amm",
      "amm": {
        "action": "add_liquidity",
        "add_liquidity": {
          "venue": {
            "name": "curve_v2",
            "chain": "$chain",
            "pool": "$to"
          },
          "params": {
            "kind": "pooled",
            "tokens": [
              [
                {
                  "key": {
                    "standard": "erc20",
                    "chain": "$chain",
                    "address": "0xf939e0a03fb07f59a73314e73794be0e57ac1b4e"
                  }
                },
                "$args.amounts[0]"
              ],
              [
                {
                  "key": {
                    "standard": "erc20",
                    "chain": "$chain",
                    "address": "0xc02aaa39b223fe8d0a0e5c4f27ead9083c756cc2"
                  }
                },
                "$args.amounts[1]"
              ],
              [
                {
                  "key": {
                    "standard": "erc20",
                    "chain": "$chain",
                    "address": "0xd533a949740bb3306d119cc777fa900ba034cd52"
                  }
                },
                "$args.amounts[2]"
              ]
            ],
            "min_lp_out": "$args.min_mint_amount",
            "recipient": "$args.receiver"
          },
          "live_inputs": {
            "pool_state": {
              "source": {
                "kind": "onchain_view",
                "chain": "$chain",
                "contract": "$to",
                "function": "get_balances()",
                "decoder_id": "curve_v2_balances"
              },
              "ttl_s": 12
            },
            "current_price": {
              "source": {
                "kind": "derived_from",
                "inputs": [
                  {
                    "scope": "global",
                    "name": "curve_v2_pool_state"
                  }
                ],
                "calc_id": "curve_v2_price_impact_bp"
              },
              "ttl_s": 12
            }
          }
        }
      }
    }
  },
  "requires": {
    "imperative": [],
    "adapter_capabilities": [
      "token_metadata"
    ],
    "host_capabilities": [],
    "extension": ">=0.1.0"
  }
}
