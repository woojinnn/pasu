{
  "type": "adapter_action",
  "id": "curve/twocrypto/crvusd-wbtc/remove_liquidity_one_coin-receiver@1.0.0",
  "publisher": "curve.fi",
  "schema_version": "3",
  "match": {
    "selector": "0x0fbcee6e",
    "chain_to_addresses": {
      "1": [
        "0x313698667d7fdd6789a9bc70821309ff891e729a",
        "0xd9ff8396554a0d18b2cfbec53e1979b7ecce8373"
      ]
    }
  },
  "abi_fragment": {
    "function_name": "remove_liquidity_one_coin",
    "abi": {
      "name": "remove_liquidity_one_coin",
      "type": "function",
      "stateMutability": "nonpayable",
      "inputs": [
        {
          "name": "lp_token_amount",
          "type": "uint256"
        },
        {
          "name": "i",
          "type": "uint256"
        },
        {
          "name": "min_amount",
          "type": "uint256"
        },
        {
          "name": "receiver",
          "type": "address"
        }
      ]
    }
  },
  "emit": {
    "strategy": "single_emit",
    "body": {
      "domain": "amm",
      "amm": {
        "action": "remove_liquidity",
        "remove_liquidity": {
          "venue": {
            "name": "curve_v2",
            "chain": "$chain",
            "pool": "$to"
          },
          "params": {
            "kind": "pooled_burn_one_coin",
            "lp_token": {
              "key": {
                "standard": "erc20",
                "chain": "$chain",
                "address": "$to"
              }
            },
            "lp_amount": "$args.lp_token_amount",
            "token_out": {
              "key": {
                "standard": "erc20",
                "chain": "$chain",
                "address": {
                  "$match": "$args.i",
                  "$cases": {
                    "0": "0xf939e0a03fb07f59a73314e73794be0e57ac1b4e",
                    "1": "0x2260fac5e5542a773aa44fbcfedf7c193bc2c599"
                  }
                }
              }
            },
            "min_out": "$args.min_amount",
            "recipient": "$args.receiver"
          },
          "live_inputs": {
            "pool_state": {
              "source": {
                "kind": "onchain_view",
                "chain": "$chain",
                "contract": "$to",
                "function": "get_balances()",
                "decoder_id": "curve_v2_balances"
              },
              "ttl_s": 12
            },
            "fees_owed": {
              "source": {
                "kind": "derived_from",
                "inputs": [
                  {
                    "scope": "global",
                    "name": "curve_v2_pool_state"
                  }
                ],
                "calc_id": "curve_v2_fees_owed"
              },
              "ttl_s": 12
            }
          }
        }
      }
    }
  },
  "requires": {
    "imperative": [],
    "adapter_capabilities": [
      "token_metadata"
    ],
    "host_capabilities": [],
    "extension": ">=0.1.0"
  }
}
