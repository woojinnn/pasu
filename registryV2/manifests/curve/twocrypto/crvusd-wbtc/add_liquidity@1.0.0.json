{
  "type": "adapter_action",
  "id": "curve/twocrypto/crvusd-wbtc/add_liquidity@1.0.0",
  "publisher": "curve.fi",
  "schema_version": "3",
  "match": {
    "selector": "0x0b4c7e4d",
    "chain_to_addresses": {
      "1": [
        "0x313698667d7fdd6789a9bc70821309ff891e729a",
        "0xd9ff8396554a0d18b2cfbec53e1979b7ecce8373"
      ]
    }
  },
  "abi_fragment": {
    "function_name": "add_liquidity",
    "abi": {
      "name": "add_liquidity",
      "type": "function",
      "stateMutability": "nonpayable",
      "inputs": [
        {
          "name": "amounts",
          "type": "uint256[2]"
        },
        {
          "name": "min_mint_amount",
          "type": "uint256"
        }
      ]
    }
  },
  "emit": {
    "strategy": "single_emit",
    "body": {
      "domain": "amm",
      "amm": {
        "action": "add_liquidity",
        "add_liquidity": {
          "venue": {
            "name": "curve_v2",
            "chain": "$chain",
            "pool": "$to"
          },
          "params": {
            "kind": "pooled",
            "tokens": [
              [
                {
                  "key": {
                    "standard": "erc20",
                    "chain": "$chain",
                    "address": "0xf939e0a03fb07f59a73314e73794be0e57ac1b4e"
                  }
                },
                "$args.amounts[0]"
              ],
              [
                {
                  "key": {
                    "standard": "erc20",
                    "chain": "$chain",
                    "address": "0x2260fac5e5542a773aa44fbcfedf7c193bc2c599"
                  }
                },
                "$args.amounts[1]"
              ]
            ],
            "min_lp_out": "$args.min_mint_amount",
            "recipient": "$tx.from"
          },
          "live_inputs": {
            "pool_state": {
              "source": {
                "kind": "onchain_view",
                "chain": "$chain",
                "contract": "$to",
                "function": "get_balances()",
                "decoder_id": "curve_v2_balances"
              },
              "ttl_s": 12
            },
            "current_price": {
              "source": {
                "kind": "derived_from",
                "inputs": [
                  {
                    "scope": "global",
                    "name": "curve_v2_pool_state"
                  }
                ],
                "calc_id": "curve_v2_price_impact_bp"
              },
              "ttl_s": 12
            }
          }
        }
      }
    }
  },
  "requires": {
    "imperative": [],
    "adapter_capabilities": [
      "token_metadata"
    ],
    "host_capabilities": [],
    "extension": ">=0.1.0"
  }
}
