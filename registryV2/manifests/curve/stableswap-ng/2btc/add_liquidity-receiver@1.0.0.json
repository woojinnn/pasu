{
  "type": "adapter_action",
  "id": "curve/stableswap-ng/2btc/add_liquidity-receiver@1.0.0",
  "publisher": "curve.fi",
  "schema_version": "3",
  "match": {
    "selector": "0x0c3e4b54",
    "chain_to_addresses": {
      "1": [
        "0xb7ecb2aa52aa64a717180e030241bc75cd946726"
      ]
    }
  },
  "abi_fragment": {
    "function_name": "add_liquidity",
    "abi": {
      "name": "add_liquidity",
      "type": "function",
      "stateMutability": "nonpayable",
      "inputs": [
        {
          "name": "_amounts",
          "type": "uint256[2]"
        },
        {
          "name": "_min_mint_amount",
          "type": "uint256"
        },
        {
          "name": "_receiver",
          "type": "address"
        }
      ]
    }
  },
  "emit": {
    "strategy": "single_emit",
    "body": {
      "domain": "amm",
      "amm": {
        "action": "add_liquidity",
        "add_liquidity": {
          "venue": {
            "name": "curve_v1",
            "chain": "$chain",
            "pool": "$to",
            "n_coins": 2,
            "is_meta": false
          },
          "params": {
            "kind": "pooled",
            "tokens": [
              [
                {
                  "key": {
                    "standard": "erc20",
                    "chain": "$chain",
                    "address": "0x2260fac5e5542a773aa44fbcfedf7c193bc2c599"
                  }
                },
                "$args._amounts[0]"
              ],
              [
                {
                  "key": {
                    "standard": "erc20",
                    "chain": "$chain",
                    "address": "0x18084fba666a33d37592fa2633fd49a74dd93a88"
                  }
                },
                "$args._amounts[1]"
              ]
            ],
            "min_lp_out": "$args._min_mint_amount",
            "recipient": "$args._receiver"
          },
          "live_inputs": {
            "pool_state": {
              "source": {
                "kind": "onchain_view",
                "chain": "$chain",
                "contract": "$to",
                "function": "get_balances()",
                "decoder_id": "curve_ng_balances"
              },
              "ttl_s": 12
            },
            "current_price": {
              "source": {
                "kind": "derived_from",
                "inputs": [
                  {
                    "scope": "global",
                    "name": "curve_ng_pool_state"
                  }
                ],
                "calc_id": "curve_ng_price_impact_bp"
              },
              "ttl_s": 12
            }
          }
        }
      }
    }
  },
  "requires": {
    "imperative": [],
    "adapter_capabilities": [
      "token_metadata"
    ],
    "host_capabilities": [],
    "extension": ">=0.1.0"
  }
}
