{
  "type": "adapter_action",
  "id": "curve/stableswap-ng/2btc/exchange-receiver@1.0.0",
  "publisher": "curve.fi",
  "schema_version": "3",
  "match": {
    "selector": "0xddc1f59d",
    "chain_to_addresses": {
      "1": [
        "0xb7ecb2aa52aa64a717180e030241bc75cd946726"
      ]
    }
  },
  "abi_fragment": {
    "function_name": "exchange",
    "abi": {
      "name": "exchange",
      "type": "function",
      "stateMutability": "nonpayable",
      "inputs": [
        {
          "name": "i",
          "type": "int128"
        },
        {
          "name": "j",
          "type": "int128"
        },
        {
          "name": "_dx",
          "type": "uint256"
        },
        {
          "name": "_min_dy",
          "type": "uint256"
        },
        {
          "name": "_receiver",
          "type": "address"
        }
      ]
    }
  },
  "emit": {
    "strategy": "single_emit",
    "body": {
      "domain": "amm",
      "amm": {
        "action": "swap",
        "swap": {
          "venue": {
            "name": "curve_v1",
            "chain": "$chain",
            "pool": "$to",
            "n_coins": 2,
            "is_meta": false
          },
          "params": {
            "token_in": {
              "key": {
                "standard": "erc20",
                "chain": "$chain",
                "address": {
                  "$match": "$args.i",
                  "$cases": {
                    "0": "0x2260fac5e5542a773aa44fbcfedf7c193bc2c599",
                    "1": "0x18084fba666a33d37592fa2633fd49a74dd93a88"
                  }
                }
              }
            },
            "token_out": {
              "key": {
                "standard": "erc20",
                "chain": "$chain",
                "address": {
                  "$match": "$args.j",
                  "$cases": {
                    "0": "0x2260fac5e5542a773aa44fbcfedf7c193bc2c599",
                    "1": "0x18084fba666a33d37592fa2633fd49a74dd93a88"
                  }
                }
              }
            },
            "direction": {
              "kind": "exact_input",
              "amount_in": "$args._dx",
              "min_amount_out": "$args._min_dy"
            },
            "recipient": "$args._receiver",
            "slippage_bp": 0
          },
          "live_inputs": {
            "route": {
              "source": {
                "kind": "onchain_view",
                "chain": "$chain",
                "contract": "$to",
                "function": "get_balances()",
                "decoder_id": "curve_ng_balances"
              },
              "ttl_s": 12
            },
            "expected_amount_out": {
              "source": {
                "kind": "derived_from",
                "inputs": [
                  {
                    "scope": "global",
                    "name": "curve_ng_pool_state"
                  }
                ],
                "calc_id": "curve_ng_expected_out"
              },
              "ttl_s": 12
            },
            "price_impact_bp": {
              "source": {
                "kind": "derived_from",
                "inputs": [
                  {
                    "scope": "global",
                    "name": "curve_ng_pool_state"
                  }
                ],
                "calc_id": "curve_ng_price_impact_bp"
              },
              "ttl_s": 12
            },
            "gas_estimate": {
              "source": {
                "kind": "oracle_feed",
                "provider": "pyth",
                "feed_id": "gas/ethereum"
              },
              "ttl_s": 6
            }
          }
        }
      }
    }
  },
  "requires": {
    "imperative": [],
    "adapter_capabilities": [
      "token_metadata"
    ],
    "host_capabilities": [],
    "extension": ">=0.1.0"
  }
}
