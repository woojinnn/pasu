{
  "type": "adapter_action",
  "id": "curve/stableswap-ng/crvusdfrax/remove_liquidity_imbalance-receiver@1.0.0",
  "publisher": "curve.fi",
  "schema_version": "3",
  "match": {
    "selector": "0x52d2cfdd",
    "chain_to_addresses": {
      "1": [
        "0x0cd6f267b2086bea681e922e19d40512511be538"
      ]
    }
  },
  "abi_fragment": {
    "function_name": "remove_liquidity_imbalance",
    "abi": {
      "name": "remove_liquidity_imbalance",
      "type": "function",
      "stateMutability": "nonpayable",
      "inputs": [
        {
          "name": "_amounts",
          "type": "uint256[2]"
        },
        {
          "name": "_max_burn_amount",
          "type": "uint256"
        },
        {
          "name": "_receiver",
          "type": "address"
        }
      ]
    }
  },
  "emit": {
    "strategy": "single_emit",
    "body": {
      "domain": "amm",
      "amm": {
        "action": "remove_liquidity",
        "remove_liquidity": {
          "venue": {
            "name": "curve_v1",
            "chain": "$chain",
            "pool": "$to",
            "n_coins": 2,
            "is_meta": false
          },
          "params": {
            "kind": "pooled_burn_imbalance",
            "lp_token": {
              "key": {
                "standard": "erc20",
                "chain": "$chain",
                "address": "$to"
              }
            },
            "max_lp_burn": "$args._max_burn_amount",
            "amounts_out": [
              [
                {
                  "key": {
                    "standard": "erc20",
                    "chain": "$chain",
                    "address": "0x853d955acef822db058eb8505911ed77f175b99e"
                  }
                },
                "$args._amounts[0]"
              ],
              [
                {
                  "key": {
                    "standard": "erc20",
                    "chain": "$chain",
                    "address": "0xf939e0a03fb07f59a73314e73794be0e57ac1b4e"
                  }
                },
                "$args._amounts[1]"
              ]
            ],
            "recipient": "$args._receiver"
          },
          "live_inputs": {
            "pool_state": {
              "source": {
                "kind": "onchain_view",
                "chain": "$chain",
                "contract": "$to",
                "function": "get_balances()",
                "decoder_id": "curve_ng_balances"
              },
              "ttl_s": 12
            },
            "fees_owed": {
              "source": {
                "kind": "derived_from",
                "inputs": [
                  {
                    "scope": "global",
                    "name": "curve_ng_pool_state"
                  }
                ],
                "calc_id": "curve_ng_fees_owed"
              },
              "ttl_s": 12
            }
          }
        }
      }
    }
  },
  "requires": {
    "imperative": [],
    "adapter_capabilities": [
      "token_metadata"
    ],
    "host_capabilities": [],
    "extension": ">=0.1.0"
  }
}
