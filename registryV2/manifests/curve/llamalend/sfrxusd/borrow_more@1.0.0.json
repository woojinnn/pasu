{
  "type": "adapter_action",
  "id": "curve/llamalend/sfrxusd/borrow_more@1.0.0",
  "publisher": "curve.fi",
  "schema_version": "3",
  "match": {
    "selector": "0xdd171e7c",
    "chain_to_addresses": {
      "1": [
        "0x3de37c38739dfb83b7a902842bf5393040f7bf50"
      ]
    }
  },
  "abi_fragment": {
    "function_name": "borrow_more",
    "abi": {
      "name": "borrow_more",
      "type": "function",
      "stateMutability": "nonpayable",
      "inputs": [
        {
          "name": "collateral",
          "type": "uint256"
        },
        {
          "name": "debt",
          "type": "uint256"
        }
      ]
    }
  },
  "emit": {
    "strategy": "single_emit",
    "body": {
      "domain": "lending",
      "lending": {
        "action": "borrow",
        "borrow": {
          "venue": {
            "name": "llama_lend",
            "chain": "$chain",
            "controller": "$to",
            "collateral": {
              "key": {
                "standard": "erc20",
                "chain": "$chain",
                "address": "0xcf62f905562626cfcdd2261162a51fd02fc9c5b6"
              }
            }
          },
          "asset": {
            "key": {
              "standard": "erc20",
              "chain": "$chain",
              "address": "0xf939e0a03fb07f59a73314e73794be0e57ac1b4e"
            }
          },
          "amount": "$args.debt",
          "rate_mode": "variable",
          "on_behalf_of": "$tx.from"
        }
      }
    },
    "live_inputs": {
      "reserve_state": {
        "source": {
          "kind": "onchain_view",
          "chain": "$chain",
          "contract": "$to",
          "function": "amm()",
          "decoder_id": "llamalend_controller_state"
        },
        "ttl_s": 30
      },
      "user_state_before": {
        "source": {
          "kind": "onchain_view",
          "chain": "$chain",
          "contract": "$to",
          "function": "user_state(address)",
          "decoder_id": "llamalend_user_state"
        },
        "ttl_s": 12
      },
      "asset_price_usd": {
        "source": {
          "kind": "derived_from",
          "inputs": [],
          "calc_id": "llamalend_debt_price"
        },
        "ttl_s": 60
      },
      "current_borrow_rate": {
        "source": {
          "kind": "derived_from",
          "inputs": [],
          "calc_id": "llamalend_borrow_rate"
        },
        "ttl_s": 30
      },
      "available_liquidity": {
        "source": {
          "kind": "derived_from",
          "inputs": [],
          "calc_id": "llamalend_available_debt"
        },
        "ttl_s": 30
      }
    }
  },
  "requires": {
    "imperative": [],
    "adapter_capabilities": [
      "token_metadata"
    ],
    "host_capabilities": [],
    "extension": ">=0.1.0"
  }
}
