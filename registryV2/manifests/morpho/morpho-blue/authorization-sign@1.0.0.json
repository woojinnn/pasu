{
  "type": "adapter_action",
  "id": "morpho/morpho-blue/authorization-sign@1.0.0",
  "publisher": "morpho.eth",
  "note": "Morpho Blue off-chain Authorization (EIP-712) — what a user SIGNS to grant an operator full control of their positions; a relayer later submits it via setAuthorizationWithSig(Authorization,Signature). Morpho's EIP-712 domain is MINIMAL (chainId + verifyingContract only, NO name/version) so domain_name is intentionally omitted. primary_type=Authorization; the 5 message fields are flat scalars so build_typed_data_args_json takes the flat path ($args.<field> = message field). selector 0x00000001 is a sign-only placeholder (off-chain sig is never an on-chain calldata call against this manifest). Verified vs github morpho-org/morpho-blue v1.0.0 (Authorization struct + Morpho.sol DOMAIN_SEPARATOR).",
  "schema_version": "3",
  "match": {
    "selector": "0x00000001",
    "chain_to_addresses": {
      "1": [
        "0xbbbbbbbbbb9cc5e90e3b3af64bdaf62c37eeffcb"
      ]
    },
    "typed_data": {
      "verifying_contract": "0xbbbbbbbbbb9cc5e90e3b3af64bdaf62c37eeffcb",
      "primary_type": "Authorization",
      "types": {
        "Authorization": [
          {
            "name": "authorizer",
            "type": "address"
          },
          {
            "name": "authorized",
            "type": "address"
          },
          {
            "name": "isAuthorized",
            "type": "bool"
          },
          {
            "name": "nonce",
            "type": "uint256"
          },
          {
            "name": "deadline",
            "type": "uint256"
          }
        ]
      }
    }
  },
  "abi_fragment": {
    "function_name": "Authorization",
    "abi": {
      "name": "Authorization",
      "type": "function",
      "inputs": [
        {
          "name": "authorizer",
          "type": "address"
        },
        {
          "name": "authorized",
          "type": "address"
        },
        {
          "name": "isAuthorized",
          "type": "bool"
        },
        {
          "name": "nonce",
          "type": "uint256"
        },
        {
          "name": "deadline",
          "type": "uint256"
        }
      ]
    }
  },
  "emit": {
    "strategy": "single_emit",
    "body": {
      "domain": "lending",
      "lending": {
