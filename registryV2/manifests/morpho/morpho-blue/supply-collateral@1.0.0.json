{
  "type": "adapter_action",
  "id": "morpho/morpho-blue/supply-collateral@1.0.0",
  "publisher": "morpho.eth",
  "schema_version": "3",
  "match": {
    "selector": "0x238d6579",
    "chain_to_addresses": {
      "1": [
        "0xbbbbbbbbbb9cc5e90e3b3af64bdaf62c37eeffcb"
      ]
    }
  },
  "abi_fragment": {
    "function_name": "supplyCollateral",
    "abi": {
      "name": "supplyCollateral",
      "type": "function",
      "stateMutability": "nonpayable",
      "inputs": [
        {
          "name": "marketParams",
          "type": "tuple",
          "components": [
            {
              "name": "loanToken",
              "type": "address"
            },
            {
              "name": "collateralToken",
              "type": "address"
            },
            {
              "name": "oracle",
              "type": "address"
            },
            {
              "name": "irm",
              "type": "address"
            },
            {
              "name": "lltv",
              "type": "uint256"
            }
          ]
        },
        {
          "name": "assets",
          "type": "uint256"
        },
        {
          "name": "onBehalf",
          "type": "address"
        },
        {
          "name": "data",
          "type": "bytes"
        }
      ],
      "outputs": []
    }
  },
  "emit": {
    "strategy": "single_emit",
    "body": {
      "domain": "lending",
      "lending": {
        "action": "supply",
        "supply": {
          "venue": {
            "name": "morpho_blue",
            "chain": "$chain",
            "market_id": "$derived.morpho_market_id"
          },
          "asset": {
            "key": {
              "standard": "erc20",
              "chain": "$chain",
              "address": "$args.marketParams[1]"
            }
          },
          "amount": "$args.assets",
          "on_behalf_of": "$args.onBehalf"
        }
      }
    },
    "live_inputs": {
      "reserve_state": {
        "source": {
          "kind": "onchain_view",
          "chain": "$chain",
          "contract": "$to",
          "function": "market(bytes32)",
          "decoder_id": "morpho_blue_market"
        },
        "ttl_s": 30
      },
      "supply_apy": {
        "source": {
          "kind": "derived_from",
          "inputs": [],
          "calc_id": "morpho_blue_collateral_supply_apy"
        },
        "ttl_s": 30
      },
      "a_token_price_usd": {
        "source": {
          "kind": "derived_from",
          "inputs": [],
          "calc_id": "morpho_blue_collateral_price"
        },
        "ttl_s": 60
      },
      "eligible_as_collat": {
        "source": {
          "kind": "derived_from",
          "inputs": [],
          "calc_id": "morpho_blue_is_collateral"
        },
        "ttl_s": 60
      },
      "user_state_before": {
        "source": {
          "kind": "onchain_view",
          "chain": "$chain",
          "contract": "$to",
          "function": "position(bytes32,address)",
          "decoder_id": "morpho_blue_position"
        },
        "ttl_s": 12
      }
    }
  }
}
