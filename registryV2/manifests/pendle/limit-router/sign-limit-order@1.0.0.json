{
  "type": "adapter_action",
  "id": "pendle/limit-router/sign-limit-order@1.0.0",
  "publisher": "pendle",
  "schema_version": "3",
  "note": "Off-chain EIP-712 maker-sign of a Pendle limit Order. domain=\"Pendle Limit Order Protocol\" v1, verifying_contract=PendleLimitRouter 0x000000000000c9b3e2c3ec88b1b4c0cd853f4321 (mainnet+Base, identical proxy), primary_type=Order. selector 0x00000001 is a sign-only placeholder (no on-chain call); routing is by (verifying_contract, primary_type) via the typed-data bridge. Order type = pendle-core-v2-public LimitRouterBase ORDER_TYPEHASH. orderType uint8 enum 0..3 mapped via value-map.",
  "match": {
    "selector": "0x00000001",
    "chain_to_addresses": {
      "1": [
        "0x000000000000c9b3e2c3ec88b1b4c0cd853f4321"
      ],
      "8453": [
        "0x000000000000c9b3e2c3ec88b1b4c0cd853f4321"
      ]
    },
    "typed_data": {
      "domain_name": "Pendle Limit Order Protocol",
      "verifying_contract": "0x000000000000c9b3e2c3ec88b1b4c0cd853f4321",
      "primary_type": "Order",
      "types": {
        "Order": [
          {
