          },
          {
            "name": "failSafeRate",
            "type": "uint256"
          },
          {
            "name": "permit",
            "type": "bytes"
          }
        ]
      }
    }
  },
  "abi_fragment": {
    "function_name": "signLimitOrder",
    "abi": {
      "name": "signLimitOrder",
      "type": "function",
      "inputs": [
        {
          "name": "order",
          "type": "tuple",
          "components": [
            {
              "name": "salt",
              "type": "uint256"
            },
            {
              "name": "expiry",
              "type": "uint256"
            },
            {
              "name": "nonce",
