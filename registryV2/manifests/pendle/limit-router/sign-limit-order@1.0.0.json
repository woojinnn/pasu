            }
          ]
        },
        {
          "name": "signature",
          "type": "bytes"
        }
      ],
      "outputs": []
    }
  },
  "emit": {
    "strategy": "single_emit",
    "body": {
      "domain": "yield",
      "yield": {
        "action": "sign_limit_order",
        "sign_limit_order": {
          "venue": {
            "name": "pendle_v2",
            "chain": "$chain"
          },
          "order_type": {
            "$match": "$args.order.orderType",
            "$cases": {
              "0": "sy_for_pt",
              "1": "pt_for_sy",
              "2": "sy_for_yt",
              "3": "yt_for_sy"
            }
          },
          "token": {
            "key": {
              "standard": "erc20",
              "chain": "$chain",
              "address": "$args.order.token"
            }
          },
          "yt": "$args.order.YT",
          "maker": "$args.order.maker",
          "receiver": "$args.order.receiver",
          "making_amount": "$args.order.makingAmount",
          "expiry": "$args.order.expiry"
        }
      }
    },
    "live_inputs": {}
  },
  "requires": {
