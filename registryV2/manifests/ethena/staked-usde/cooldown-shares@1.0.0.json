{
  "type": "adapter_action",
  "id": "ethena/staked-usde/cooldown-shares@1.0.0",
  "publisher": "ethena",
  "note": "Ethena sUSDe cooldownShares(uint256 shares) \u2014 burn `shares` sUSDe, move underlying USDe into the cooldown silo; redeemable via unstake after cooldownDuration. Maps to staking::Cooldown (amount=shares, denomination=shares). selector keccak-verified.",
  "schema_version": "3",
  "match": {
    "selector": "0x9343d9e1",
    "chain_to_addresses": {
      "1": [
        "0x9d39a5de30e57443bff2a8307a4256c8797a3497"
      ]
    }
  },
  "abi_fragment": {
    "function_name": "cooldownShares",
    "abi": {
      "name": "cooldownShares",
      "type": "function",
      "stateMutability": "nonpayable",
      "inputs": [
        {
          "name": "shares",
          "type": "uint256"
        }
      ],
      "outputs": [
        {
          "name": "assets",
          "type": "uint256"
        }
      ]
    }
  },
  "emit": {
    "strategy": "single_emit",
    "body": {
      "domain": "staking",
      "staking": {
        "action": "cooldown",
        "cooldown": {
          "venue": {
            "name": "ethena_staked_usde",
            "chain": "$chain",
            "vault": "$to"
          },
          "amount": "$args.shares",
          "denomination": "shares"
        }
      }
    }
  },
  "requires": {
    "imperative": [],
    "adapter_capabilities": [
      "token_metadata"
    ],
    "host_capabilities": [],
    "extension": ">=0.1.0"
  }
}
