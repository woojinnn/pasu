{
  "type": "adapter_action",
  "id": "compound-v2/comptroller/enterMarkets@1.0.0",
  "publisher": "compound.eth",
  "note": "Compound v2 Comptroller enterMarkets(cTokens): enable each cToken market as collateral (Lending::EnableCollateral, one per array element).",
  "schema_version": "3",
  "match": {
    "selector": "0xc2998238",
    "chain_to_addresses": {
      "1": [
        "0x3d9819210a31b4961b30ef54be2aed79b9c9cd3b"
      ]
    }
  },
  "abi_fragment": {
    "function_name": "enterMarkets",
    "abi": {
      "name": "enterMarkets",
      "type": "function",
      "stateMutability": "nonpayable",
      "inputs": [
        {
          "name": "cTokens",
          "type": "address[]"
        }
      ],
      "outputs": []
    }
  },
  "emit": {
    "strategy": "array_emit",
    "array_source": "$args.cTokens",
    "body": {
      "domain": "lending",
      "lending": {
        "action": "enable_collateral",
        "enable_collateral": {
          "venue": {
            "name": "compound_v2",
            "chain": "$chain",
            "comptroller": "0x3d9819210a31b4961b30ef54be2aed79b9c9cd3b"
          },
          "asset": {
            "key": {
              "standard": "erc20",
              "chain": "$chain",
              "address": "$inputs"
            }
          }
        }
      }
    },
    "live_inputs": {
      "reserve_state": {
        "source": {
          "kind": "derived_from",
          "inputs": [],
          "calc_id": "compound_v2_reserve_state"
        },
        "ttl_s": 30
      },
      "user_state_before": {
        "source": {
          "kind": "derived_from",
          "inputs": [],
          "calc_id": "compound_v2_user_state_before"
        },
        "ttl_s": 12
      }
    }
  }
}
