{
  "type": "adapter_action",
  "id": "compound-v2/ceth/liquidateBorrow@1.0.0",
  "publisher": "compound.eth",
  "note": "Compound v2 cETH liquidateBorrow(borrower,cTokenCollateral): repay ETH debt via msg.value + seize collateral (Lending::Liquidate; payable).",
  "schema_version": "3",
  "match": {
    "selector": "0xaae40a2a",
    "chain_to_addresses": {
      "1": [
        "0x4ddc2d193948926d02f9b1fe9e1daa0718270ed5"
      ]
    }
  },
  "abi_fragment": {
    "function_name": "liquidateBorrow",
    "abi": {
      "name": "liquidateBorrow",
      "type": "function",
      "stateMutability": "payable",
      "inputs": [
        {
          "name": "borrower",
          "type": "address"
        },
        {
          "name": "cTokenCollateral",
          "type": "address"
        }
      ],
      "outputs": []
    }
  },
  "emit": {
    "strategy": "single_emit",
    "body": {
      "domain": "lending",
      "lending": {
        "action": "liquidate",
        "liquidate": {
          "venue": {
            "name": "compound_v2",
            "chain": "$chain",
            "comptroller": "0x3d9819210a31b4961b30ef54be2aed79b9c9cd3b"
          },
          "victim": "$args.borrower",
          "debt_asset": {
            "key": {
              "standard": "native",
              "chain": "$chain",
              "address": "0x0000000000000000000000000000000000000000"
            }
          },
          "collat_asset": {
            "key": {
              "standard": "erc20",
              "chain": "$chain",
              "address": "$args.cTokenCollateral"
            }
          },
          "debt_to_cover": "$tx.value",
          "receive_a_token": false
        }
      }
    },
    "live_inputs": {
      "victim_state": {
        "source": {
          "kind": "derived_from",
          "inputs": [],
          "calc_id": "compound_v2_victim_state"
        },
        "ttl_s": 12
      },
      "liquidation_bonus": {
        "source": {
          "kind": "derived_from",
          "inputs": [],
          "calc_id": "compound_v2_liquidation_bonus"
        },
        "ttl_s": 60
      },
      "debt_asset_price": {
        "source": {
          "kind": "derived_from",
          "inputs": [],
          "calc_id": "compound_v2_debt_asset_price"
        },
        "ttl_s": 60
      },
      "collat_asset_price": {
        "source": {
          "kind": "derived_from",
          "inputs": [],
          "calc_id": "compound_v2_collat_asset_price"
        },
        "ttl_s": 60
      }
    }
  }
