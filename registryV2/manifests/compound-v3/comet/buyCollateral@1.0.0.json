  "schema_version": "3",
  "match": {
    "selector": "0xe4e6e779",
    "chain_to_addresses": {
      "1": [
        "0xc3d688b66703497daa19211eedff47f25384cdc3",
        "0xa17581a9e3356d9a858b789d68b4d866e593ae94"
      ],
      "8453": [
        "0x784efeb622244d2348d4f2522f8860b96fbece89",
        "0x9c4ec768c28520b50860ea7a15bd7213a9ff58bf",
        "0xb125e6687d4313864e53df431d5425969c15eb2f",
        "0x2c776041ccfe903071af44aa147368a9c8eea518",
        "0x46e6b214b524310239732d51387075e0e70970bf"
      ]
    }
  },
  "abi_fragment": {
    "function_name": "buyCollateral",
    "abi": {
      "name": "buyCollateral",
      "type": "function",
      "stateMutability": "nonpayable",
      "inputs": [
        {
          "name": "asset",
          "type": "address"
        },
        {
          "name": "minAmount",
          "type": "uint256"
        },
        {
          "name": "baseAmount",
          "type": "uint256"
        },
        {
          "name": "recipient",
          "type": "address"
        }
      ],
      "outputs": []
    }
  },
  "emit": {
    "strategy": "single_emit",
    "body": {
      "domain": "lending",
      "lending": {
        "action": "buy_collateral",
        "buy_collateral": {
          "venue": {
            "name": "compound_v3",
            "chain": "$chain",
            "comet": "$to",
            "base_asset": {
              "key": {
                "standard": "erc20",
                "chain": "$chain",
                "address": "$resolved.compound_v3_base_asset"
              }
            }
          },
          "collateral_asset": {
            "key": {
              "standard": "erc20",
              "chain": "$chain",
              "address": "$args.asset"
            }
          },
          "base_asset": {
            "key": {
              "standard": "erc20",
              "chain": "$chain",
              "address": "$resolved.compound_v3_base_asset"
            }
          },
          "min_collateral_amount": "$args.minAmount",
          "base_amount": "$args.baseAmount",
          "recipient": "$args.recipient"
        }
      }
    }
  }
}
