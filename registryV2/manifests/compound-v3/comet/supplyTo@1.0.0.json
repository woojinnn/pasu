{
  "type": "adapter_action",
  "id": "compound-v3/comet/supplyTo@1.0.0",
  "publisher": "compound.eth",
  "schema_version": "3",
  "match": {
    "selector": "0x4232cd63",
    "chain_to_addresses": {
      "1": [
        "0xc3d688b66703497daa19211eedff47f25384cdc3",
        "0xa17581a9e3356d9a858b789d68b4d866e593ae94"
      ]
    }
  },
  "abi_fragment": {
    "function_name": "supplyTo",
    "abi": {
      "name": "supplyTo",
      "type": "function",
      "stateMutability": "nonpayable",
      "inputs": [
        { "name": "dst", "type": "address" },
        { "name": "asset", "type": "address" },
        { "name": "amount", "type": "uint256" }
      ],
      "outputs": []
    }
  },
  "emit": {
    "strategy": "single_emit",
    "body": {
      "domain": "lending",
      "lending": {
        "action": "supply",
        "supply": {
          "venue": {
            "name": "compound_v3",
            "chain": "$chain",
            "comet": "$to",
            "base_asset": { "key": { "standard": "erc20", "chain": "$chain", "address": "$resolved.compound_v3_base_asset" } }
          },
          "asset": { "key": { "standard": "erc20", "chain": "$chain", "address": "$args.asset" } },
          "amount": "$args.amount",
          "on_behalf_of": "$args.dst"
        }
      }
    },
    "live_inputs": {
      "reserve_state": { "source": { "kind": "onchain_view", "chain": "$chain", "contract": "$to", "function": "getAssetInfoByAddress(address)", "decoder_id": "compound_v3_asset_info" }, "ttl_s": 30 },
      "supply_apy": { "source": { "kind": "derived_from", "inputs": [], "calc_id": "compound_v3_supply_apy" }, "ttl_s": 30 },
      "a_token_price_usd": { "source": { "kind": "oracle_feed", "provider": "chainlink", "feed_id": "COMPOUND_V3_ASSET_PRICE" }, "ttl_s": 60 },
      "eligible_as_collat": { "source": { "kind": "derived_from", "inputs": [], "calc_id": "compound_v3_eligible_as_collat" }, "ttl_s": 60 },
      "user_state_before": { "source": { "kind": "onchain_view", "chain": "$chain", "contract": "$to", "function": "userBasic(address)", "decoder_id": "compound_v3_user_basic" }, "ttl_s": 12 }
    }
  }
}
