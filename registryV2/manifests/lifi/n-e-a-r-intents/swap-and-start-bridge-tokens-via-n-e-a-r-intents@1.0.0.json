                },
                "token_out": {
                  "key": {
                    "$fn": "token_key_or_native_zero",
                    "$args": [
                      "$inputs[3]",
                      "$chain"
                    ]
                  }
                },
                "direction": {
                  "kind": "exact_input",
                  "amount_in": "$inputs[4]",
                  "min_amount_out": "0x0"
                },
                "recipient": "$to",
                "slippage_bp": 0
