{
  "type": "adapter_action",
  "id": "1inch/aggregation-router-v6/ethUnoswap2@1.0.0",
  "publisher": "1inch.io",
  "schema_version": "3",
  "note": "1inch AggregationRouterV6 ethUnoswap2: direct/multi-hop swap with pool(s) packed in calldata `dex` uint256 word(s) (1inch AddressLib \u2014 low 160 bits = pool address, high bits = direction/protocol flags). Statically decodable: srcToken, amount_in, min_amount_out, recipient, and the packed pool route (route_hash). token_out is OMITTED \u2014 it is the pool's OTHER token, which is not in calldata and requires an on-chain pool token0/token1 read. The decoded static fields bind fund safety (amount_in / min_amount_out / recipient).",
  "match": {
    "selector": "0x89af926a",
    "chain_to_addresses": {
      "1": [
        "0x111111125421ca6dc452d289314280a0f8842a65"
      ]
    }
  },
  "abi_fragment": {
    "function_name": "ethUnoswap2",
    "abi": {
      "name": "ethUnoswap2",
      "type": "function",
      "stateMutability": "payable",
      "inputs": [
        {
          "name": "minReturn",
          "type": "uint256"
        },
        {
          "name": "dex",
          "type": "uint256"
        },
        {
          "name": "dex2",
          "type": "uint256"
        }
      ],
      "outputs": [
        {
          "name": "returnAmount",
          "type": "uint256"
        }
      ]
    }
  },
  "emit": {
    "strategy": "single_emit",
    "body": {
      "domain": "amm",
      "amm": {
        "action": "swap",
        "swap": {
          "venue": {
            "name": "aggregator_route",
            "chain": "$chain",
            "router": "$to",
            "route_hash": {
              "$fn": "unoswap_route_hash",
              "$args": [
                "$args.dex",
                "$args.dex2"
              ]
            }
          },
          "params": {
            "token_in": {
              "key": {
                "standard": "native",
                "chain": "$chain"
              }
            },
            "direction": {
              "kind": "exact_input",
              "amount_in": "$tx.value",
              "min_amount_out": "$args.minReturn"
            },
            "recipient": "$tx.from",
            "slippage_bp": 0
          },
          "live_inputs": {
            "route": {
              "source": {
                "kind": "derived_from",
                "inputs": [
                  {
                    "scope": "global",
                    "name": "oneinch_v6_route"
                  }
                ],
                "calc_id": "oneinch_v6_route"
              },
              "ttl_s": 12
            },
            "expected_amount_out": {
              "source": {
                "kind": "derived_from",
                "inputs": [
                  {
                    "scope": "global",
                    "name": "oneinch_v6_route"
                  }
                ],
                "calc_id": "oneinch_v6_expected_out"
              },
              "ttl_s": 12
            },
            "price_impact_bp": {
              "source": {
                "kind": "derived_from",
                "inputs": [
                  {
                    "scope": "global",
                    "name": "oneinch_v6_route"
                  }
                ],
                "calc_id": "oneinch_v6_price_impact_bp"
              },
              "ttl_s": 12
            },
            "gas_estimate": {
              "source": {
                "kind": "oracle_feed",
                "provider": "pyth",
                "feed_id": "gas/ethereum"
              },
              "ttl_s": 6
            }
          }
        }
      }
    }
  },
  "requires": {
    "imperative": [],
    "adapter_capabilities": [
      "token_metadata"
    ],
    "host_capabilities": [],
    "extension": ">=0.1.0"
  }
}
