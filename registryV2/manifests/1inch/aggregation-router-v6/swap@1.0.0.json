{
  "type": "adapter_action",
  "id": "1inch/aggregation-router-v6/swap@1.0.0",
  "publisher": "1inch.io",
  "schema_version": "3",
  "match": {
    "selector": "0x07ed2379",
    "chain_to_addresses": {
      "1": [
        "0x111111125421ca6dc452d289314280a0f8842a65"
      ]
    }
  },
  "abi_fragment": {
    "function_name": "swap",
    "abi": {
      "name": "swap",
      "type": "function",
      "stateMutability": "payable",
      "inputs": [
        { "name": "executor", "type": "address" },
        {
          "name": "desc",
          "type": "tuple",
          "components": [
            { "name": "srcToken", "type": "address" },
            { "name": "dstToken", "type": "address" },
            { "name": "srcReceiver", "type": "address" },
            { "name": "dstReceiver", "type": "address" },
            { "name": "amount", "type": "uint256" },
            { "name": "minReturnAmount", "type": "uint256" },
            { "name": "flags", "type": "uint256" }
          ]
        },
        { "name": "data", "type": "bytes" }
      ],
      "outputs": [
        { "name": "returnAmount", "type": "uint256" },
        { "name": "spentAmount", "type": "uint256" }
      ]
    }
  },
  "emit": {
    "strategy": "single_emit",
    "body": {
      "domain": "amm",
      "amm": {
        "action": "swap",
        "swap": {
          "venue": {
            "name": "aggregator_route",
            "chain": "$chain",
            "router": "$to",
            "route_hash": { "$fn": "keccak256", "$args": ["$args.data"] }
          },
          "params": {
            "token_in": {
              "key": { "standard": "erc20", "chain": "$chain", "address": "$args.desc[0]" }
            },
            "token_out": {
              "key": { "standard": "erc20", "chain": "$chain", "address": "$args.desc[1]" }
            },
            "direction": {
              "kind": "exact_input",
              "amount_in": "$args.desc[4]",
              "min_amount_out": "$args.desc[5]"
            },
            "recipient": "$args.desc[3]",
            "slippage_bp": 0
          },
          "live_inputs": {
            "route": {
              "source": {
                "kind": "derived_from",
                "inputs": [{ "scope": "global", "name": "oneinch_v6_route" }],
                "calc_id": "oneinch_v6_route"
              },
              "ttl_s": 12
            },
            "expected_amount_out": {
              "source": {
                "kind": "derived_from",
                "inputs": [{ "scope": "global", "name": "oneinch_v6_route" }],
                "calc_id": "oneinch_v6_expected_out"
              },
              "ttl_s": 12
            },
            "price_impact_bp": {
              "source": {
                "kind": "derived_from",
                "inputs": [{ "scope": "global", "name": "oneinch_v6_route" }],
                "calc_id": "oneinch_v6_price_impact_bp"
              },
              "ttl_s": 12
            },
            "gas_estimate": {
              "source": { "kind": "oracle_feed", "provider": "pyth", "feed_id": "gas/ethereum" },
              "ttl_s": 6
            }
          }
        }
      }
    }
  },
  "requires": {
    "imperative": [],
    "adapter_capabilities": ["token_metadata"],
    "host_capabilities": [],
    "extension": ">=0.1.0"
  }
}
