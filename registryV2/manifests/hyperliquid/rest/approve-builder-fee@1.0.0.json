{
  "type": "adapter_action",
  "id": "hyperliquid/rest/approve-builder-fee@1.0.0",
  "publisher": "hyperliquid",
  "schema_version": "3",
  "_note_mapping": "HyperLiquid Mode B `HyperliquidTransaction:ApproveBuilderFee` — off-chain L1 approval of a `maxFeeRate` (decimal-string percentage) payable to a `builder` address, signed via eth_signTypedData_v4. This is a protocol-level permission primitive, so it maps to Permission::ProtocolAuthorization with permission=builder_fee, authorizer=$tx.from, authorized=builder, permission_limit=maxFeeRate.",
  "match": {
    "selector": "0x0000000c",
    "chain_to_addresses": {
      "42161": ["0x0000000000000000000000000000000000000000"],
      "421614": ["0x0000000000000000000000000000000000000000"]
    },
    "typed_data": {
      "domain_name": "HyperliquidSignTransaction",
      "verifying_contract": "0x0000000000000000000000000000000000000000",
      "primary_type": "HyperliquidTransaction:ApproveBuilderFee",
      "types": {
        "HyperliquidTransaction:ApproveBuilderFee": [
          { "name": "hyperliquidChain", "type": "string" },
          { "name": "maxFeeRate", "type": "string" },
          { "name": "builder", "type": "address" },
          { "name": "nonce", "type": "uint64" }
        ]
      }
    }
  },
  "abi_fragment": {
    "function_name": "approveBuilderFee",
    "abi": {
      "name": "approveBuilderFee",
      "type": "function",
      "inputs": [
        {
          "name": "approveBuilderFee",
          "type": "tuple",
          "components": [
            { "name": "hyperliquidChain", "type": "string" },
            { "name": "maxFeeRate", "type": "string" },
            { "name": "builder", "type": "address" },
            { "name": "nonce", "type": "uint64" }
          ]
        }
      ]
    }
  },
  "emit": {
    "strategy": "single_emit",
    "body": {
      "domain": "permission",
      "permission": {
        "action": "protocol_authorization",
        "protocol_authorization": {
          "chain": "$chain",
          "protocol": "0x0000000000000000000000000000000000000000",
          "protocol_name": "hyperliquid",
          "permission": "builder_fee",
          "permission_limit": "$args.approveBuilderFee.maxFeeRate",
          "authorizer": "$tx.from",
          "authorized": "$args.approveBuilderFee.builder",
          "is_authorized": true
        }
      }
    }
  },
  "requires": {
    "imperative": [],
    "adapter_capabilities": [],
    "host_capabilities": [],
    "extension": ">=0.1.0"
  }
}
