              "standard": "erc20",
              "chain": "$chain",
              "address": "$inputs"
            }
          },
          "gauges": [
            "$args.stakeToken"
          ],
          "on_behalf_of": null,
          "recipient": null,
          "restake": "$args.restake"
        }
      }
    }
  }
