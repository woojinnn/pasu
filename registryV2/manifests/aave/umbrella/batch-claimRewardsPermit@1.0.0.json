      "inputs": [
        {
          "components": [
            {
              "internalType": "contract IStakeToken",
              "name": "stakeToken",
              "type": "address"
            },
            {
              "internalType": "address[]",
              "name": "rewards",
              "type": "address[]"
            },
            {
              "internalType": "uint256",
              "name": "deadline",
              "type": "uint256"
            },
            {
              "internalType": "uint8",
              "name": "v",
              "type": "uint8"
            },
            {
              "internalType": "bytes32",
              "name": "r",
              "type": "bytes32"
            },
            {
              "internalType": "bytes32",
              "name": "s",
              "type": "bytes32"
            },
            {
              "internalType": "bool",
              "name": "restake",
              "type": "bool"
            }
          ],
          "internalType": "struct IUmbrellaBatchHelper.ClaimPermit",
          "name": "p",
          "type": "tuple"
        }
      ],
      "name": "claimRewardsPermit",
      "outputs": [],
      "stateMutability": "nonpayable",
      "type": "function"
    }
  },
  "emit": {
