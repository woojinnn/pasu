{
  "type": "adapter_action",
  "id": "aave/v3/l2SupplyWithPermitPacked@1.0.0",
  "publisher": "aave.eth",
  "schema_version": "3",
  "note": "Aave V3 L2Pool.supplyWithPermit(bytes32,bytes32,bytes32) packs supply fields plus permit metadata. Signature r/s are decoded only by the ABI layer and are not emitted; V3 WASM derives the lending supply intent from packed args.",
  "match": {
    "selector": "0x680dd47c",
    "chain_to_addresses": {
      "8453": ["0xa238dd80c259a72e81d7e4664a9801593f98d1c5"],
      "42161": ["0x794a61358d6845594f94dc1db02a252b5b4814ad"]
    }
  },
  "abi_fragment": {
    "function_name": "supplyWithPermit",
    "abi": {
      "name": "supplyWithPermit",
      "type": "function",
      "stateMutability": "nonpayable",
      "inputs": [
        { "name": "args", "type": "bytes32" },
        { "name": "r", "type": "bytes32" },
        { "name": "s", "type": "bytes32" }
      ],
      "outputs": []
    }
  },
  "emit": {
    "strategy": "single_emit",
    "body": {
      "domain": "lending",
      "lending": {
        "action": "supply",
        "supply": {
          "venue": {
            "name": "aave_v3",
            "chain": "$chain",
            "pool": "$to",
            "market_id": null
          },
          "asset": { "key": { "standard": "erc20", "chain": "$chain", "address": "$derived.aave_l2_asset" } },
          "amount": "$derived.aave_l2_amount",
          "on_behalf_of": "$tx.from"
        }
      }
    },
    "live_inputs": {
      "reserve_state": {
        "source": {
          "kind": "onchain_view",
          "chain": "$chain",
          "contract": "$to",
          "function": "getReserveData(address)",
          "decoder_id": "aave_v3_reserve_data"
        },
        "ttl_s": 30
      },
      "supply_apy": {
        "source": {
          "kind": "derived_from",
          "inputs": [],
          "calc_id": "aave_v3_supply_apy"
        },
        "ttl_s": 30
      },
      "a_token_price_usd": {
        "source": {
          "kind": "oracle_feed",
          "provider": "chainlink",
          "feed_id": "AAVE_V3_RESERVE_PRICE"
        },
        "ttl_s": 60
      },
      "eligible_as_collat": {
        "source": {
          "kind": "onchain_view",
          "chain": "$chain",
          "contract": "$to",
          "function": "getConfiguration(address)",
          "decoder_id": "aave_v3_reserve_config"
        },
        "ttl_s": 60
      },
      "user_state_before": {
        "source": {
          "kind": "onchain_view",
          "chain": "$chain",
          "contract": "$to",
          "function": "getUserAccountData(address)",
          "decoder_id": "aave_v3_user_account_data"
        },
        "ttl_s": 12
      }
    }
  },
  "requires": {
    "imperative": [],
    "adapter_capabilities": [],
    "host_capabilities": [],
    "extension": ">=0.1.0"
  }
}
