{
  "type": "adapter_action",
  "id": "aave/v3/l2WithdrawPacked@1.0.0",
  "publisher": "aave.eth",
  "schema_version": "3",
  "note": "Aave V3 L2Pool.withdraw(bytes32) packs reserve index and amount into bytes32. The V3 WASM route bit-slices args, resolves supported-chain reserve id to asset address, expands uint128.max to uint256.max, and L2Pool uses _msgSender() as recipient.",
  "match": {
    "selector": "0x8e19899e",
    "chain_to_addresses": {
      "8453": ["0xa238dd80c259a72e81d7e4664a9801593f98d1c5"],
      "42161": ["0x794a61358d6845594f94dc1db02a252b5b4814ad"]
    }
  },
  "abi_fragment": {
    "function_name": "withdraw",
    "abi": {
      "name": "withdraw",
      "type": "function",
      "stateMutability": "nonpayable",
      "inputs": [
        { "name": "args", "type": "bytes32" }
      ],
      "outputs": [
        { "name": "", "type": "uint256" }
      ]
    }
  },
  "emit": {
    "strategy": "single_emit",
    "body": {
      "domain": "lending",
      "lending": {
        "action": "withdraw",
        "withdraw": {
          "venue": {
            "name": "aave_v3",
            "chain": "$chain",
            "pool": "$to",
            "market_id": null
          },
          "asset": { "key": { "standard": "erc20", "chain": "$chain", "address": "$derived.aave_l2_asset" } },
          "amount": "$derived.aave_l2_amount",
          "recipient": "$tx.from"
        }
      }
    },
    "live_inputs": {
      "reserve_state": {
        "source": {
          "kind": "onchain_view",
          "chain": "$chain",
          "contract": "$to",
          "function": "getReserveData(address)",
          "decoder_id": "aave_v3_reserve_data"
        },
        "ttl_s": 30
      },
      "available_to_withdraw": {
        "source": {
          "kind": "derived_from",
          "inputs": [],
          "calc_id": "aave_v3_available_to_withdraw"
        },
        "ttl_s": 30
      },
      "user_state_before": {
        "source": {
          "kind": "onchain_view",
          "chain": "$chain",
          "contract": "$to",
          "function": "getUserAccountData(address)",
          "decoder_id": "aave_v3_user_account_data"
        },
        "ttl_s": 12
      }
    }
  },
  "requires": {
    "imperative": [],
    "adapter_capabilities": [],
    "host_capabilities": [],
    "extension": ">=0.1.0"
  }
}
