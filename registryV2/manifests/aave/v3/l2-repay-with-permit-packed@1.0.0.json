{
  "type": "adapter_action",
  "id": "aave/v3/l2RepayWithPermitPacked@1.0.0",
  "publisher": "aave.eth",
  "schema_version": "3",
  "note": "Aave V3 Base L2Pool.repayWithPermit(bytes32,bytes32,bytes32) packs repay fields plus permit metadata. Signature r/s are decoded only by the ABI layer and are not emitted; V3 WASM derives the lending repay intent from packed args.",
  "match": {
    "selector": "0x94b576de",
    "chain_to_addresses": {
      "8453": ["0xa238dd80c259a72e81d7e4664a9801593f98d1c5"]
    }
  },
  "abi_fragment": {
    "function_name": "repayWithPermit",
    "abi": {
      "name": "repayWithPermit",
      "type": "function",
      "stateMutability": "nonpayable",
      "inputs": [
        { "name": "args", "type": "bytes32" },
        { "name": "r", "type": "bytes32" },
        { "name": "s", "type": "bytes32" }
      ],
      "outputs": [
        { "name": "", "type": "uint256" }
      ]
    }
  },
  "emit": {
    "strategy": "single_emit",
    "body": {
      "domain": "lending",
      "lending": {
        "action": "repay",
        "repay": {
          "venue": {
            "name": "aave_v3",
            "chain": "$chain",
            "pool": "$to",
            "market_id": null
          },
          "asset": { "key": { "standard": "erc20", "chain": "$chain", "address": "$derived.aave_l2_asset" } },
          "amount": "$derived.aave_l2_amount",
          "rate_mode": { "$match": "$derived.aave_l2_rate_mode", "$cases": { "1": "stable", "2": "variable" } },
          "on_behalf_of": "$tx.from",
          "use_a_tokens": false
        }
      }
    },
    "live_inputs": {
      "reserve_state": {
        "source": {
          "kind": "onchain_view",
          "chain": "$chain",
          "contract": "$to",
          "function": "getReserveData(address)",
          "decoder_id": "aave_v3_reserve_data"
        },
        "ttl_s": 30
      },
      "current_debt": {
        "source": {
          "kind": "derived_from",
          "inputs": [],
          "calc_id": "aave_v3_current_debt"
        },
        "ttl_s": 12
      },
      "user_state_before": {
        "source": {
          "kind": "onchain_view",
          "chain": "$chain",
          "contract": "$to",
          "function": "getUserAccountData(address)",
          "decoder_id": "aave_v3_user_account_data"
        },
        "ttl_s": 12
      }
    }
  },
  "requires": {
    "imperative": [],
    "adapter_capabilities": [],
    "host_capabilities": [],
    "extension": ">=0.1.0"
  }
}
