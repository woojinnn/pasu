{
  "type": "adapter_action",
  "id": "aave/v3/l2BorrowPacked@1.0.0",
  "publisher": "aave.eth",
  "schema_version": "3",
  "note": "Aave V3 L2Pool.borrow(bytes32) packs reserve index, amount, rate mode, and referral code into bytes32. The V3 WASM route bit-slices args, resolves supported-chain reserve id to asset address, and L2Pool uses _msgSender() as onBehalfOf.",
  "match": {
    "selector": "0xd5eed868",
    "chain_to_addresses": {
      "8453": ["0xa238dd80c259a72e81d7e4664a9801593f98d1c5"],
      "42161": ["0x794a61358d6845594f94dc1db02a252b5b4814ad"]
    }
  },
  "abi_fragment": {
    "function_name": "borrow",
    "abi": {
      "name": "borrow",
      "type": "function",
      "stateMutability": "nonpayable",
      "inputs": [
        { "name": "args", "type": "bytes32" }
      ],
      "outputs": []
    }
  },
  "emit": {
    "strategy": "single_emit",
    "body": {
      "domain": "lending",
      "lending": {
        "action": "borrow",
        "borrow": {
          "venue": {
            "name": "aave_v3",
            "chain": "$chain",
            "pool": "$to",
            "market_id": null
          },
          "asset": { "key": { "standard": "erc20", "chain": "$chain", "address": "$derived.aave_l2_asset" } },
          "amount": "$derived.aave_l2_amount",
          "rate_mode": { "$match": "$derived.aave_l2_rate_mode", "$cases": { "1": "stable", "2": "variable" } },
          "on_behalf_of": "$tx.from"
        }
      }
    },
    "live_inputs": {
      "reserve_state": {
        "source": {
          "kind": "onchain_view",
          "chain": "$chain",
          "contract": "$to",
          "function": "getReserveData(address)",
          "decoder_id": "aave_v3_reserve_data"
        },
        "ttl_s": 30
      },
      "user_state_before": {
        "source": {
          "kind": "onchain_view",
          "chain": "$chain",
          "contract": "$to",
          "function": "getUserAccountData(address)",
          "decoder_id": "aave_v3_user_account_data"
        },
        "ttl_s": 12
      },
      "asset_price_usd": {
        "source": {
          "kind": "oracle_feed",
          "provider": "chainlink",
          "feed_id": "AAVE_V3_RESERVE_PRICE"
        },
        "ttl_s": 60
      },
      "current_borrow_rate": {
        "source": {
          "kind": "derived_from",
          "inputs": [],
          "calc_id": "aave_v3_borrow_rate"
        },
        "ttl_s": 30
      },
      "available_liquidity": {
        "source": {
          "kind": "derived_from",
          "inputs": [],
          "calc_id": "aave_v3_available_liquidity"
        },
        "ttl_s": 30
      }
    }
  },
  "requires": {
    "imperative": [],
    "adapter_capabilities": [],
    "host_capabilities": [],
    "extension": ">=0.1.0"
  }
}
