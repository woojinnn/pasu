{
  "type": "adapter_action",
  "id": "aave/governance/core/updateRepresentativesForChain@1.0.0",
  "publisher": "aave.eth",
  "schema_version": "3",
  "note": "Aave Governance V3 representative updates expanded per representative tuple.",
  "match": {
    "selector": "0x133539ec",
    "chain_to_addresses": {
      "1": [
        "0x9aee0b04504cef83a65ac3f0e838d0593bcb2bc7"
      ]
    }
  },
  "abi_fragment": {
    "function_name": "updateRepresentativesForChain",
    "abi": {
      "inputs": [
        {
          "components": [
            {
              "internalType": "address",
              "name": "representative",
              "type": "address"
            },
            {
              "internalType": "uint256",
              "name": "chainId",
              "type": "uint256"
            }
          ],
          "internalType": "struct IGovernanceCore.RepresentativeInput[]",
          "name": "representatives",
          "type": "tuple[]"
        }
      ],
      "name": "updateRepresentativesForChain",
      "outputs": [],
      "stateMutability": "nonpayable",
      "type": "function"
    }
  },
  "emit": {
    "strategy": "array_emit",
    "array_source": "$args.representatives",
    "per_item_body": {
      "domain": "governance",
      "governance": {
        "action": "update_representative",
        "update_representative": {
          "venue": {
            "name": "aave_governance_v3",
            "chain": "$chain",
            "governance": "$to"
          },
          "representative": "$inputs[0]",
          "representative_chain_id": "$inputs[1]"
        }
      }
    }
  }
}
