  "match": {
    "selector": "0x867b96c2",
    "chain_to_addresses": {
      "1": [
        "0x06a1795a88b82700896583e123f46be43877bfb6"
      ]
    }
  },
  "abi_fragment": {
    "function_name": "closeAndSendVote",
    "abi": {
      "inputs": [
        {
          "internalType": "uint256",
          "name": "proposalId",
          "type": "uint256"
        }
      ],
      "name": "closeAndSendVote",
      "outputs": [],
      "stateMutability": "nonpayable",
      "type": "function"
    }
  },
  "emit": {
    "strategy": "single_emit",
    "body": {
      "domain": "governance",
