{
  "type": "adapter_action",
  "id": "lido/steth/transferShares@1.0.0",
  "publisher": "lido.eth",
  "schema_version": "3",
  "match": {
    "selector": "0x8fcb4e5b",
    "chain_to_addresses": {
      "1": ["0xae7ab96520de3a18e5e111b5eaab095312d7fe84"]
    }
  },
  "abi_fragment": {
    "function_name": "transferShares",
    "abi": {
      "name": "transferShares",
      "type": "function",
      "stateMutability": "nonpayable",
      "inputs": [
        { "name": "_recipient", "type": "address" },
        { "name": "_sharesAmount", "type": "uint256" }
      ],
      "outputs": []
    }
  },
  "emit": {
    "strategy": "single_emit",
    "body": {
      "domain": "liquid_staking",
      "liquid_staking": {
        "action": "transfer_shares",
        "transfer_shares": {
          "venue": { "name": "lido", "chain": "$chain" },
          "recipient": "$args._recipient",
          "shares": "$args._sharesAmount"
        }
      }
    },
    "live_inputs": {
      "pooled_eth": {
        "source": {
          "kind": "onchain_view",
          "chain": "$chain",
          "contract": "$to",
          "function": "getPooledEthByShares(uint256)",
          "decoder_id": "u256"
        },
        "ttl_s": 30
      }
    }
  }
}
